---
import LayoutSidebar from '../layouts/LayoutSidebar.astro';

const sidebarMenu = {
    title: "Layanan & Aturan",
    items: [{"label": "Tata Tertib Pemustaka", "href": "/tata-tertib"}, {"label": "Panduan Ruangan Gedung", "href": "/panduan-ruangan"}, {"label": "Kontak & Lokasi", "href": "/kontak"}, {"label": "Survei Kepuasan (IKM)", "href": "/survei"}]
};
---

<LayoutSidebar title="Survei Kepuasan (IKM)" sidebarMenu={sidebarMenu}>
    
    <div class="mb-10 text-left">
        <p class="font-serif text-[15px] text-[#444444] leading-relaxed">
            Perpustakaan IAIN Sorong berkomitmen untuk terus meningkatkan kualitas layanan. Partisipasi Anda dalam mengisi <strong class="text-[#168940]">Indeks Kepuasan Masyarakat (IKM)</strong> sangat berharga bagi evaluasi kami.
        </p>
    </div>

    <!-- Form Container -->
    <div class="bg-white border border-[#dadada] rounded-[8px] p-6 md:p-8 shadow-sm mb-8">
        
        <div class="flex items-center gap-4 mb-8 pb-6 border-b border-[#dadada]">
            <div class="w-12 h-12 bg-[#F0FDF4] border border-[#dadada] text-[#168940] rounded-[8px] flex items-center justify-center shadow-sm">
                <iconify-icon icon="flat-color-icons:inspection" ></iconify-icon>
            </div>
            <div>
                <h3 class="text-xl font-semibold text-[#222222] m-0 tracking-tight">Formulir Survei</h3>
                <p class="font-serif text-sm text-[#666666] m-0">Waktu pengisian sekitar 2-3 menit</p>
            </div>
        </div>

        <form class="space-y-6" onsubmit="event.preventDefault(); alert('Terima kasih atas partisipasi Anda!');">
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <!-- Status -->
                <div>
                    <label class="block text-sm font-semibold text-[#222222] mb-2">Status Pengguna <span class="text-red-500">*</span></label>
                    <select class="w-full bg-[#F8FAFC] border border-[#dadada] text-[#444444] font-serif rounded-[4px] px-4 py-3 focus:outline-none focus:ring-[3px] focus:ring-[#EAB308]/30 focus:border-[#168940] transition-colors appearance-none cursor-pointer" required>
                        <option value="" disabled selected>Pilih status Anda...</option>
                        <option value="mahasiswa">Mahasiswa IAIN Sorong</option>
                        <option value="dosen">Dosen / Tenaga Pengajar</option>
                        <option value="tendik">Tenaga Kependidikan</option>
                        <option value="umum">Masyarakat Umum / Peneliti Luar</option>
                    </select>
                </div>

                <!-- Fakultas -->
                <div>
                    <label class="block text-sm font-semibold text-[#222222] mb-2">Fakultas / Instansi</label>
                    <input type="text" placeholder="Cth: Fakultas Tarbiyah" class="w-full bg-[#F8FAFC] border border-[#dadada] text-[#444444] font-serif rounded-[4px] px-4 py-3 focus:outline-none focus:ring-[3px] focus:ring-[#EAB308]/30 focus:border-[#168940] transition-colors">
                </div>
            </div>

            <div class="w-full h-px bg-[#dadada] my-6"></div>

            <!-- Penilaian -->
            <div class="space-y-4">
                <label class="block text-sm font-semibold text-[#222222] mb-2">Bagaimana penilaian Anda terhadap kelengkapan koleksi buku kami? <span class="text-red-500">*</span></label>
                <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
                    <label class="cursor-pointer group">
                        <input type="radio" name="koleksi" class="peer sr-only" required>
                        <div class="text-center p-4 rounded-[4px] border border-[#dadada] peer-checked:bg-[#168940] peer-checked:text-white peer-checked:border-[#168940] group-hover:bg-[#F8FAFC] transition-colors text-[#666666]">
                            <iconify-icon icon="flat-color-icons:landscape" class="mb-2"></iconify-icon>
                            <div class="text-sm font-semibold">Sangat Baik</div>
                        </div>
                    </label>
                    <label class="cursor-pointer group">
                        <input type="radio" name="koleksi" class="peer sr-only">
                        <div class="text-center p-4 rounded-[4px] border border-[#dadada] peer-checked:bg-[#168940] peer-checked:text-white peer-checked:border-[#168940] group-hover:bg-[#F8FAFC] transition-colors text-[#666666]">
                            <iconify-icon icon="flat-color-icons:happy" class="mb-2"></iconify-icon>
                            <div class="text-sm font-semibold">Baik</div>
                        </div>
                    </label>
                    <label class="cursor-pointer group">
                        <input type="radio" name="koleksi" class="peer sr-only">
                        <div class="text-center p-4 rounded-[4px] border border-[#dadada] peer-checked:bg-amber-500 peer-checked:text-white peer-checked:border-amber-500 group-hover:bg-[#F8FAFC] transition-colors text-[#666666]">
                            <iconify-icon icon="flat-color-icons:sad" class="mb-2"></iconify-icon>
                            <div class="text-sm font-semibold">Cukup</div>
                        </div>
                    </label>
                    <label class="cursor-pointer group">
                        <input type="radio" name="koleksi" class="peer sr-only">
                        <div class="text-center p-4 rounded-[4px] border border-[#dadada] peer-checked:bg-red-500 peer-checked:text-white peer-checked:border-red-500 group-hover:bg-[#F8FAFC] transition-colors text-[#666666]">
                            <iconify-icon icon="flat-color-icons:sad" class="mb-2"></iconify-icon>
                            <div class="text-sm font-semibold">Kurang</div>
                        </div>
                    </label>
                </div>
            </div>

            <!-- Saran -->
            <div class="pt-4">
                <label class="block text-sm font-semibold text-[#222222] mb-2">Kritik & Saran Membangun</label>
                <textarea rows="4" placeholder="Tuliskan masukan Anda di sini..." class="w-full bg-[#F8FAFC] border border-[#dadada] text-[#444444] font-serif rounded-[4px] px-4 py-3 focus:outline-none focus:ring-[3px] focus:ring-[#EAB308]/30 focus:border-[#168940] transition-colors resize-none"></textarea>
            </div>

            <!-- Submit -->
            <div class="pt-4">
                <button type="submit" class="w-full md:w-auto bg-[#168940] hover:bg-[#0B4226] text-white font-semibold py-3 px-8 rounded-[4px] transition-colors flex items-center justify-center gap-2 shadow-sm focus:outline-none focus:ring-[3px] focus:ring-[#EAB308]">
                    <iconify-icon icon="flat-color-icons:paper-plane" ></iconify-icon>
                    Kirim Penilaian
                </button>
            </div>

        </form>
    </div>

</LayoutSidebar>
