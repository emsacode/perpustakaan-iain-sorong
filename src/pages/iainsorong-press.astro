---
import LayoutSidebar from '../layouts/LayoutSidebar.astro';

const sidebarMenu = {
    title: "Layanan & Koleksi",
    items: [{"label": "Sistem Otomasi (SORPUS)", "href": "/sorpus"}, {"label": "Keanggotaan Online", "href": "/k-online"}, {"label": "IAIN Sorong Press", "href": "/iainsorong-press"}]
};
---

<LayoutSidebar title="IAIN Sorong Press" sidebarMenu={sidebarMenu}>
    
    <!-- Hero Banner for Press -->
    <div class="bg-white border border-[#dadada] rounded-[8px] overflow-hidden mb-12 shadow-sm relative group hover:border-[#BBF7D0] transition-all flex flex-col items-center text-center p-10 md:p-14">
        <!-- Decoration -->
        <div class="absolute right-0 top-0 w-40 h-40 bg-[#FFFBEB] rounded-bl-full opacity-70 z-0"></div>
        <div class="absolute left-0 bottom-0 w-32 h-32 bg-[#F0FDF4] rounded-tr-full opacity-70 z-0"></div>
        
        <div class="relative z-10 w-20 h-20 bg-[#FFFBEB] border border-[#FDE68A] rounded-[8px] flex items-center justify-center text-amber-600 mb-6 group-hover:border-amber-400 transition-colors">
            <iconify-icon icon="flat-color-icons:bookmark" ></iconify-icon>
        </div>
        
        <div class="relative z-10 uppercase tracking-widest text-xs font-semibold text-amber-600 mb-2">Penerbitan & Publikasi</div>
        <h2 class="relative z-10 text-3xl md:text-4xl font-semibold text-[#222222] mb-4 tracking-tight m-0">IAIN Sorong Press</h2>
        <p class="relative z-10 font-serif text-[15px] text-[#444444] mb-8 leading-relaxed max-w-2xl mx-auto m-0">Unit penerbitan kampus yang menaungi publikasi karya ilmiah, buku ajar, monograf, dan prosiding dari civitas academica IAIN Sorong.</p>
        
        <a href="#" class="relative z-10 inline-flex items-center gap-2 bg-amber-600 hover:bg-amber-700 text-white font-semibold py-3 px-8 rounded-[4px] shadow-sm transition-colors focus:outline-none focus:ring-[3px] focus:ring-amber-300 text-sm no-underline">
            Kunjungi Portal OMP
            <iconify-icon icon="flat-color-icons:up-right" ></iconify-icon>
        </a>
    </div>

    <!-- Intro Text -->
    <div class="mb-10 text-left">
        <h3 class="text-2xl font-semibold text-[#222222] mb-4 m-0 tracking-tight">Mewadahi Literasi & Intelektualitas Kampus</h3>
        <p class="font-serif text-[15px] text-[#444444] leading-relaxed max-w-3xl m-0">
            Perpustakaan tidak hanya sebagai tempat mengumpulkan buku, namun juga sebagai motor penggerak literasi dan publikasi. IAIN Sorong Press hadir untuk memfasilitasi penerbitan buku ber-ISBN secara profesional.
        </p>
    </div>

    <!-- Layanan Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-10">
        
        <div class="bg-white border border-[#dadada] p-6 rounded-[8px] shadow-sm text-center group hover:border-[#BBF7D0] hover:shadow-md transition-all">
            <div class="w-12 h-12 bg-[#EFF6FF] text-blue-600 border border-[#BFDBFE] rounded-[8px] flex items-center justify-center mx-auto mb-4 group-hover:bg-blue-600 group-hover:text-white transition-colors">
                <iconify-icon icon="flat-color-icons:edit-image" ></iconify-icon>
            </div>
            <h4 class="font-semibold text-[#222222] mb-2 m-0">Penyuntingan & Layout</h4>
            <p class="font-serif text-[13px] text-[#666666] m-0 leading-relaxed">Layanan proofreading dan tata letak profesional sesuai standar penerbitan akademik nasional.</p>
        </div>

        <div class="bg-white border border-[#dadada] p-6 rounded-[8px] shadow-sm text-center group hover:border-[#BBF7D0] hover:shadow-md transition-all">
            <div class="w-12 h-12 bg-[#FFFBEB] text-amber-600 border border-[#FDE68A] rounded-[8px] flex items-center justify-center mx-auto mb-4 group-hover:bg-amber-600 group-hover:text-white transition-colors">
                <iconify-icon icon="flat-color-icons:barcode-reader" ></iconify-icon>
            </div>
            <h4 class="font-semibold text-[#222222] mb-2 m-0">Pengurusan ISBN</h4>
            <p class="font-serif text-[13px] text-[#666666] m-0 leading-relaxed">Fasilitasi pendaftaran International Standard Book Number (ISBN) ke Perpustakaan Nasional RI.</p>
        </div>

        <div class="bg-white border border-[#dadada] p-6 rounded-[8px] shadow-sm text-center group hover:border-[#BBF7D0] hover:shadow-md transition-all">
            <div class="w-12 h-12 bg-[#F0FDF4] text-[#168940] border border-[#dadada] rounded-[8px] flex items-center justify-center mx-auto mb-4 group-hover:bg-[#168940] group-hover:text-white transition-colors">
                <iconify-icon icon="flat-color-icons:shop" ></iconify-icon>
            </div>
            <h4 class="font-semibold text-[#222222] mb-2 m-0">Pemasaran Digital</h4>
            <p class="font-serif text-[13px] text-[#666666] m-0 leading-relaxed">Buku yang diterbitkan akan dipasarkan dan diindeks melalui portal Open Monograph Press (OMP).</p>
        </div>

    </div>

</LayoutSidebar>
