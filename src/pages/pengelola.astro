---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const team = [
  { role: "Dukungan Riset & Publikasi", name: "Drs. MUHAMMAD SATIR, M.Pd.I", image: "/images/team/Drs. Muhammad Satir, M.Pd.I. - Kepala Perpustakaan.png" },
  { role: "Kerja Sama & Promosi", name: "MUTAWALLI, S.Hum", image: "/images/team/Mutawalli, S.Hum. - Pengembangan Koleksi.png" },
  { role: "Tata Usaha", name: "ZULFIKAR, S.Sos.", image: null },
  { role: "Pengembangan Koleksi", name: "LA EMPE, SP.i", image: "/images/team/La Empe.S.Pi. - Layanan Pemustaka.png" },
  { role: "Layanan Pemustaka", name: "NAUFAL FA`IQ AMRULLAH, A.Md", image: null },
  { role: "Teknologi Informasi", name: "SAID AQIL AL-MUNAWWAR, S.I.P.", image: "/images/team/Said Aqil Al Munawwar, S.I.P. - Pengelola Informasi.png" },
  { role: "Penjaminan Mutu", name: "ROSDIANA, S.Ag., M.Pd", image: "/images/team/Rosdiana S.Ag.,M.Pd. - Dukungan Riset dan Publikasi.png" },
  { role: "Anggota / Staff", name: "ALVIN ARRA UFUU, S.Kom.", image: null }
];
---
<Layout title="Tim Pengelola Perpustakaan | IAIN Sorong">
  <Header />
  
  <!-- Hero Section -->
  <section class="relative pt-32 pb-20 lg:pt-40 lg:pb-28 overflow-hidden bg-[#0B4226]">
    <div class="absolute inset-0 bg-[url('https://images.unsplash.com/photo-1541339907198-e08756dedf3f?q=80&w=2000&auto=format&fit=crop')] bg-cover bg-center opacity-10 mix-blend-overlay"></div>
    <div class="max-w-[1280px] mx-auto px-4 sm:px-6 lg:px-8 relative z-10 text-center">
      <span class="inline-block py-1 px-3 rounded-full bg-[#168940]/20 text-[#BBF7D0] text-xs font-bold tracking-wider uppercase mb-4 border border-[#168940]/50 backdrop-blur-md">
        Struktur Organisasi
      </span>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white tracking-tight mb-6 drop-shadow-md">
        Pengelola Perpustakaan
      </h1>
      <p class="text-lg md:text-xl text-[#BBF7D0] max-w-3xl mx-auto font-serif leading-relaxed font-medium">
        Institut Agama Islam Negeri (IAIN) Sorong
      </p>
    </div>
  </section>

  <!-- Content Section -->
  <section class="py-16 md:py-24 bg-[#F7F7F2]">
    <div class="max-w-[1280px] mx-auto px-4 sm:px-6 lg:px-8">
      
      <!-- Top Level Structure (Rektor & Kepala) -->
      <div class="flex flex-col items-center mb-20 relative">
         
         <!-- Rektor -->
         <div class="bg-white border border-[#dadada] rounded-[16px] p-6 shadow-sm text-center w-[280px] z-10 relative">
            <h3 class="text-xl font-bold text-[#0B4226] uppercase tracking-wide">REKTOR</h3>
            <p class="text-sm text-[#666666] font-serif mt-1 font-medium">IAIN Sorong</p>
         </div>

         <!-- Line Connector -->
         <div class="w-1 h-12 bg-gradient-to-b from-[#dadada] to-[#168940] relative">
            <div class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 bg-white px-2 py-1 border border-[#dadada] rounded text-[10px] text-[#666666] font-semibold whitespace-nowrap shadow-sm">
                Garis Instruktursional
            </div>
         </div>

         <!-- Kepala Perpustakaan -->
         <div class="bg-gradient-to-b from-white to-[#F0FDF4] border-t-4 border-t-[#168940] border-x border-b border-[#dadada] rounded-b-[16px] p-8 shadow-md text-center w-full max-w-[420px] z-10 relative">
            <div class="w-32 h-32 mx-auto bg-white rounded-full border border-[#dadada] shadow-sm flex items-center justify-center mb-6 overflow-hidden">
               <!-- Placeholder for Kepala as no photo provided -->
               <iconify-icon icon="lucide:user" class="text-5xl text-slate-300"></iconify-icon>
            </div>
            <h3 class="text-xl font-bold text-[#222222] mb-1">Dr. SUPARTO IRIBARAM, S.Sos., M.A.</h3>
            <p class="text-sm font-bold text-[#168940] uppercase tracking-wider mb-2">Kepala / Pengelola Informasi</p>
         </div>

         <!-- Downward Line to Grid -->
         <div class="w-1 h-12 bg-gradient-to-b from-[#168940] to-transparent"></div>
      </div>

      <!-- Staff Grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-x-8 gap-y-12 relative">
         
         <!-- Grid Connectors (Visual Only) -->
         <div class="absolute -top-6 left-0 right-0 h-1 hidden lg:block border-t border-dashed border-[#168940]/50">
             <div class="absolute -top-3 left-1/2 transform -translate-x-1/2 bg-[#F7F7F2] px-3 py-1 rounded text-[10px] text-[#168940] font-bold whitespace-nowrap uppercase tracking-wider border border-[#168940]/30 shadow-sm">
                Garis Koordinasi Tim
            </div>
         </div>

         {team.map(member => (
            <div class="bg-white border border-[#dadada] hover:border-[#BBF7D0] rounded-[12px] p-6 shadow-sm hover:shadow-xl transition-all duration-300 text-center group flex flex-col items-center">
               <div class="w-28 h-28 mx-auto bg-slate-50 rounded-full border-4 border-white shadow-sm flex items-center justify-center mb-5 overflow-hidden group-hover:scale-105 group-hover:shadow-md transition-all duration-300">
                  {member.image ? (
                     <img src={member.image} alt={member.name} class="w-full h-full object-cover" loading="lazy" />
                  ) : (
                     <iconify-icon icon="lucide:user" class="text-4xl text-slate-300"></iconify-icon>
                  )}
               </div>
               <h3 class="text-[15px] font-bold text-[#222222] leading-snug mb-2 flex-1">{member.name}</h3>
               <p class="text-[11px] font-bold text-[#168940] uppercase tracking-widest bg-[#F0FDF4] px-3 py-1.5 rounded-full w-full">{member.role}</p>
            </div>
         ))}
      </div>

      <!-- Legend -->
      <div class="mt-20 pt-8 border-t border-[#dadada] flex flex-col md:flex-row gap-6 items-center justify-center">
          <p class="text-sm font-bold text-[#666666] uppercase tracking-wider">Keterangan Struktur:</p>
          <div class="flex items-center gap-6">
              <div class="flex items-center gap-3">
                  <div class="w-8 h-1 bg-gradient-to-r from-[#dadada] to-[#168940] rounded-full"></div>
                  <span class="text-sm font-semibold text-[#222222]">Garis Instruktursional</span>
              </div>
              <div class="flex items-center gap-3">
                  <div class="w-8 h-1 border-t-2 border-dashed border-[#168940]/50 rounded-full"></div>
                  <span class="text-sm font-semibold text-[#222222]">Garis Koordinasi</span>
              </div>
          </div>
      </div>

    </div>
  </section>

  <Footer />
</Layout>
