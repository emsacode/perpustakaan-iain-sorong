---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const team = [
  { role: "Kepala / Pengelola Informasi", name: "Dr. SUPARTO IRIBARAM, S.Sos., M.A.", image: null },
  { role: "Dukungan Riset & Publikasi", name: "Drs. MUHAMMAD SATIR, M.Pd.I", image: "/images/team/Drs. Muhammad Satir, M.Pd.I. - Kepala Perpustakaan.png" },
  { role: "Kerja Sama & Promosi", name: "MUTAWALLI, S.Hum", image: "/images/team/Mutawalli, S.Hum. - Pengembangan Koleksi.png" },
  { role: "Tata Usaha", name: "ZULFIKAR, S.Sos.", image: null },
  { role: "Pengembangan Koleksi", name: "LA EMPE, SP.i", image: "/images/team/La Empe.S.Pi. - Layanan Pemustaka.png" },
  { role: "Layanan Pemustaka", name: "NAUFAL FA`IQ AMRULLAH, A.Md", image: null },
  { role: "Teknologi Informasi", name: "SAID AQIL AL-MUNAWWAR, S.I.P.", image: "/images/team/Said Aqil Al Munawwar, S.I.P. - Pengelola Informasi.png" },
  { role: "Penjaminan Mutu", name: "ROSDIANA, S.Ag., M.Pd", image: "/images/team/Rosdiana S.Ag.,M.Pd. - Dukungan Riset dan Publikasi.png" },
  { role: "Anggota / Staff", name: "ALVIN ARRA UFUU, S.Kom.", image: null }
];
---
<Layout title="Tim Pengelola Perpustakaan | IAIN Sorong">
  <Header />
  
  <!-- Hero Section -->
  <section class="relative pt-32 pb-20 lg:pt-40 lg:pb-28 overflow-hidden bg-[#0B4226]">
    <div class="absolute inset-0 bg-[url('https://images.unsplash.com/photo-1541339907198-e08756dedf3f?q=80&w=2000&auto=format&fit=crop')] bg-cover bg-center opacity-10 mix-blend-overlay"></div>
    <div class="max-w-[1280px] mx-auto px-4 sm:px-6 lg:px-8 relative z-10 text-center">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white tracking-tight mb-6 drop-shadow-md">
        Direktori Pengelola
      </h1>
      <p class="text-lg md:text-xl text-[#BBF7D0] max-w-3xl mx-auto font-serif leading-relaxed font-medium">
        Kenali lebih dekat tenaga profesional di balik layanan Perpustakaan Institut Agama Islam Negeri (IAIN) Sorong
      </p>
    </div>
  </section>

  <!-- Content Section -->
  <section class="py-16 md:py-24 bg-[#F7F7F2]">
    <div class="max-w-[1280px] mx-auto px-4 sm:px-6 lg:px-8">
      
      <!-- Staff Directory Grid -->
      <div class="grid grid-cols-1 lg:grid-cols-2 xl:grid-cols-3 gap-6 sm:gap-8">
         {team.map(member => (
            <div class="bg-white border border-[#dadada] hover:border-[#168940] rounded-[16px] p-5 sm:p-6 shadow-sm hover:shadow-xl transition-all duration-300 group flex items-center gap-5">
               <div class="w-20 h-20 sm:w-24 sm:h-24 flex-shrink-0 bg-slate-50 rounded-full border border-[#dadada] shadow-sm flex items-center justify-center overflow-hidden group-hover:scale-105 transition-all duration-300">
                  {member.image ? (
                     <img src={member.image} alt={member.name} class="w-full h-full object-cover" loading="lazy" />
                  ) : (
                     <iconify-icon icon="lucide:user" class="text-4xl text-slate-300"></iconify-icon>
                  )}
               </div>
               <div class="flex flex-col text-left flex-1 min-w-0">
                  <h3 class="text-base sm:text-lg font-bold text-[#222222] leading-tight mb-2 truncate whitespace-normal break-words">{member.name}</h3>
                  <div class="flex items-start">
                     <span class="text-[10px] sm:text-xs font-bold text-[#168940] uppercase tracking-wider bg-[#F0FDF4] px-3 py-1.5 rounded-full border border-[#BBF7D0] inline-block max-w-full truncate whitespace-normal break-words leading-tight">{member.role}</span>
                  </div>
               </div>
            </div>
         ))}
      </div>

    </div>
  </section>

  <Footer />
</Layout>
