---

<Layout title="Panduan E-Resources - Perpustakaan IAIN Sorong">
  <Header />
  
  <main class="bg-[#FAF9F6] min-h-screen pb-16 font-sans text-slate-700">
    <!-- Hero Banner Section -->
    <div class="bg-gradient-to-r from-[#0B4226] to-[#168940] text-white py-10 md:py-14 border-b border-emerald-800">
      <div class="max-w-[1280px] mx-auto px-4 sm:px-6 lg:px-8">
        <nav class="flex gap-2 text-xs text-[#BBF7D0] mb-3 font-medium">
          <a href="/" class="hover:underline">Beranda</a>
          <span>/</span>
          <span class="text-white">Panduan E-Resources</span>
        </nav>
        <h1 class="text-2xl md:text-4xl font-serif font-bold tracking-tight mb-3">
          Panduan Penggunaan E-Resources
        </h1>
        <p class="text-sm md:text-base text-[#BBF7D0] max-w-3xl leading-relaxed font-serif">
          Akses panduan langkah demi langkah menggunakan berbagai sumber daya elektronik (e-resources) dari Perpusnas dan mitra perpustakaan untuk mempermudah riset dan pembelajaran Anda.
        </p>
      </div>
    </div>

    <!-- Main Container -->
    <div class="max-w-[1280px] mx-auto px-4 sm:px-6 lg:px-8 mt-10">
      
      <!-- GRID PANDUAN -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {panduanList.map((item, index) => (
          <div 
            class="epaper-card group flex items-start gap-4 p-5 bg-white rounded-2xl shadow-sm border border-slate-200/60 hover:shadow-md hover:border-[#168940]/40 transition-all duration-300 transform hover:-translate-y-1 cursor-pointer"
            data-source={item.url}
            data-title={item.title}
            role="button"
            tabindex="0"
          >
            <div class="flex-shrink-0 w-12 h-12 bg-red-50 rounded-xl flex items-center justify-center text-red-500 group-hover:bg-red-500 group-hover:text-white transition-colors duration-300 shadow-sm border border-red-100">
              <iconify-icon icon="lucide:file-text" width="1.5rem"></iconify-icon>
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="font-bold text-[#0B4226] text-[15px] leading-snug group-hover:text-[#168940] transition-colors mb-1.5">
                {item.title}
              </h3>
              <div class="flex items-center gap-1 text-xs text-slate-400 font-medium group-hover:text-[#168940]/70 transition-colors">
                <span>Buka Panduan PDF</span>
                <iconify-icon icon="lucide:arrow-right" width="0.8rem"></iconify-icon>
              </div>
            </div>
          </div>
        ))}
      </div>
      
    </div>
  </main>
  
  <Footer />

  <!-- DFlip Dependencies for PDF reading -->
  <link href="https://cdn.jsdelivr.net/npm/@dearhive/dearflip-jquery-flipbook@1.7.3/dflip/css/dflip.min.css" rel="stylesheet" type="text/css">
  <link href="https://cdn.jsdelivr.net/npm/@dearhive/dearflip-jquery-flipbook@1.7.3/dflip/css/themify-icons.min.css" rel="stylesheet" type="text/css">
  <script is:inline src="https://cdn.jsdelivr.net/npm/jquery@3.6.0/dist/jquery.min.js"></script>
  <script is:inline>
    window.dFlipLocation = "https://cdn.jsdelivr.net/npm/@dearhive/dearflip-jquery-flipbook@1.7.3/dflip/";
  </script>
  <script is:inline src="https://cdn.jsdelivr.net/npm/@dearhive/dearflip-jquery-flipbook@1.7.3/dflip/js/dflip.min.js"></script>
  
  <script is:inline>
    if (window.DFLIP && window.DFLIP.defaults) {
      Object.assign(window.DFLIP.defaults, {
        webgl: true,
        zoomRatio: 1.5,
        autoEnableOutline: false,
        autoEnableThumbnail: true,
        backgroundColor: "#FAF9F6",
        threejsSrc: "https://cdn.jsdelivr.net/npm/@dearhive/dearflip-jquery-flipbook@1.7.3/dflip/js/libs/three.min.js",
        soundFile: "https://cdn.jsdelivr.net/npm/@dearhive/dearflip-jquery-flipbook@1.7.3/dflip/sound/turn2.mp3"
      });
    }
  </script>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const cards = document.querySelectorAll('.epaper-card');
      
      cards.forEach(card => {
        card.addEventListener('click', () => {
          const pdfUrl = card.getAttribute('data-source');
          const title = card.getAttribute('data-title');
          if (pdfUrl) {
            // Check if DFLIP is available globally
            if (window.DFLIP && typeof window.DFLIP.showLightbox === 'function') {
              window.DFLIP.showLightbox(pdfUrl, {
                title: title || 'Panduan PDF',
                webgl: true
              });
            } else {
              // Fallback if DFLIP fails to load
              window.open(pdfUrl, '_blank');
            }
          }
        });

        // Keyboard accessibility
        card.addEventListener('keydown', (e) => {
          if (e.key === 'Enter' || e.key === ' ') {
            e.preventDefault();
            (card as HTMLElement).click();
          }
        });
      });
    });
  </script>
</Layout>
