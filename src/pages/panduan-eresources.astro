---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { panduanList } from '../data/panduanEresources';
---

<Layout title="Panduan E-Resources - Perpustakaan IAIN Sorong">
  <Header />
  
  <main class="bg-[#FAF9F6] min-h-screen pb-16 font-sans text-slate-700">
    <!-- Hero Banner Section -->
    <div class="bg-gradient-to-r from-[#0B4226] to-[#168940] text-white py-10 md:py-14 border-b border-emerald-800">
      <div class="max-w-[1280px] mx-auto px-4 sm:px-6 lg:px-8">
        <nav class="flex gap-2 text-xs text-[#BBF7D0] mb-3 font-medium">
          <a href="/" class="hover:underline">Beranda</a>
          <span>/</span>
          <span class="text-white">Panduan E-Resources</span>
        </nav>
        <h1 class="text-2xl md:text-4xl font-serif font-bold tracking-tight mb-3">
          Panduan Penggunaan E-Resources
        </h1>
        <p class="text-sm md:text-base text-[#BBF7D0] max-w-3xl leading-relaxed font-serif">
          Akses panduan langkah demi langkah menggunakan berbagai sumber daya elektronik (e-resources) dari Perpusnas dan mitra perpustakaan untuk mempermudah riset dan pembelajaran Anda.
        </p>
      </div>
    </div>

    <!-- Main Container -->
    <div class="max-w-[1280px] mx-auto px-4 sm:px-6 lg:px-8 mt-10">
      
      <!-- SEARCH BAR -->
      <div class="mb-8">
        <div class="relative max-w-xl">
          <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none text-slate-400">
            <iconify-icon icon="lucide:search" width="1.2rem"></iconify-icon>
          </div>
          <input 
            type="text" 
            id="searchInput" 
            placeholder="Cari nama sumber daya (misal: Kompas, Wiley, Oxford...)" 
            class="block w-full pl-10 pr-3 py-3 border border-slate-200 rounded-xl leading-5 bg-white placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-[#168940] focus:border-[#168940] sm:text-sm transition-shadow shadow-sm"
          >
        </div>
      </div>

      <!-- GRID PANDUAN -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6" id="panduanGrid">
        {panduanList.map((item) => (
          <a 
            href={item.url}
            target="_blank"
            rel="noopener noreferrer"
            class="epaper-card group flex items-start gap-4 p-5 bg-white rounded-2xl shadow-sm border border-slate-200/60 hover:shadow-md hover:border-[#168940]/40 transition-all duration-300 transform hover:-translate-y-1 cursor-pointer"
            title={item.title}
          >
            <div class="flex-shrink-0 w-12 h-12 bg-red-50 rounded-xl flex items-center justify-center text-red-500 group-hover:bg-red-500 group-hover:text-white transition-colors duration-300 shadow-sm border border-red-100">
              <iconify-icon icon="lucide:file-text" width="1.5rem"></iconify-icon>
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="panduan-title font-bold text-[#0B4226] text-[15px] leading-snug group-hover:text-[#168940] transition-colors mb-1.5">
                {item.title}
              </h3>
              <div class="flex items-center gap-1 text-xs text-slate-400 font-medium group-hover:text-[#168940]/70 transition-colors">
                <span>Buka Panduan PDF</span>
                <iconify-icon icon="lucide:external-link" width="0.8rem"></iconify-icon>
              </div>
            </div>
          </a>
        ))}
      </div>
      
      <!-- EMPTY STATE -->
      <div id="emptyState" class="hidden text-center py-12">
        <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-slate-100 text-slate-400 mb-4">
          <iconify-icon icon="lucide:search-x" width="2rem"></iconify-icon>
        </div>
        <h3 class="text-lg font-medium text-slate-900 mb-1">Panduan tidak ditemukan</h3>
        <p class="text-slate-500">Coba gunakan kata kunci pencarian yang lain.</p>
      </div>
      
    </div>
  </main>
  
  <Footer />

  <script is:inline>
    // Search functionality
    const searchInput = document.getElementById('searchInput');
    const cards = document.querySelectorAll('.epaper-card');
    const emptyState = document.getElementById('emptyState');
    
    if (searchInput) {
      searchInput.addEventListener('input', (e) => {
        const searchTerm = e.target.value.toLowerCase();
        let visibleCount = 0;
        
        cards.forEach(card => {
          const titleElement = card.querySelector('.panduan-title');
          const title = titleElement ? titleElement.textContent.toLowerCase() : '';
          
          if (title.includes(searchTerm)) {
            card.style.display = 'flex';
            visibleCount++;
          } else {
            card.style.display = 'none';
          }
        });
        
        if (visibleCount === 0) {
          emptyState.classList.remove('hidden');
        } else {
          emptyState.classList.add('hidden');
        }
      });
    }
  </script>
</Layout>
