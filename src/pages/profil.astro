---
import LayoutSidebar from '../layouts/LayoutSidebar.astro';
import statsRaw from '../data/live_stats.json';

const stats = statsRaw;

const sidebarMenu = {
    title: "Profil & Tentang Kami",
    items: [{"label": "Profil Singkat", "href": "/profil"}, {"label": "Visi & Misi", "href": "/visi-misi"}, {"label": "Struktur Organisasi", "href": "/struktur"}, {"label": "Jam Buka Layanan", "href": "/jam-layanan"}]
};

// Fetch dynamic page from Laravel API
let pageData = null;
/* 
try {
    const response = await fetch((import.meta.env.PUBLIC_API_URL || 'https://dash-perpus.emsacode.com') + '/api/v1/pages/profil');
    if (response.ok) {
        pageData = await response.json();
    }
} catch (e) {
    // Fail silently, fallback to static HTML
}
*/
---

<LayoutSidebar title="Profil Singkat" sidebarMenu={sidebarMenu}>
    
    <!-- Hero Section -->
    <div class="bg-[#F0FDF4] border border-[#dadada] rounded-[8px] p-8 sm:p-10 mb-10 flex flex-col md:flex-row items-center gap-8">
        <div class="w-20 h-20 md:w-24 md:h-24 bg-white rounded-full flex items-center justify-center border border-[#dadada] shrink-0 shadow-sm">
            <iconify-icon icon="flat-color-icons:library" ></iconify-icon>
        </div>
        <div>
            <h2 class="text-2xl font-semibold tracking-tight text-[#222222] mb-3">Jantung Akademik IAIN Sorong</h2>
            <p class="font-serif text-[15px] text-[#444444] leading-relaxed max-w-2xl">
                Perpustakaan Institut Agama Islam Negeri (IAIN) Sorong hadir sebagai pusat literatur yang komprehensif, menggerakkan roda tridharma perguruan tinggi di kawasan timur Indonesia.
            </p>
        </div>
    </div>

    <!-- Main Content -->
    <div class="prose prose-lg max-w-none text-[#444444]">
        {pageData ? (
            <div set:html={pageData.content} />
        ) : (
            <div class="space-y-6">
                <h3 class="text-2xl font-bold tracking-tight text-[#222222] mb-4">Jejak Langkah & Sejarah Perkembangan</h3>
                
                <p class="font-serif leading-relaxed text-justify">
                    Perpustakaan IAIN Sorong memiliki akar sejarah yang panjang, bermula sebagai warisan dari Perpustakaan STAIS Al-Hikmah. Pada tanggal 20 Juli 2006, perpustakaan ini resmi beralih status menjadi Perpustakaan STAIN Sorong, dengan penempatan awal di gedung MAN Model Sorong. Seiring dinamika institusi, pada tahun 2009 lokasi perpustakaan dipindahkan ke Sekolah SD An-Nur Kampung Baru hingga tahun 2010.
                </p>

                <p class="font-serif leading-relaxed text-justify">
                    Titik terang perkembangan sarana dan prasarana terlihat pada tanggal 5 Mei 2010, bertepatan dengan peresmian gedung baru STAIN Sorong. Seluruh aktivitas sivitas akademika, termasuk layanan perpustakaan serta administrasi keuangan dan kepegawaian, secara resmi dipindahkan ke kampus terpadu di Jalan Sorong-Klamono Kilometer 17, Kota Sorong. Saat itu, perpustakaan menempati gedung serbaguna yang kini difungsikan sebagai Gedung Akademik.
                </p>

                <p class="font-serif leading-relaxed text-justify">
                    Seiring berjalannya waktu, pertumbuhan koleksi yang pesat serta meningkatnya kebutuhan ruang baca bagi pemustaka membuat fasilitas yang ada terasa kian menyempit. Demi memastikan kenyamanan pelayanan, pada tahun 2014 perpustakaan kembali direlokasi, kali ini menempati lantai dua eks-Gedung Rektorat lama hingga saat ini.
                </p>

                <p class="font-serif leading-relaxed text-justify">
                    Kepindahan ini menjadi momentum pembenahan total. Perpustakaan mulai menata ulang sistem administrasi, tata letak rak koleksi, hingga pembagian zona fungsi yang meliputi ruang baca, ruang koleksi referensi, ruang pengolahan, serta ruang Kepala Perpustakaan. Sejak tahun 2016, langkah digitalisasi mulai diimplementasikan secara masif melalui penertiban koleksi dan automasi perpustakaan menggunakan aplikasi SLiMS (Senayan Library Management System). Langkah ini terbukti berhasil mempermudah pengelolaan koleksi, sistem administrasi, dan mempercepat pelayanan kepada pemustaka.
                </p>

                <p class="font-serif leading-relaxed text-justify">
                    Berkat transformasi berkelanjutan tersebut, Perpustakaan IAIN Sorong kini menjadi salah satu fasilitas terfavorit sivitas akademika. Ruangan yang nyaman didukung fasilitas penelusuran informasi yang memadai sukses menunjang atmosfer belajar mengajar dan riset yang dinamis di lingkungan IAIN Sorong.
                </p>

                <h3 class="text-2xl font-bold tracking-tight text-[#222222] mt-10 mb-4">Akreditasi dan Kepemimpinan</h3>

                <p class="font-serif leading-relaxed text-justify">
                    Sebagai buah dari upaya inovatif dan kreatif, serta komitmen dalam menumbuhkan minat literasi insan akademik, Perpustakaan IAIN Sorong berhasil meraih prestasi gemilang: mendapatkan <strong>Akreditasi dengan nilai A</strong> dari Perpustakaan Nasional RI pada tahun 2021.
                </p>

                <p class="font-serif leading-relaxed text-justify mb-4">
                    Capaian bersejarah ini tentu tak lepas dari kerja keras dan dedikasi panjang jajaran pimpinan yang pernah menakhodai Perpustakaan IAIN Sorong dari masa ke masa, yaitu:
                </p>

                <div class="bg-white p-6 rounded-[8px] border border-[#dadada] shadow-sm font-sans mb-10">
                    <ul class="grid grid-cols-1 md:grid-cols-2 gap-y-3 gap-x-6 text-[15px] text-[#444444]">
                        <li class="flex items-center gap-2"><iconify-icon icon="lucide:check-circle" class="text-[#168940]"></iconify-icon> <strong>Mahsunah, S.Pd</strong> <span class="text-slate-500">(2008-2010)</span></li>
                        <li class="flex items-center gap-2"><iconify-icon icon="lucide:check-circle" class="text-[#168940]"></iconify-icon> <strong>Irfakaharudin, M.E</strong> <span class="text-slate-500">(2010-2011)</span></li>
                        <li class="flex items-center gap-2"><iconify-icon icon="lucide:check-circle" class="text-[#168940]"></iconify-icon> <strong>Mutawali, M.IP</strong> <span class="text-slate-500">(2011-2012)</span></li>
                        <li class="flex items-center gap-2"><iconify-icon icon="lucide:check-circle" class="text-[#168940]"></iconify-icon> <strong>Rusyaid, M.Pd</strong> <span class="text-slate-500">(2012-2013)</span></li>
                        <li class="flex items-center gap-2"><iconify-icon icon="lucide:check-circle" class="text-[#168940]"></iconify-icon> <strong>Dr. Muh. Rusdi Rasyid, M.Pd.I</strong> <span class="text-slate-500">(2013-2015)</span></li>
                        <li class="flex items-center gap-2"><iconify-icon icon="lucide:check-circle" class="text-[#168940]"></iconify-icon> <strong>Akramunnisa, S.E</strong> <span class="text-slate-500">(2015-2017)</span></li>
                        <li class="flex items-center gap-2"><iconify-icon icon="lucide:check-circle" class="text-[#168940]"></iconify-icon> <strong>Ahmadi, M.MP.d</strong> <span class="text-slate-500">(2018-2020)</span></li>
                        <li class="flex items-center gap-2"><iconify-icon icon="lucide:check-circle" class="text-[#168940]"></iconify-icon> <strong>Wati Irmawati, S.Pd.I</strong> <span class="text-slate-500">(2021-2022)</span></li>
                        <li class="flex items-center gap-2"><iconify-icon icon="lucide:check-circle" class="text-[#168940]"></iconify-icon> <strong>Rabiudin, M.Pd</strong> <span class="text-slate-500">(2022-2024)</span></li>
                        <li class="flex items-center gap-2"><iconify-icon icon="lucide:check-circle" class="text-[#168940]"></iconify-icon> <strong>Muhammad Ramli, M.Pd.</strong> <span class="text-slate-500">(2024-2025)</span></li>
                        <li class="flex items-center gap-2"><iconify-icon icon="lucide:check-circle" class="text-[#168940]"></iconify-icon> <strong>Drs. Muhammad Satir, M.Pd.I</strong> <span class="text-slate-500 text-[13px] uppercase font-bold tracking-wider px-2 py-0.5 rounded-full bg-green-100 text-green-700 ml-1">Sekarang</span></li>
                    </ul>
                </div>
            </div>
        )}
    </div>

    <!-- Quick Stats — Data Riil dari Pipeline Otomatis -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mt-12 pt-10 border-t border-[#dadada]">
        <div class="text-center p-4 hover:bg-[#F0FDF4] rounded-[8px] transition-colors">
            <div class="text-2xl font-bold text-[#168940] mb-1">{stats.judul_buku.toLocaleString('id-ID')}</div>
            <div class="text-xs font-semibold text-[#666666] uppercase tracking-wider">Judul Koleksi Buku</div>
        </div>
        <div class="text-center p-4 hover:bg-[#EBF8FF] rounded-[8px] transition-colors">
            <div class="text-2xl font-bold text-[#3182CE] mb-1">{stats.jurnal_ilmiah.toLocaleString('id-ID')}</div>
            <div class="text-xs font-semibold text-[#666666] uppercase tracking-wider">Artikel Jurnal</div>
        </div>
        <div class="text-center p-4 hover:bg-[#FAF5FF] rounded-[8px] transition-colors">
            <div class="text-2xl font-bold text-[#805AD5] mb-1">{stats.dokumen_skripsi}</div>
            <div class="text-xs font-semibold text-[#666666] uppercase tracking-wider">Dokumen Repositori</div>
        </div>
        <div class="text-center p-4 hover:bg-[#FFFAF0] rounded-[8px] transition-colors">
            <div class="text-2xl font-bold text-[#DD6B20] mb-1">{stats.total_anggota.toLocaleString('id-ID')}</div>
            <div class="text-xs font-semibold text-[#666666] uppercase tracking-wider">Total Anggota</div>
        </div>
    </div>
    <div class="text-center mt-3">
        <a href="/statistik" class="text-xs font-semibold text-[#168940] hover:text-[#0B4226] no-underline">Lihat Statistik Lengkap →</a>
    </div>
</LayoutSidebar>
