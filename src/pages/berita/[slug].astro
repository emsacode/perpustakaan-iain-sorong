---
import { getCollection } from 'astro:content';
import LayoutSidebar from '../../layouts/LayoutSidebar.astro';

export async function getStaticPaths() {
  const berita = await getCollection('berita');
  return berita.map(entry => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();

const sidebarMenu = {
    title: "Kategori Berita",
    items: [
        {"label": "Semua Berita", "href": "/berita"},
        {"label": "Pengumuman", "href": "#"},
        {"label": "Kegiatan", "href": "#"},
        {"label": "Tips Literasi", "href": "#"}
    ]
};
---

<LayoutSidebar title={entry.data.title} sidebarMenu={sidebarMenu}>
    
    <!-- Breadcrumb -->
    <nav class="flex items-center gap-2 text-sm font-serif text-[#666666] mb-6 flex-wrap">
        <a href="/" class="hover:text-[#168940] transition-colors whitespace-nowrap">Beranda</a>
        <iconify-icon icon="lucide:chevron-right" width="14"></iconify-icon>
        <a href="/berita" class="hover:text-[#168940] transition-colors whitespace-nowrap">Berita</a>
        <iconify-icon icon="lucide:chevron-right" width="14"></iconify-icon>
        <span class="text-[#222222] font-semibold truncate max-w-[200px] md:max-w-md">{entry.data.title}</span>
    </nav>

    <article class="bg-white border border-[#dadada] rounded-[8px] overflow-hidden shadow-sm">
        <!-- Hero Image -->
        <div class="aspect-video w-full overflow-hidden bg-slate-100">
            <img src={entry.data.image} alt={entry.data.title} class="w-full h-full object-cover">
        </div>

        <div class="p-6 md:p-10">
            <!-- Meta Header -->
            <div class="flex flex-wrap items-center gap-4 mb-6 pb-6 border-b border-[#dadada]">
                <span class="bg-[#F0FDF4] text-[#168940] border border-[#168940]/20 text-xs font-bold uppercase tracking-wider px-3 py-1.5 rounded-[4px]">
                    {entry.data.category}
                </span>
                <div class="flex flex-wrap items-center gap-4 text-[#666666] text-sm font-serif">
                    <span class="flex items-center gap-1.5">
                        <iconify-icon icon="lucide:calendar" width="16"></iconify-icon>
                        {entry.data.date}
                    </span>
                    <span class="flex items-center gap-1.5">
                        <iconify-icon icon="lucide:user-circle" width="16"></iconify-icon>
                        {entry.data.author}
                    </span>
                    <span class="flex items-center gap-1.5">
                        <iconify-icon icon="lucide:clock" width="16"></iconify-icon>
                        {entry.data.readTime}
                    </span>
                </div>
            </div>

            <!-- Title -->
            <h1 class="text-2xl md:text-4xl font-bold text-[#0B4226] mb-8 leading-tight tracking-tight">
                {entry.data.title}
            </h1>

            <!-- Content -->
            <div class="prose prose-slate prose-lg max-w-none 
                prose-headings:text-[#0B4226] prose-headings:font-bold 
                prose-a:text-[#168940] prose-a:no-underline hover:prose-a:underline
                prose-img:rounded-[8px] prose-img:shadow-sm
                prose-blockquote:border-l-4 prose-blockquote:border-[#168940] prose-blockquote:bg-[#F0FDF4] prose-blockquote:py-2 prose-blockquote:px-4 prose-blockquote:rounded-r-[4px] prose-blockquote:text-[#222222] prose-blockquote:font-serif
                text-[#444444] font-serif leading-relaxed">
                <Content />
            </div>

            <!-- Share & Tag -->
            <div class="mt-12 pt-6 border-t border-[#dadada] flex flex-col md:flex-row items-center justify-between gap-4">
                <div class="flex items-center gap-3">
                    <span class="text-sm font-semibold text-[#222222]">Bagikan:</span>
                    <a href={`https://wa.me/?text=${encodeURIComponent(entry.data.title + ' - ' + Astro.url)}`} target="_blank" class="w-8 h-8 rounded-full bg-[#F8FAFC] border border-[#dadada] text-[#444444] flex items-center justify-center hover:bg-[#25D366] hover:text-white hover:border-[#25D366] transition-colors">
                        <iconify-icon icon="lucide:message-circle" width="16"></iconify-icon>
                    </a>
                    <a href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(Astro.url)}`} target="_blank" class="w-8 h-8 rounded-full bg-[#F8FAFC] border border-[#dadada] text-[#444444] flex items-center justify-center hover:bg-[#1877F2] hover:text-white hover:border-[#1877F2] transition-colors">
                        <iconify-icon icon="lucide:facebook" width="16"></iconify-icon>
                    </a>
                    <a href={`https://twitter.com/intent/tweet?url=${encodeURIComponent(Astro.url)}&text=${encodeURIComponent(entry.data.title)}`} target="_blank" class="w-8 h-8 rounded-full bg-[#F8FAFC] border border-[#dadada] text-[#444444] flex items-center justify-center hover:bg-[#1DA1F2] hover:text-white hover:border-[#1DA1F2] transition-colors">
                        <iconify-icon icon="lucide:twitter" width="16"></iconify-icon>
                    </a>
                </div>
            </div>
        </div>
    </article>

</LayoutSidebar>
