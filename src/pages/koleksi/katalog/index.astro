---
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import catalogData from '../../../data/catalog.json';

// Get unique types and subjects for filter
const types = [...new Set(catalogData.map(item => item.type))].sort();
const subjects = [...new Set(catalogData.map(item => item.subject))].sort();
---

<Layout title="Katalog Terpadu - Perpustakaan IAIN Sorong">
  <Header />
  
  <main class="bg-slate-50 min-h-screen pb-16 font-sans">
    <!-- Hero Banner Section -->
    <div class="bg-gradient-to-r from-[#0B4226] to-[#168940] text-white py-10 md:py-14 border-b border-[#dadada]">
      <div class="max-w-[1280px] mx-auto px-4 sm:px-6 lg:px-8">
        <nav class="flex gap-2 text-xs text-[#BBF7D0] mb-3 font-medium">
          <a href="/" class="hover:underline">Beranda</a>
          <span>/</span>
          <span class="text-white">Koleksi</span>
          <span>/</span>
          <span class="text-white">Katalog Terpadu</span>
        </nav>
        <h1 class="text-2xl md:text-4xl font-serif font-bold tracking-tight mb-3">
          Katalog Terpadu (Internal)
        </h1>
        <p class="text-sm md:text-base text-[#BBF7D0] max-w-3xl leading-relaxed font-serif">
          Pencarian referensi terpadu dari sistem katalog buku cetak (SLiMS OPAC), Repositori Skripsi (EPrints), dan artikel ilmiah Rumah Jurnal (OJS) Perpustakaan IAIN Sorong.
        </p>
      </div>
    </div>

    <!-- Main Container -->
    <div class="max-w-[1280px] mx-auto px-4 sm:px-6 lg:px-8 mt-6">
      
      <!-- CONTROL PANEL -->
      <div class="bg-white border border-slate-200 rounded-xl shadow-md p-5 mb-8">
        <div class="grid grid-cols-1 md:grid-cols-12 gap-4 items-center">
          
          <!-- Search Bar -->
          <div class="md:col-span-4 relative">
            <div class="relative">
              <input 
                type="text" 
                id="search-input" 
                placeholder="Cari judul, pengarang, subjek..."
                class="w-full pl-10 pr-4 py-2.5 border border-slate-300 rounded-xl text-sm text-slate-700 focus:outline-none focus:ring-2 focus:ring-[#168940] focus:border-[#168940] bg-white hover:bg-slate-50 transition-colors shadow-sm"
              />
              <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none text-slate-400">
                <iconify-icon icon="lucide:search" width="1.1rem"></iconify-icon>
              </div>
            </div>
          </div>

          <!-- Type Filter -->
          <div class="md:col-span-4">
            <select id="type-select" class="w-full px-3 py-2.5 border border-slate-300 rounded-xl text-sm text-slate-700 bg-white hover:bg-slate-50 focus:outline-none focus:ring-2 focus:ring-[#168940] focus:border-[#168940] shadow-sm">
              <option value="all">Semua Tipe Koleksi</option>
              {types.map(t => (
                <option value={t}>{t}</option>
              ))}
            </select>
          </div>

          <!-- Subject Filter -->
          <div class="md:col-span-4">
            <select id="subject-select" class="w-full px-3 py-2.5 border border-slate-300 rounded-xl text-sm text-slate-700 bg-white hover:bg-slate-50 focus:outline-none focus:ring-2 focus:ring-[#168940] focus:border-[#168940] shadow-sm">
              <option value="all">Semua Subjek / Bidang</option>
              {subjects.map(s => (
                <option value={s}>{s}</option>
              ))}
            </select>
          </div>

        </div>
      </div>

      <!-- RESULTS GRID -->
      <div class="flex flex-col gap-4" id="catalog-list">
        {catalogData.map(item => (
          <a 
            href={`/koleksi/katalog/${item.id}`}
            class="catalog-item group block bg-white rounded-xl shadow-sm border border-slate-200 p-5 md:p-6 hover:shadow-md hover:border-[#168940]/40 transition-all duration-200"
            data-type={item.type}
            data-subject={item.subject}
            data-title={item.title.toLowerCase()}
            data-author={item.authors.map(a => a.name.toLowerCase()).join(' ')}
          >
            <div class="flex flex-col md:flex-row md:items-start justify-between gap-4">
              <div class="flex-1 min-w-0">
                <div class="flex flex-wrap items-center gap-2 mb-2">
                  <span class="bg-[#168940]/10 text-[#168940] text-[10px] font-bold px-2.5 py-1 rounded-full uppercase tracking-wider">
                    {item.type}
                  </span>
                  <span class="bg-slate-100 text-slate-600 text-[10px] font-bold px-2.5 py-1 rounded-full uppercase tracking-wider">
                    {item.source}
                  </span>
                </div>
                
                <h3 class="font-serif font-bold text-lg md:text-xl text-[#0B4226] group-hover:text-[#168940] transition-colors leading-snug mb-2">
                  {item.title}
                </h3>
                
                <p class="text-xs text-[#718096] mb-3 font-sans flex items-center gap-1.5">
                  <iconify-icon icon="lucide:user" width="0.9rem"></iconify-icon>
                  <span>Oleh: <strong>{item.authors.map(a => a.name).join(', ')}</strong></span>
                  {item.publisher && (
                    <>
                      <span class="text-slate-300">|</span>
                      <iconify-icon icon="lucide:building" width="0.9rem"></iconify-icon>
                      <span>{item.publisher} ({item.year})</span>
                    </>
                  )}
                </p>

                <p class="text-sm text-slate-600 line-clamp-2 leading-relaxed font-sans font-normal">
                  {item.abstract}
                </p>
              </div>

              <!-- Sidebar Metrics inside Card -->
              <div class="flex md:flex-col items-center md:items-end justify-between md:justify-start gap-2 shrink-0 border-t md:border-t-0 pt-3 md:pt-0 border-slate-100">
                <div class="text-[11px] font-mono bg-slate-50 border border-slate-200 rounded px-2.5 py-1 text-slate-600">
                  {item.classification}
                </div>
                <div class="flex items-center gap-1 text-xs text-slate-500 font-medium md:mt-2">
                  <iconify-icon icon="lucide:eye" class="text-slate-400" width="1rem"></iconify-icon>
                  <span>{item.views} Kali Dilihat</span>
                </div>
                <div class="md:mt-2">
                  {item.physical_availability ? (
                    <span class="bg-[#F0FDF4] text-[#168940] border border-[#BBF7D0] text-[10px] font-bold px-2.5 py-1 rounded-full uppercase tracking-wider">
                      Buku Fisik
                    </span>
                  ) : (
                    <span class="bg-blue-50 text-blue-600 border border-blue-100 text-[10px] font-bold px-2.5 py-1 rounded-full uppercase tracking-wider">
                      Digital (PDF)
                    </span>
                  )}
                </div>
              </div>
            </div>
          </a>
        ))}
      </div>

      <!-- Pagination Controls -->
      <div id="pagination-controls" class="flex justify-center items-center flex-wrap gap-2 mt-10 select-none">
      </div>
      
      <!-- Empty State -->
      <div id="empty-state" class="hidden py-12 text-center bg-white rounded-xl border border-slate-200 border-dashed">
        <iconify-icon icon="lucide:search-x" class="text-slate-300 mx-auto mb-3" width="3rem"></iconify-icon>
        <h3 class="text-lg font-bold text-slate-700 mb-1">Koleksi Tidak Ditemukan</h3>
        <p class="text-sm text-slate-500">Coba gunakan kata kunci atau filter klasifikasi yang berbeda.</p>
      </div>

    </div>
  </main>

  <Footer />
</Layout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const searchInput = document.getElementById('search-input') as HTMLInputElement;
    const typeSelect = document.getElementById('type-select') as HTMLSelectElement;
    const subjectSelect = document.getElementById('subject-select') as HTMLSelectElement;
    const items = document.querySelectorAll('.catalog-item') as NodeListOf<HTMLElement>;
    const emptyState = document.getElementById('empty-state');
    const paginationContainer = document.getElementById('pagination-controls');

    const itemsPerPage = 10;
    let currentPage = 1;
    let filteredItems: HTMLElement[] = [];

    let searchQuery = '';
    let selectedType = 'all';
    let selectedSubject = 'all';

    function filterCatalog() {
      filteredItems = [];

      items.forEach(item => {
        const type = item.getAttribute('data-type') || '';
        const subject = item.getAttribute('data-subject') || '';
        const title = item.getAttribute('data-title') || '';
        const author = item.getAttribute('data-author') || '';

        const matchSearch = searchQuery === '' || title.includes(searchQuery) || author.includes(searchQuery);
        const matchType = selectedType === 'all' || type === selectedType;
        const matchSubject = selectedSubject === 'all' || subject === selectedSubject;

        if (matchSearch && matchType && matchSubject) {
          filteredItems.push(item);
        } else {
          item.style.display = 'none';
        }
      });

      if (emptyState) {
        emptyState.style.display = filteredItems.length === 0 ? 'block' : 'none';
      }

      currentPage = 1;
      updatePageResults();
      renderPagination();
    }

    function updatePageResults() {
      const startIndex = (currentPage - 1) * itemsPerPage;
      const endIndex = startIndex + itemsPerPage;

      items.forEach(item => {
        const isVisible = filteredItems.includes(item);
        if (isVisible) {
          const indexInFiltered = filteredItems.indexOf(item);
          if (indexInFiltered >= startIndex && indexInFiltered < endIndex) {
            item.style.display = 'block';
          } else {
            item.style.display = 'none';
          }
        }
      });
    }

    function renderPagination() {
      if (!paginationContainer) return;
      paginationContainer.innerHTML = '';

      const totalPages = Math.ceil(filteredItems.length / itemsPerPage);
      if (totalPages <= 1) {
        return;
      }

      // Helper to render a page button
      function renderPageBtn(pageNumber) {
        const pageBtn = document.createElement('button');
        const isActive = currentPage === pageNumber;
        pageBtn.className = `w-8 h-8 rounded-lg text-xs font-bold transition-colors ${
          isActive 
            ? 'bg-[#168940] text-white border border-[#168940]' 
            : 'bg-white text-slate-700 hover:text-[#168940] hover:border-[#168940] border border-slate-300 shadow-sm'
        }`;
        pageBtn.innerText = pageNumber.toString();
        pageBtn.addEventListener('click', () => {
          currentPage = pageNumber;
          updatePageResults();
          renderPagination();
          window.scrollTo({ top: 200, behavior: 'smooth' });
        });
        paginationContainer.appendChild(pageBtn);
      }

      // Helper to render ellipses
      function renderEllipses() {
        const el = document.createElement('span');
        el.className = 'w-8 h-8 flex items-center justify-center text-slate-400 text-xs font-bold';
        el.innerText = '...';
        paginationContainer.appendChild(el);
      }

      // Prev Button
      const prevBtn = document.createElement('button');
      prevBtn.className = `px-3 py-1.5 rounded-lg text-xs font-bold transition-colors flex items-center gap-1 ${
        currentPage === 1 
          ? 'bg-slate-100 text-slate-400 cursor-not-allowed border border-slate-200' 
          : 'bg-white text-slate-700 hover:text-[#168940] hover:border-[#168940] border border-slate-300 shadow-sm'
      }`;
      prevBtn.innerHTML = '<iconify-icon icon="lucide:chevron-left" width="1rem"></iconify-icon> Sebelumnya';
      if (currentPage > 1) {
        prevBtn.addEventListener('click', () => {
          currentPage--;
          updatePageResults();
          renderPagination();
          window.scrollTo({ top: 200, behavior: 'smooth' });
        });
      }
      paginationContainer.appendChild(prevBtn);

      // Page numbers with ellipses
      const range = [];
      const delta = 1; // Number of pages to show before and after current page
      const left = currentPage - delta;
      const right = currentPage + delta + 1;
      let lastVal;

      for (let i = 1; i <= totalPages; i++) {
        if (i === 1 || i === totalPages || (i >= left && i < right)) {
          range.push(i);
        }
      }

      for (let i of range) {
        if (lastVal) {
          if (i - lastVal === 2) {
            renderPageBtn(lastVal + 1);
          } else if (i - lastVal > 2) {
            renderEllipses();
          }
        }
        renderPageBtn(i);
        lastVal = i;
      }

      // Next Button
      const nextBtn = document.createElement('button');
      nextBtn.className = `px-3 py-1.5 rounded-lg text-xs font-bold transition-colors flex items-center gap-1 ${
        currentPage === totalPages 
          ? 'bg-slate-100 text-slate-400 cursor-not-allowed border border-slate-200' 
          : 'bg-white text-slate-700 hover:text-[#168940] hover:border-[#168940] border border-slate-300 shadow-sm'
      }`;
      nextBtn.innerHTML = 'Selanjutnya <iconify-icon icon="lucide:chevron-right" width="1rem"></iconify-icon>';
      if (currentPage < totalPages) {
        nextBtn.addEventListener('click', () => {
          currentPage++;
          updatePageResults();
          renderPagination();
          window.scrollTo({ top: 200, behavior: 'smooth' });
        });
      }
      paginationContainer.appendChild(nextBtn);
    }

    if (searchInput) {
      searchInput.addEventListener('input', (e) => {
        searchQuery = (e.target as HTMLInputElement).value.toLowerCase();
        filterCatalog();
      });
    }

    if (typeSelect) {
      typeSelect.addEventListener('change', (e) => {
        selectedType = (e.target as HTMLSelectElement).value;
        filterCatalog();
      });
    }

    if (subjectSelect) {
      subjectSelect.addEventListener('change', (e) => {
        selectedSubject = (e.target as HTMLSelectElement).value;
        filterCatalog();
      });
    }

    // Parse query parameter ?q=keyword on page load
    const urlParams = new URLSearchParams(window.location.search);
    const initialQuery = urlParams.get('q');
    if (initialQuery && searchInput) {
      searchInput.value = initialQuery;
      searchQuery = initialQuery.toLowerCase();
    }

    // Run filters initially
    filterCatalog();
  });
</script>
