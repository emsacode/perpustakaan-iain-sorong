---
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import catalogData from '../../../data/catalog.json';

// Group initial data by category for structured rendering
const books = catalogData.filter(item => item.type === 'Buku Cetak');
const theses = catalogData.filter(item => item.type.includes('Skripsi') || item.type.includes('Karya Ilmiah'));
const journals = catalogData.filter(item => item.type.includes('Jurnal') || item.type.includes('Artikel'));
---

<Layout title="Pencarian Terpadu - Perpustakaan IAIN Sorong">
  <Header />
  
  <main class="bg-slate-50 min-h-screen pb-16 font-sans">
    
    <!-- Hero Banner (Golden-Yellow/Orange Gradient) -->
    <div class="bg-gradient-to-r from-amber-500 via-orange-500 to-yellow-500 text-white py-12 md:py-16 border-b border-[#dadada] relative overflow-hidden">
      <!-- Decorative Icons Background -->
      <div class="absolute inset-0 opacity-10 flex items-center justify-between pointer-events-none px-12">
        <iconify-icon icon="lucide:book-open" width="10rem"></iconify-icon>
        <iconify-icon icon="lucide:search" width="12rem"></iconify-icon>
      </div>

      <div class="max-w-[1280px] mx-auto px-4 sm:px-6 lg:px-8 text-center relative z-10 flex flex-col items-center">
        <div class="w-16 h-16 bg-white/20 rounded-full flex items-center justify-center mb-4 border border-white/20">
          <iconify-icon icon="lucide:search" width="2rem" class="text-white"></iconify-icon>
        </div>
        <h1 class="text-3xl md:text-5xl font-serif font-bold tracking-tight mb-3">
          Pencarian Terpadu Perpustakaan
        </h1>
        <p class="text-sm md:text-base text-orange-100 max-w-2xl leading-relaxed font-sans mb-8">
          Satu pintu pencarian untuk seluruh koleksi Buku Cetak (SLiMS), Repositori Tugas Akhir (EPrints), dan Jurnal Ilmiah (OJS) IAIN Sorong.
        </p>

        <!-- Centered Search Box -->
        <div class="w-full max-w-3xl bg-white p-2 rounded-2xl shadow-xl flex items-center border border-slate-200">
          <div class="pl-3 pr-2 text-slate-400 flex items-center">
            <iconify-icon icon="lucide:search" width="1.25rem"></iconify-icon>
          </div>
          <input 
            type="text" 
            id="search-input" 
            placeholder="Ketik kata kunci judul, pengarang, subjek..."
            class="w-full py-3 text-slate-800 bg-transparent border-none outline-none font-sans text-sm md:text-base placeholder:text-slate-400"
          />
          <button 
            type="button" 
            id="search-btn" 
            class="bg-amber-500 hover:bg-amber-600 text-white font-bold px-6 md:px-8 py-3 rounded-xl transition-all duration-200 text-sm md:text-base shrink-0 shadow-sm"
          >
            Cari
          </button>
        </div>
      </div>
    </div>

    <!-- Alert / Notice Section -->
    <div class="max-w-[1280px] mx-auto px-4 sm:px-6 lg:px-8 mt-6">
      <div class="bg-amber-50 border-l-4 border-amber-500 p-4 rounded-r-xl flex gap-3 shadow-sm items-start">
        <iconify-icon icon="lucide:info" class="text-amber-600 mt-0.5" width="1.2rem"></iconify-icon>
        <div class="text-xs md:text-sm text-amber-800 leading-relaxed font-sans">
          <strong>Info Layanan:</strong> Untuk mengusulkan buku baru yang belum tersedia di perpustakaan fisik, dosen dan mahasiswa dapat menggunakan menu 
          <a href="/desiderata" class="font-bold underline text-amber-900 hover:text-amber-950">Layanan Usulan Buku</a>.
        </div>
      </div>
    </div>

    <!-- Main Results List Area -->
    <div class="max-w-[1280px] mx-auto px-4 sm:px-6 lg:px-8 mt-8">
      
      <!-- CATEGORY 1: BUKU CETAK (SLiMS OPAC) -->
      <div class="mb-12 scroll-mt-24" id="books-section">
        <h2 class="text-lg md:text-xl font-serif font-bold text-slate-800 mb-4 pb-2 border-b border-slate-200 flex items-center justify-between">
          <span class="flex items-center gap-2">
            <iconify-icon icon="lucide:book-open" class="text-emerald-600"></iconify-icon>
            Pustaka / Katalog Buku (SLiMS OPAC)
          </span>
          <span class="text-xs font-mono bg-emerald-100 text-emerald-800 px-2.5 py-0.5 rounded-full font-bold" id="books-count">
            {books.length} Koleksi
          </span>
        </h2>
        
        <div class="flex flex-col gap-4" id="books-container">
          {books.map(item => (
            <div class="catalog-item bg-white rounded-xl shadow-sm border border-slate-200 p-5 flex flex-col md:flex-row gap-5 hover:shadow-md hover:border-emerald-300 transition-all duration-200" data-id={item.id} data-title={item.title.toLowerCase()} data-author={item.authors.map(a => a.name.toLowerCase()).join(' ')}>
              <!-- Left Side Resource Icon -->
              <div class="flex-shrink-0 flex items-center justify-center w-12 h-12 rounded-xl bg-emerald-50 text-emerald-600 border border-emerald-100">
                <iconify-icon icon="lucide:book-open" width="1.5rem"></iconify-icon>
              </div>
              <!-- Middle Main Details -->
              <div class="flex-grow">
                <span class="text-[10px] font-mono font-bold px-2 py-0.5 rounded bg-slate-100 text-slate-500 uppercase tracking-wider mb-2 inline-block">
                  ISBN: {item.isbn_issn || '-'}
                </span>
                <h3 class="font-sans font-bold text-lg text-slate-900 mb-1 leading-snug">
                  {item.title}
                </h3>
                <p class="text-xs text-slate-600 mb-2">
                  Penulis: <span class="font-semibold text-slate-700">{item.authors.map(a => a.name).join(', ')}</span> &bull; Penerbit: <span class="text-slate-700">{item.publisher} ({item.year})</span>
                </p>
                <p class="text-xs md:text-sm text-slate-500 line-clamp-2 leading-relaxed">
                  {item.abstract}
                </p>
              </div>
              <!-- Right Side CTA -->
              <div class="flex-shrink-0 flex items-center border-t md:border-t-0 md:border-l border-slate-100 pt-4 md:pt-0 md:pl-5 justify-end w-full md:w-auto">
                <a href={`/koleksi/katalog/${item.id}`} class="w-full md:w-auto bg-emerald-600 hover:bg-emerald-700 text-white font-bold text-xs py-2.5 px-5 rounded-lg transition-colors text-center no-underline shadow-sm whitespace-nowrap">
                  Detail Buku
                </a>
              </div>
            </div>
          ))}
        </div>
        <div class="hidden py-8 text-center bg-white rounded-xl border border-slate-200 border-dashed" id="books-empty">
          <p class="text-sm text-slate-500">Tidak ada buku cetak yang cocok.</p>
        </div>
        <!-- Pagination controls -->
        <div id="books-pagination" class="mt-6 flex items-center justify-center gap-3"></div>
      </div>

      <!-- CATEGORY 2: REPOSITORY ILMIAH (EPrints) -->
      <div class="mb-12 scroll-mt-24" id="theses-section">
        <h2 class="text-lg md:text-xl font-serif font-bold text-slate-800 mb-4 pb-2 border-b border-slate-200 flex items-center justify-between">
          <span class="flex items-center gap-2">
            <iconify-icon icon="lucide:graduation-cap" class="text-blue-600"></iconify-icon>
            Repository / Tugas Akhir (EPrints)
          </span>
          <span class="text-xs font-mono bg-blue-100 text-blue-800 px-2.5 py-0.5 rounded-full font-bold" id="theses-count">
            {theses.length} Dokumen
          </span>
        </h2>
        
        <div class="flex flex-col gap-4" id="theses-container">
          {theses.map(item => (
            <div class="catalog-item bg-white rounded-xl shadow-sm border border-slate-200 p-5 flex flex-col md:flex-row gap-5 hover:shadow-md hover:border-blue-300 transition-all duration-200" data-id={item.id} data-title={item.title.toLowerCase()} data-author={item.authors.map(a => a.name.toLowerCase()).join(' ')}>
              <!-- Left Side Resource Icon -->
              <div class="flex-shrink-0 flex items-center justify-center w-12 h-12 rounded-xl bg-blue-50 text-blue-600 border border-blue-100">
                <iconify-icon icon="lucide:graduation-cap" width="1.5rem"></iconify-icon>
              </div>
              <!-- Middle Main Details -->
              <div class="flex-grow">
                <span class="text-[10px] font-mono font-bold px-2 py-0.5 rounded bg-blue-50 text-blue-700 uppercase tracking-wider mb-2 inline-block">
                  Tahun Lulus: {item.year}
                </span>
                <h3 class="font-sans font-bold text-lg text-slate-900 mb-1 leading-snug">
                  {item.title}
                </h3>
                <p class="text-xs text-slate-600 mb-2">
                  Penyusun: <span class="font-semibold text-slate-700">{item.authors.map(a => a.name).join(', ')}</span> &bull; Bidang: <span class="text-slate-700">{item.subject}</span>
                </p>
                <p class="text-xs md:text-sm text-slate-500 line-clamp-2 leading-relaxed">
                  {item.abstract}
                </p>
              </div>
              <!-- Right Side CTA -->
              <div class="flex-shrink-0 flex items-center border-t md:border-t-0 md:border-l border-slate-100 pt-4 md:pt-0 md:pl-5 justify-end w-full md:w-auto">
                <a href={`/koleksi/katalog/${item.id}`} class="w-full md:w-auto bg-blue-600 hover:bg-blue-700 text-white font-bold text-xs py-2.5 px-5 rounded-lg transition-colors text-center no-underline shadow-sm whitespace-nowrap">
                  Detail Skripsi
                </a>
              </div>
            </div>
          ))}
        </div>
        <div class="hidden py-8 text-center bg-white rounded-xl border border-slate-200 border-dashed" id="theses-empty">
          <p class="text-sm text-slate-500">Tidak ada dokumen repositori yang cocok.</p>
        </div>
        <!-- Pagination controls -->
        <div id="theses-pagination" class="mt-6 flex items-center justify-center gap-3"></div>
      </div>

      <!-- CATEGORY 3: RUMAH JURNAL (OJS) -->
      <div class="mb-12 scroll-mt-24" id="journals-section">
        <h2 class="text-lg md:text-xl font-serif font-bold text-slate-800 mb-4 pb-2 border-b border-slate-200 flex items-center justify-between">
          <span class="flex items-center gap-2">
            <iconify-icon icon="lucide:file-text" class="text-orange-600"></iconify-icon>
            Artikel Jurnal Ilmiah (OJS)
          </span>
          <span class="text-xs font-mono bg-orange-100 text-orange-800 px-2.5 py-0.5 rounded-full font-bold" id="journals-count">
            {journals.length} Artikel
          </span>
        </h2>
        
        <div class="flex flex-col gap-4" id="journals-container">
          {journals.map(item => (
            <div class="catalog-item bg-white rounded-xl shadow-sm border border-slate-200 p-5 flex flex-col md:flex-row gap-5 hover:shadow-md hover:border-orange-300 transition-all duration-200" data-id={item.id} data-title={item.title.toLowerCase()} data-author={item.authors.map(a => a.name.toLowerCase()).join(' ')}>
              <!-- Left Side Resource Icon -->
              <div class="flex-shrink-0 flex items-center justify-center w-12 h-12 rounded-xl bg-orange-50 text-orange-600 border border-orange-100">
                <iconify-icon icon="lucide:file-text" width="1.5rem"></iconify-icon>
              </div>
              <!-- Middle Main Details -->
              <div class="flex-grow">
                <span class="text-[10px] font-mono font-bold px-2 py-0.5 rounded bg-orange-50 text-orange-700 uppercase tracking-wider mb-2 inline-block">
                  {item.subtitle}
                </span>
                <h3 class="font-sans font-bold text-lg text-slate-900 mb-1 leading-snug">
                  {item.title}
                </h3>
                <p class="text-xs text-slate-600 mb-2">
                  Penulis: <span class="font-semibold text-slate-700">{item.authors.map(a => a.name).join(', ')}</span> &bull; Terbitan: <span class="text-slate-700">{item.publisher} ({item.year})</span>
                </p>
                <p class="text-xs md:text-sm text-slate-500 line-clamp-2 leading-relaxed">
                  {item.abstract}
                </p>
              </div>
              <!-- Right Side CTA -->
              <div class="flex-shrink-0 flex items-center border-t md:border-t-0 md:border-l border-slate-100 pt-4 md:pt-0 md:pl-5 justify-end w-full md:w-auto">
                <a href={`/koleksi/katalog/${item.id}`} class="w-full md:w-auto bg-orange-600 hover:bg-orange-700 text-white font-bold text-xs py-2.5 px-5 rounded-lg transition-colors text-center no-underline shadow-sm whitespace-nowrap">
                  Detail Artikel
                </a>
              </div>
            </div>
          ))}
        </div>
        <div class="hidden py-8 text-center bg-white rounded-xl border border-slate-200 border-dashed" id="journals-empty">
          <p class="text-sm text-slate-500">Tidak ada artikel jurnal yang cocok.</p>
        </div>
        <!-- Pagination controls -->
        <div id="journals-pagination" class="mt-6 flex items-center justify-center gap-3"></div>
      </div>

      <!-- Global Empty State -->
      <div id="global-empty" class="hidden py-16 text-center bg-white rounded-2xl border border-slate-200 border-dashed shadow-sm">
        <iconify-icon icon="lucide:search-x" class="text-slate-300 mx-auto mb-4" width="4rem"></iconify-icon>
        <h3 class="text-lg font-bold text-slate-700 mb-1">Referensi Tidak Ditemukan</h3>
        <p class="text-sm text-slate-500">Kata kunci pencarian Anda tidak cocok dengan koleksi mana pun di SLiMS, EPrints, maupun OJS.</p>
      </div>

    </div>
  </main>

  <Footer />
</Layout>

<style is:global>
  /* Clean Tailwind styles for Pagination Buttons */
  .pag-btn {
    @apply px-4 py-2 text-xs md:text-sm font-bold bg-white border border-slate-200 text-slate-600 rounded-lg shadow-sm hover:bg-slate-50 hover:text-slate-900 transition-colors disabled:opacity-50 disabled:cursor-not-allowed disabled:hover:bg-white disabled:hover:text-slate-600;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const searchInput = document.getElementById('search-input') as HTMLInputElement;
    const searchBtn = document.getElementById('search-btn');
    const items = document.querySelectorAll('.catalog-item') as NodeListOf<HTMLElement>;
    
    // Page sizes and current state
    const PAGE_SIZE = 9;
    let booksPage = 1;
    let thesesPage = 1;
    let journalsPage = 1;

    // Containers & Sections
    const booksContainer = document.getElementById('books-container');
    const thesesContainer = document.getElementById('theses-container');
    const journalsContainer = document.getElementById('journals-container');

    const booksSection = document.getElementById('books-section');
    const thesesSection = document.getElementById('theses-section');
    const journalsSection = document.getElementById('journals-section');

    // Counts
    const booksCount = document.getElementById('books-count');
    const thesesCount = document.getElementById('theses-count');
    const journalsCount = document.getElementById('journals-count');

    // Empty States
    const booksEmpty = document.getElementById('books-empty');
    const thesesEmpty = document.getElementById('theses-empty');
    const journalsEmpty = document.getElementById('journals-empty');
    const globalEmpty = document.getElementById('global-empty');

    // Pagination Containers
    const booksPagContainer = document.getElementById('books-pagination');
    const thesesPagContainer = document.getElementById('theses-pagination');
    const journalsPagContainer = document.getElementById('journals-pagination');

    function filterAndPaginate(resetPage = false) {
      if (resetPage) {
        booksPage = 1;
        thesesPage = 1;
        journalsPage = 1;
      }

      const query = searchInput ? searchInput.value.toLowerCase().trim() : '';

      // Group matching items
      const matchingBooks: HTMLElement[] = [];
      const matchingTheses: HTMLElement[] = [];
      const matchingJournals: HTMLElement[] = [];

      items.forEach(item => {
        const id = item.getAttribute('data-id') || '';
        const title = item.getAttribute('data-title') || '';
        const author = item.getAttribute('data-author') || '';

        const match = query === '' || title.includes(query) || author.includes(query);

        // Hide all initially
        item.style.display = 'none';

        if (match) {
          if (id.startsWith('opac-')) matchingBooks.push(item);
          else if (id.startsWith('eprints-') || id.startsWith('epr-')) matchingTheses.push(item);
          else if (id.startsWith('ojs-')) matchingJournals.push(item);
        }
      });

      // Update Counts
      if (booksCount) booksCount.innerText = `${matchingBooks.length} Koleksi`;
      if (thesesCount) thesesCount.innerText = `${matchingTheses.length} Dokumen`;
      if (journalsCount) journalsCount.innerText = `${matchingJournals.length} Artikel`;

      // 1. Process SLiMS Books
      const totalBooksPages = Math.ceil(matchingBooks.length / PAGE_SIZE) || 1;
      if (booksPage > totalBooksPages) booksPage = totalBooksPages;

      if (booksContainer && booksEmpty) {
        if (matchingBooks.length === 0) {
          booksContainer.style.display = 'none';
          booksEmpty.style.display = 'block';
        } else {
          booksContainer.style.display = 'flex';
          booksEmpty.style.display = 'none';
          
          // Show only current page items
          const start = (booksPage - 1) * PAGE_SIZE;
          const end = start + PAGE_SIZE;
          matchingBooks.slice(start, end).forEach(item => {
            item.style.display = 'flex';
          });
        }
      }
      renderPaginationControls(booksPagContainer, booksPage, totalBooksPages, 'books');

      // 2. Process EPrints Theses
      const totalThesesPages = Math.ceil(matchingTheses.length / PAGE_SIZE) || 1;
      if (thesesPage > totalThesesPages) thesesPage = totalThesesPages;

      if (thesesContainer && thesesEmpty) {
        if (matchingTheses.length === 0) {
          thesesContainer.style.display = 'none';
          thesesEmpty.style.display = 'block';
        } else {
          thesesContainer.style.display = 'flex';
          thesesEmpty.style.display = 'none';

          // Show only current page items
          const start = (thesesPage - 1) * PAGE_SIZE;
          const end = start + PAGE_SIZE;
          matchingTheses.slice(start, end).forEach(item => {
            item.style.display = 'flex';
          });
        }
      }
      renderPaginationControls(thesesPagContainer, thesesPage, totalThesesPages, 'theses');

      // 3. Process OJS Journals
      const totalJournalsPages = Math.ceil(matchingJournals.length / PAGE_SIZE) || 1;
      if (journalsPage > totalJournalsPages) journalsPage = totalJournalsPages;

      if (journalsContainer && journalsEmpty) {
        if (matchingJournals.length === 0) {
          journalsContainer.style.display = 'none';
          journalsEmpty.style.display = 'block';
        } else {
          journalsContainer.style.display = 'flex';
          journalsEmpty.style.display = 'none';

          // Show only current page items
          const start = (journalsPage - 1) * PAGE_SIZE;
          const end = start + PAGE_SIZE;
          matchingJournals.slice(start, end).forEach(item => {
            item.style.display = 'flex';
          });
        }
      }
      renderPaginationControls(journalsPagContainer, journalsPage, totalJournalsPages, 'journals');

      // Global empty handling (when all are 0)
      const totalMatches = matchingBooks.length + matchingTheses.length + matchingJournals.length;
      if (globalEmpty) {
        if (totalMatches === 0) {
          globalEmpty.style.display = 'block';
        } else {
          globalEmpty.style.display = 'none';
        }
      }
    }

    function renderPaginationControls(container: HTMLElement | null, currentPage: number, totalPages: number, type: 'books' | 'theses' | 'journals') {
      if (!container) return;

      if (totalPages <= 1) {
        container.innerHTML = '';
        return;
      }

      container.innerHTML = `
        <button type="button" class="pag-btn prev-btn" ${currentPage === 1 ? 'disabled' : ''}>Sebelumnya</button>
        <span class="text-xs md:text-sm text-slate-500 font-sans">Halaman <strong>${currentPage}</strong> dari <strong>${totalPages}</strong></span>
        <button type="button" class="pag-btn next-btn" ${currentPage === totalPages ? 'disabled' : ''}>Selanjutnya</button>
      `;

      // Event Listeners
      const prevBtn = container.querySelector('.prev-btn');
      const nextBtn = container.querySelector('.next-btn');

      if (prevBtn) {
        prevBtn.addEventListener('click', () => {
          if (type === 'books') booksPage--;
          else if (type === 'theses') thesesPage--;
          else if (type === 'journals') journalsPage--;

          filterAndPaginate(false);
          scrollToSection(type);
        });
      }

      if (nextBtn) {
        nextBtn.addEventListener('click', () => {
          if (type === 'books') booksPage++;
          else if (type === 'theses') thesesPage++;
          else if (type === 'journals') journalsPage++;

          filterAndPaginate(false);
          scrollToSection(type);
        });
      }
    }

    function scrollToSection(type: 'books' | 'theses' | 'journals') {
      let target: HTMLElement | null = null;
      if (type === 'books') target = booksSection;
      else if (type === 'theses') target = thesesSection;
      else if (type === 'journals') target = journalsSection;

      if (target) {
        target.scrollIntoView({ behavior: 'smooth' });
      }
    }

    if (searchInput) {
      searchInput.addEventListener('input', () => filterAndPaginate(true));
    }
    if (searchBtn) {
      searchBtn.addEventListener('click', () => filterAndPaginate(true));
    }

    // Parse URL parameter q=keyword on page load
    const urlParams = new URLSearchParams(window.location.search);
    const initialQuery = urlParams.get('q');
    if (initialQuery && searchInput) {
      searchInput.value = initialQuery;
    }

    // Run initially
    filterAndPaginate(false);
  });
</script>
