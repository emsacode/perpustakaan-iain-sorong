---
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import catalogData from '../../../data/catalog.json';
import coversData from '../../../data/covers.json';

export async function getStaticPaths() {
  return catalogData.map(item => ({
    params: { id: item.id },
    props: { item }
  }));
}

const { item } = Astro.props;
const coverUrl = (coversData as Record<string, string>)[item.id] || null;
---

<Layout title={`${item.title} - Katalog Terpadu Perpustakaan IAIN Sorong`}>
  <Header />

  <!-- Breadcrumb -->
  <div class="bg-[#F7F7F2] border-b border-[#dadada]">
    <div class="max-w-[1280px] mx-auto px-4 sm:px-6 lg:px-8 py-3">
      <nav class="flex items-center gap-2 text-[11px] font-sans text-[#718096]">
        <a href="/" class="hover:text-primary transition-colors flex items-center gap-1">
          <iconify-icon icon="lucide:home"></iconify-icon> Beranda
        </a>
        <iconify-icon icon="lucide:chevron-right" class="text-[10px] opacity-50"></iconify-icon>
        <a href="/koleksi/katalog" class="hover:text-primary transition-colors">Katalog Terpadu</a>
        <iconify-icon icon="lucide:chevron-right" class="text-[10px] opacity-50"></iconify-icon>
        <span class="text-dark font-semibold line-clamp-1">{item.title}</span>
      </nav>
    </div>
  </div>

  <main class="bg-white py-8 lg:py-12">
    <div class="max-w-[1280px] mx-auto px-4 sm:px-6 lg:px-8">
      
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12">
        
        <!-- Left Area: Main Focus (Cover/Icon, Title, Abstract, Authors) -->
        <div class="lg:col-span-8">
          <div class="flex flex-col md:flex-row gap-6 md:gap-8">
            
            <!-- Book Cover Image or Fallback -->
            <div class="shrink-0 mx-auto md:mx-0">
              <div class="w-[200px] aspect-[3/4] bg-[#0b4226] rounded-[8px] shadow-md flex flex-col items-center justify-center text-center relative overflow-hidden border-b-[6px] border-[#D69E2E]">
                {coverUrl ? (
                  <img src={coverUrl} alt={item.title} class="w-full h-full object-cover" />
                ) : (
                  <>
                    <div class="absolute inset-0 opacity-5 bg-[linear-gradient(45deg,transparent_25%,#ffffff_25%,#ffffff_50%,transparent_50%,transparent_75%,#ffffff_75%,#ffffff_100%)] bg-[length:10px_10px]"></div>
                    {item.type.includes("Skripsi") || item.type.includes("Karya Ilmiah") ? (
                      <iconify-icon icon="lucide:graduation-cap" class="text-[#EAB308] text-5xl mb-4 z-10"></iconify-icon>
                    ) : item.type.includes("Jurnal") ? (
                      <iconify-icon icon="lucide:file-text" class="text-blue-400 text-5xl mb-4 z-10"></iconify-icon>
                    ) : (
                      <iconify-icon icon="lucide:book-open" class="text-emerald-400 text-5xl mb-4 z-10"></iconify-icon>
                    )}
                    <h3 class="text-white font-serif font-bold text-[13px] leading-snug z-10 line-clamp-3 px-4">
                      {item.title}
                    </h3>
                  </>
                )}
              </div>
              
              <div class="mt-4 flex gap-2">
                <span class="flex-1 text-center py-1.5 bg-[#F7F7F2] text-[#718096] text-[10px] font-bold uppercase tracking-wider rounded-[4px] border border-[#dadada]">
                  {item.circulation}
                </span>
                <span class="flex-1 text-center py-1.5 bg-primary/10 text-primary text-[10px] font-bold uppercase tracking-wider rounded-[4px]">
                  {item.format}
                </span>
              </div>
            </div>

            <!-- Content Details -->
            <div class="flex-1 font-sans">
              
              <div class="flex flex-wrap items-center gap-2 mb-3">
                <span class="bg-[#168940]/10 text-[#168940] text-[10px] font-bold px-2.5 py-1 rounded-full uppercase tracking-wider">
                  {item.type}
                </span>
                <div class="flex items-center gap-1 text-xs text-slate-500 font-medium">
                  <iconify-icon icon="lucide:eye" class="text-slate-400" width="1rem"></iconify-icon>
                  <span>{item.views} Views</span>
                </div>
              </div>
              
              <h1 class="text-2xl md:text-3xl font-serif font-bold text-dark leading-tight mb-2">
                {item.title}
              </h1>
              
              {item.subtitle && (
                <p class="text-sm md:text-base text-slate-500 font-medium font-serif italic mb-6">
                  {item.subtitle}
                </p>
              )}

              <div class="flex flex-wrap gap-4 text-[12px] text-[#718096] mb-8 pb-6 border-b border-[#dadada]">
                <span class="flex items-center gap-1.5"><iconify-icon icon="lucide:calendar"></iconify-icon> {item.year}</span>
                <span class="flex items-center gap-1.5"><iconify-icon icon="lucide:building"></iconify-icon> {item.publisher}</span>
                <span class="flex items-center gap-1.5"><iconify-icon icon="lucide:bookmark"></iconify-icon> {item.subject}</span>
              </div>

              <!-- Sinopsis/Abstrak -->
              <div class="mb-8">
                <h3 class="text-lg font-serif font-bold text-dark mb-3 flex items-center gap-2">
                  <iconify-icon icon="lucide:align-left" class="text-primary"></iconify-icon> 
                  {item.type.includes("Skripsi") || item.type.includes("Jurnal") ? "Abstrak" : "Sinopsis / Deskripsi"}
                </h3>
                <div class="prose prose-sm md:prose-base prose-green text-[#4a5568] leading-relaxed max-w-none">
                  {item.abstract.split('\n').map(paragraph => (
                    <p class="mb-4">{paragraph}</p>
                  ))}
                </div>
              </div>

              <!-- Author / Creator details -->
              <div class="bg-slate-50 border border-slate-200 rounded-xl p-5">
                <h4 class="text-sm font-bold text-[#0B4226] uppercase tracking-wider mb-4 flex items-center gap-1.5">
                  <iconify-icon icon="lucide:users" width="1.1rem"></iconify-icon>
                  Detail Kepengarangan
                </h4>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4 text-sm">
                  <div>
                    <span class="text-xs text-[#718096] block mb-1">Penulis Utama</span>
                    {item.authors.map(author => (
                      <div class="mb-2">
                        <span class="font-bold text-dark">{author.name}</span>
                        <span class="text-xs bg-slate-200 text-slate-700 px-2 py-0.5 rounded-full ml-2 font-medium">{author.type}</span>
                      </div>
                    ))}
                  </div>

                  {item.editors && item.editors.length > 0 && (
                    <div>
                      <span class="text-xs text-[#718096] block mb-1">Editor / Promotor</span>
                      <span class="font-semibold text-dark">{item.editors.join(', ')}</span>
                    </div>
                  )}

                  {item.translators && item.translators.length > 0 && (
                    <div class="md:col-span-2 border-t border-slate-200 pt-3">
                      <span class="text-xs text-[#718096] block mb-1">Penerjemah</span>
                      <span class="font-semibold text-dark">{item.translators.join(', ')}</span>
                    </div>
                  )}
                </div>
              </div>

            </div>
          </div>
        </div>

        <!-- Right Area: Sidebar Metadata & Actions -->
        <div class="lg:col-span-4">
          <div class="sticky top-[100px] border border-[#dadada] rounded-[10px] bg-[#F9FAFB] p-6 shadow-sm">
            
            <h3 class="text-[13px] font-bold text-dark font-serif uppercase tracking-widest border-b-[2px] border-primary pb-3 mb-4 flex items-center gap-1.5">
              <iconify-icon icon="lucide:info" class="text-primary" width="1.1rem"></iconify-icon>
              Informasi Katalog
            </h3>

            <!-- Metadata List -->
            <ul class="space-y-4 text-[12px] font-sans">
              <li class="flex flex-col gap-1">
                <span class="text-[#718096] font-semibold">Kode Klasifikasi</span>
                <span class="text-dark font-bold text-[13px] bg-white border border-[#dadada] w-max px-2.5 py-0.5 rounded-[4px] font-mono">
                  {item.classification}
                </span>
              </li>
              <li class="flex flex-col gap-1">
                <span class="text-[#718096] font-semibold">Kode Transaksi (System Code)</span>
                <span class="text-dark font-bold text-[13px]">{item.code}</span>
              </li>
              <li class="flex flex-col gap-1">
                <span class="text-[#718096] font-semibold">ISBN / ISSN</span>
                <span class="text-dark font-bold text-[13px]">{item.isbn_issn}</span>
              </li>
              <li class="flex flex-col gap-1">
                <span class="text-[#718096] font-semibold">Penerbit & Tempat Terbit</span>
                <span class="text-dark font-semibold text-[13px]">
                  {item.publisher}, {item.city} ({item.year})
                </span>
              </li>
              <li class="flex flex-col gap-1 border-t border-slate-200 pt-3">
                <span class="text-[#718096] font-semibold">Tanggal Diunggah / Terbit</span>
                <span class="text-dark font-semibold">{item.published_date}</span>
              </li>
              <li class="flex flex-col gap-1">
                <span class="text-[#718096] font-semibold">Format Dokumen</span>
                <span class="text-dark font-semibold">{item.format}</span>
              </li>
              <li class="flex flex-col gap-1">
                <span class="text-[#718096] font-semibold">Biaya Pinjam & Denda Harian</span>
                <span class="text-dark font-semibold">
                  Rp {item.rent_fee.toLocaleString('id-ID')} / Rp {item.penalty_per_day.toLocaleString('id-ID')} hari
                </span>
              </li>
            </ul>

            <!-- Call To Action: Download / OPAC Link -->
            <div class="mt-8 pt-6 border-t border-[#dadada]">
              <p class="text-[11px] text-[#718096] font-sans mb-3 text-center leading-snug">
                {item.physical_availability ? (
                  "Buku ini tersedia secara fisik di perpustakaan. Cek status salinan dan lokasi rak di sistem OPAC SLiMS."
                ) : item.source.includes("Repository") || item.source.includes("EPrints") ? (
                  "Dokumen karya ilmiah ini dapat diakses secara penuh di sistem repositori ilmiah institusi."
                ) : item.source.includes("OJS") || item.source.includes("Jurnal") ? (
                  "Artikel jurnal ilmiah ini dapat diakses secara penuh di portal Rumah Jurnal (OJS) kampus."
                ) : (
                  "Dokumen digital ini dapat diakses dan diunduh dalam format digital."
                )}
              </p>
              
              {item.physical_availability ? (
                <a 
                  href={item.download_url} 
                  target="_blank" 
                  rel="noopener noreferrer" 
                  class="w-full flex items-center justify-center gap-2 bg-primary hover:bg-[#0B4226] text-white font-sans font-bold text-[13px] py-3.5 px-4 rounded-[6px] transition-all shadow-[0_4px_12px_rgba(17,133,59,0.2)] hover:-translate-y-0.5"
                >
                  Cek Salinan di OPAC
                  <iconify-icon icon="lucide:external-link" class="text-[15px]"></iconify-icon>
                </a>
              ) : item.source.includes("Repository") || item.source.includes("EPrints") ? (
                <a 
                  href={item.download_url} 
                  target="_blank" 
                  rel="noopener noreferrer" 
                  class="download-pdf-btn w-full flex items-center justify-center gap-2 bg-[#168940] hover:bg-[#0B4226] text-white font-sans font-bold text-[13px] py-3.5 px-4 rounded-[6px] transition-all shadow-[0_4px_12px_rgba(17,133,59,0.2)] hover:-translate-y-0.5"
                >
                  Buka Halaman Repositori
                  <iconify-icon icon="lucide:external-link" class="text-[15px]"></iconify-icon>
                </a>
              ) : item.source.includes("OJS") || item.source.includes("Jurnal") ? (
                <a 
                  href={item.download_url} 
                  target="_blank" 
                  rel="noopener noreferrer" 
                  class="download-pdf-btn w-full flex items-center justify-center gap-2 bg-[#168940] hover:bg-[#0B4226] text-white font-sans font-bold text-[13px] py-3.5 px-4 rounded-[6px] transition-all shadow-[0_4px_12px_rgba(17,133,59,0.2)] hover:-translate-y-0.5"
                >
                  Buka Halaman Jurnal
                  <iconify-icon icon="lucide:external-link" class="text-[15px]"></iconify-icon>
                </a>
              ) : (
                <a 
                  href={item.download_url} 
                  class="download-pdf-btn w-full flex items-center justify-center gap-2 bg-[#168940] hover:bg-[#0B4226] text-white font-sans font-bold text-[13px] py-3.5 px-4 rounded-[6px] transition-all shadow-[0_4px_12px_rgba(17,133,59,0.2)] hover:-translate-y-0.5"
                  onclick="alert('Mengunduh dokumen digital...'); return false;"
                >
                  Unduh Dokumen PDF
                  <iconify-icon icon="lucide:download" class="text-[15px]"></iconify-icon>
                </a>
              )}
            </div>

          </div>
        </div>

      </div>

    </div>
  </main>

  <Footer />
</Layout>

<script>
  // Capture click events on download/read buttons to track usage stats
  document.addEventListener('DOMContentLoaded', () => {
    const downloadButtons = document.querySelectorAll('.download-pdf-btn');
    const API_URL = import.meta.env.PUBLIC_API_URL || "https://api.emsacode.com";
    
    downloadButtons.forEach(btn => {
      btn.addEventListener('click', async () => {
        try {
          // Trigger download event directly to the API gateway (proxy or direct)
          await fetch(`${API_URL}/api/v1/library/stats/download-event`, {
            method: 'POST',
            headers: {
              'Accept': 'application/json'
            }
          });
          console.log('Download event logged successfully.');
        } catch (err) {
          console.error('Failed to log digital collection download:', err);
        }
      });
    });
  });
</script>
