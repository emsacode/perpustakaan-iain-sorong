---
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
---

<Layout title="Koleksi E-Paper Surat Kabar & Majalah - Perpustakaan IAIN Sorong">
  <Header />
  
  <main class="bg-[#FAF9F6] min-h-screen pb-16 font-sans text-slate-700">
    <!-- Hero Banner Section -->
    <div class="bg-gradient-to-r from-[#0B4226] to-[#168940] text-white py-10 md:py-14 border-b border-emerald-800">
      <div class="max-w-[1280px] mx-auto px-4 sm:px-6 lg:px-8">
        <nav class="flex gap-2 text-xs text-[#BBF7D0] mb-3 font-medium">
          <a href="/" class="hover:underline">Beranda</a>
          <span>/</span>
          <span class="text-white">Koleksi</span>
          <span>/</span>
          <span class="text-white">E-Paper Surat Kabar</span>
        </nav>
        <h1 class="text-2xl md:text-4xl font-serif font-bold tracking-tight mb-3">
          Koleksi Surat Kabar &amp; Majalah Digital
        </h1>
        <p class="text-sm md:text-base text-[#BBF7D0] max-w-3xl leading-relaxed font-serif">
          Akses arsip surat kabar harian cetak versi elektronik secara real-time. Baca koran nasional dan daerah terbaru untuk mendukung kelengkapan referensi sivitas akademika IAIN Sorong.
        </p>
      </div>
    </div>

    <!-- Main Container -->
    <div class="max-w-[1280px] mx-auto px-4 sm:px-6 lg:px-8 mt-6">
      
      <!-- CONTROL PANEL -->
      <div class="bg-white border border-slate-200/80 rounded-2xl shadow-sm p-4 mb-8">
        <div class="flex flex-col md:flex-row items-center gap-4 w-full">
          <!-- Search Bar -->
          <div class="relative w-full md:w-[25%] shrink-0">
            <div class="relative">
              <input 
                type="text" 
                id="search-input" 
                placeholder="Cari koran..."
                class="w-full pl-10 pr-4 py-2 border border-slate-200 rounded-xl text-sm text-slate-700 focus:outline-none focus:border-[#168940]/50 bg-slate-50 focus:bg-white hover:bg-slate-100/50 transition-colors shadow-sm"
              />
              <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none text-slate-400">
                <iconify-icon icon="lucide:search" width="1.1rem"></iconify-icon>
              </div>
            </div>
          </div>

          <!-- Publisher Filter -->
          <div class="w-full md:w-[75%] min-w-0">
            <div class="flex flex-row gap-2 overflow-x-auto py-1.5 scrollbar-thin scrollbar-thumb-slate-200 scrollbar-track-transparent" id="publisher-filters">
              <!-- Dynamically rendered -->
              <button class="filter-btn active shrink-0 px-4 py-2 rounded-full text-xs font-bold transition-all bg-[#168940] text-white border border-[#168940] shadow-sm hover:shadow" data-publisher="all">
                Semua Koran
              </button>
              <div class="flex gap-2" id="dynamic-publishers">
                <!-- Skeleton categories -->
                <div class="h-8 w-24 bg-slate-100 animate-pulse rounded-full"></div>
                <div class="h-8 w-28 bg-slate-100 animate-pulse rounded-full"></div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- SKELETON LOADER GRID -->
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-4 md:gap-6" id="skeleton-grid">
        {Array.from({ length: 10 }).map(() => (
          <div class="bg-white rounded-2xl shadow-sm border border-slate-200/60 overflow-hidden p-3 space-y-3">
            <div class="bg-slate-100 aspect-[3/4] rounded-xl animate-pulse w-full"></div>
            <div class="h-4 bg-slate-100 animate-pulse rounded w-3/4"></div>
            <div class="h-3 bg-slate-100 animate-pulse rounded w-1/2"></div>
          </div>
        ))}
      </div>

      <!-- GRID KOLEKSI (DYNAMICALLY RENDERED) -->
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-4 md:gap-6 hidden" id="epaper-grid">
      </div>
      
      <!-- Empty State -->
      <div id="empty-state" class="hidden py-16 text-center bg-white rounded-2xl border border-slate-200/80 border-dashed shadow-sm">
        <iconify-icon icon="lucide:search-x" class="text-slate-300 mx-auto mb-3" width="3.5rem"></iconify-icon>
        <h3 class="text-lg font-bold text-slate-800 mb-1">Edisi Tidak Ditemukan</h3>
        <p class="text-sm text-slate-400 font-medium">Coba gunakan kata kunci atau filter penerbit yang berbeda.</p>
      </div>

      <!-- Error State -->
      <div id="error-state" class="hidden py-16 text-center bg-white rounded-2xl border border-slate-200/80 border-dashed shadow-sm">
        <iconify-icon icon="lucide:cloud-lightning" class="text-amber-500 mx-auto mb-3" width="3.5rem"></iconify-icon>
        <h3 class="text-lg font-bold text-slate-800 mb-1">Koneksi API Gagal</h3>
        <p class="text-sm text-slate-400 font-medium mb-4">Gagal terhubung dengan server Koran Digital DDAG.</p>
        <button id="retry-btn" class="px-5 py-2.5 bg-[#168940] hover:bg-[#0B4226] text-white text-xs font-bold rounded-lg shadow-sm transition-colors cursor-pointer">
          Coba Lagi
        </button>
      </div>
      
    </div>
  </main>
  
  <Footer />

  <!-- DFlip Dependencies -->
  <link href="https://cdn.jsdelivr.net/npm/@dearhive/dearflip-jquery-flipbook@1.7.3/dflip/css/dflip.min.css" rel="stylesheet" type="text/css">
  <link href="https://cdn.jsdelivr.net/npm/@dearhive/dearflip-jquery-flipbook@1.7.3/dflip/css/themify-icons.min.css" rel="stylesheet" type="text/css">
  <script is:inline src="https://cdn.jsdelivr.net/npm/jquery@3.6.0/dist/jquery.min.js"></script>
  <script is:inline>
    window.dFlipLocation = "https://cdn.jsdelivr.net/npm/@dearhive/dearflip-jquery-flipbook@1.7.3/dflip/";
  </script>
  <script is:inline src="https://cdn.jsdelivr.net/npm/@dearhive/dearflip-jquery-flipbook@1.7.3/dflip/js/dflip.min.js"></script>
  
  <script is:inline>
    if (window.DFLIP && window.DFLIP.defaults) {
      Object.assign(window.DFLIP.defaults, {
        webgl: true,
        zoomRatio: 1.5,
        autoEnableOutline: false,
        autoEnableThumbnail: true,
        backgroundColor: "#FAF9F6",
        threejsSrc: "https://cdn.jsdelivr.net/npm/@dearhive/dearflip-jquery-flipbook@1.7.3/dflip/js/libs/three.min.js",
        soundFile: "https://cdn.jsdelivr.net/npm/@dearhive/dearflip-jquery-flipbook@1.7.3/dflip/sound/turn2.mp3"
      });
    }
  </script>
</Layout>

