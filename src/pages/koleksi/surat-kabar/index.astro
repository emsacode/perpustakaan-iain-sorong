        file_url: "/epaper/Satelit News - 17 Juni 2026.pdf",
        published_at: "2026-06-17"
      }
    ];

    let originalData: EpaperItem[] = [];
    let currentFilter = 'all';
    let searchQuery = '';

    async function loadNewspapers() {
      if (skeletonGrid) skeletonGrid.classList.remove('hidden');
      if (epaperGrid) epaperGrid.classList.add('hidden');
      if (emptyState) emptyState.classList.add('hidden');
      if (errorState) errorState.classList.add('hidden');

      try {
        // Fetch from local Laravel proxy endpoint to bypass CORS and hide API secrets
        const dataResponse = await fetch((import.meta.env.PUBLIC_API_URL || 'https://dash-perpus.emsacode.com') + '/api/v1/newspapers');

        if (!dataResponse.ok) throw new Error('Data fetch failed');
        const result = await dataResponse.json();

        if (result.success && Array.isArray(result.data) && result.data.length > 0) {
          originalData = result.data;
        } else {
          console.warn('API returned empty or invalid data, using local fallback.');
          originalData = localNewspapers;
        }
        renderFilters();
        renderGrid();
      } catch (err) {
        console.warn('Koran Digital API error, falling back to local fallback:', err);
        originalData = localNewspapers;
        renderFilters();
        renderGrid();
      }
    }

    function renderFilters() {
      if (!dynamicPublishers) return;
      dynamicPublishers.innerHTML = '';

      // Get unique category names
      const categories = [...new Set(originalData.map(item => item.category_name))].sort();

      categories.forEach(cat => {
        const btn = document.createElement('button');
        btn.className = 'filter-btn shrink-0 px-4 py-2 rounded-full text-xs font-bold transition-all bg-white text-slate-600 border border-slate-200 hover:border-[#168940] hover:text-[#168940] hover:bg-[#FAF9F6] shadow-sm cursor-pointer';
        btn.textContent = cat;
        btn.setAttribute('data-publisher', cat);
        
        btn.addEventListener('click', (e) => {
          // Reset all filter buttons
          const allBtns = document.querySelectorAll('.filter-btn');
          allBtns.forEach(b => {
            b.classList.remove('bg-[#168940]', 'text-white', 'border-[#168940]');
            b.classList.add('bg-white', 'text-slate-600', 'border-slate-200');
          });

          const target = e.currentTarget as HTMLElement;
          target.classList.remove('bg-white', 'text-slate-600', 'border-slate-200');
          target.classList.add('bg-[#168940]', 'text-white', 'border-[#168940]');

          currentFilter = target.getAttribute('data-publisher') || 'all';
          renderGrid();
        });

        dynamicPublishers.appendChild(btn);
      });

      // Bind the "Semua Koran" button
      const allBtn = document.querySelector('[data-publisher="all"]');
      if (allBtn) {
        allBtn.addEventListener('click', (e) => {
          const allBtns = document.querySelectorAll('.filter-btn');
          allBtns.forEach(b => {
            b.classList.remove('bg-[#168940]', 'text-white', 'border-[#168940]');
            b.classList.add('bg-white', 'text-slate-600', 'border-slate-200');
          });

          const target = e.currentTarget as HTMLElement;
          target.classList.remove('bg-white', 'text-slate-600', 'border-slate-200');
          target.classList.add('bg-[#168940]', 'text-white', 'border-[#168940]');

          currentFilter = 'all';
          renderGrid();
        });
      }
    }

    function renderGrid() {
      if (!epaperGrid || !skeletonGrid) return;

      skeletonGrid.classList.add('hidden');
      epaperGrid.innerHTML = '';

      // Filter local list
      const filtered = originalData.filter(item => {
        const matchPub = currentFilter === 'all' || item.category_name === currentFilter;
        const matchSearch = searchQuery === '' || item.title.toLowerCase().includes(searchQuery);
        return matchPub && matchSearch;
      });

      if (filtered.length === 0) {
        epaperGrid.classList.add('hidden');
        if (emptyState) emptyState.classList.remove('hidden');
        return;
      }

      if (emptyState) emptyState.classList.add('hidden');
      epaperGrid.classList.remove('hidden');

      filtered.forEach(item => {
        const card = document.createElement('div');
        card.className = 'epaper-card group block bg-white rounded-2xl shadow-sm border border-slate-200/60 overflow-hidden hover:shadow-md hover:border-[#168940]/40 transition-all duration-300 transform hover:-translate-y-1 cursor-pointer p-3';
        card.setAttribute('source', item.file_url);
        card.setAttribute('role', 'button');
        card.setAttribute('tabindex', '0');
        card.setAttribute('aria-label', `Baca koran ${item.title}`);

        // Custom formatted date
        const pubDate = item.published_at ? new Date(item.published_at).toLocaleDateString('id-ID', {
          day: 'numeric',
          month: 'long',
          year: 'numeric'
        }) : '';

        card.innerHTML = `
          <!-- Cover Depan Koran -->
          <div class="bg-slate-55 aspect-[3/4] border border-slate-100 rounded-xl relative overflow-hidden">
            <img 
              src="${item.cover_url}" 
              alt="Cover ${item.title}"
              class="w-full h-full object-cover object-top transition-transform duration-500 group-hover:scale-105"
              loading="lazy"
              onerror="this.src='/images/katalog-default.png'"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/40 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-all duration-300 flex items-end justify-center pb-6">
              <span class="bg-[#168940] text-white text-[11px] font-bold px-3 py-1.5 rounded-lg shadow flex items-center gap-1 transform translate-y-2 group-hover:translate-y-0 transition-all duration-300">
                <iconify-icon icon="lucide:book-open" width="0.9rem"></iconify-icon>
                Baca Koran
              </span>
            </div>
          </div>
          
          <div class="pt-3">
            <h3 class="font-bold text-sm text-[#0B4226] line-clamp-2 leading-snug group-hover:text-[#168940] transition-colors">
              ${item.title}
            </h3>
            <div class="mt-2 flex items-center justify-between text-[10px] font-medium">
              <span class="text-slate-400">${pubDate}</span>
              <span class="bg-emerald-50 border border-emerald-100/50 text-emerald-700 px-2 py-0.5 rounded-full font-bold uppercase tracking-wider text-[9px]">
                ${item.category_name}
              </span>
            </div>
          </div>
        `;

        // Click to open in Lightbox flipbook reader
        card.addEventListener('click', () => {
          const pdfUrl = card.getAttribute('source');
          if (pdfUrl) {
            // @ts-ignore
            if (window.DFLIP) {
              // @ts-ignore
              window.DFLIP.showLightbox(pdfUrl, {
                title: item.title,
                webgl: true
              });
            } else {
              window.open(pdfUrl, '_blank');
            }
          }
        });

        epaperGrid.appendChild(card);
      });
    }

    if (searchInput) {
      searchInput.addEventListener('input', (e) => {
        searchQuery = (e.target as HTMLInputElement).value.toLowerCase();
        renderGrid();
      });
    }

    if (retryBtn) {
      retryBtn.addEventListener('click', loadNewspapers);
    }

    // Keyboard accessibility for card selection (Space or Enter key)
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') {
        const activeEl = document.activeElement;
        if (activeEl && activeEl.classList.contains('epaper-card')) {
          e.preventDefault();
          (activeEl as HTMLElement).click();
        }
      }
    });

    // Load initially
    loadNewspapers();
  });
</script>
