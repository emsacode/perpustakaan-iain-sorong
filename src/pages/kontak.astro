---
import LayoutSidebar from '../layouts/LayoutSidebar.astro';

const sidebarMenu = {
    title: "Layanan & Aturan",
    items: [{"label": "Tata Tertib Pemustaka", "href": "/tata-tertib"}, {"label": "Panduan Ruangan Gedung", "href": "/panduan-ruangan"}, {"label": "Kontak & Lokasi", "href": "/kontak"}, {"label": "Survei Kepuasan (IKM)", "href": "/survei"}]
};
---

<LayoutSidebar title="Kontak & Lokasi" sidebarMenu={sidebarMenu}>
    
    <p class="font-serif text-[15px] text-[#444444] leading-relaxed mb-10">
        Punya pertanyaan terkait peminjaman, keanggotaan, atau akses layanan digital? Tim layanan Perpustakaan IAIN Sorong dengan senang hati siap membantu Anda melalui berbagai saluran komunikasi.
    </p>

    <!-- Map & Address Container -->
    <div class="bg-white rounded-[8px] overflow-hidden border border-[#dadada] shadow-sm mb-12">
        <div class="grid grid-cols-1 md:grid-cols-2">
            <!-- Address Info -->
            <div class="p-8 md:p-10 bg-[#F8FAFC]">
                <div class="w-12 h-12 bg-[#F0FDF4] border border-[#dadada] rounded-[8px] flex items-center justify-center text-[#168940] mb-6 shadow-sm">
                    <iconify-icon icon="flat-color-icons:marker" ></iconify-icon>
                </div>
                <h3 class="text-2xl font-semibold text-[#222222] mb-4 m-0 tracking-tight">Gedung Pusat Perpustakaan</h3>
                <p class="font-serif text-sm text-[#444444] leading-relaxed mb-8 m-0">
                    Jalan Sorong - Klamono Km. 17 Klablim, Distrik Klaurung,<br/>
                    Kota Sorong, Papua Barat Daya 98416
                </p>
                <a href="https://maps.google.com/maps?q=IAIN+Sorong+Papua+Barat+Daya" target="_blank" class="inline-flex items-center gap-2 px-6 py-3 bg-[#168940] text-white rounded-[4px] font-semibold hover:bg-[#0B4226] transition-colors focus-visible:ring-[3px] focus-visible:ring-[#EAB308] outline-none text-sm group">
                    <iconify-icon icon="flat-color-icons:map" class="group-hover:-translate-y-1 transition-transform"></iconify-icon>
                    Buka di Google Maps
                </a>
            </div>
            <!-- Embed Google Maps IAIN Sorong -->
            <div class="relative min-h-[250px] overflow-hidden border-l border-[#dadada]">
                <iframe
                    src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3989.8!2d131.24!3d-0.88!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x2d4a4f08d7b5d5b5%3A0x1234567890abcdef!2sIAIN%20Sorong!5e0!3m2!1sid!2sid!4v1234567890"
                    width="100%"
                    height="100%"
                    style="border:0; min-height: 250px;"
                    allowfullscreen
                    loading="lazy"
                    referrerpolicy="no-referrer-when-downgrade"
                    title="Peta Lokasi IAIN Sorong"
                    class="absolute inset-0 w-full h-full"
                ></iframe>
            </div>
        </div>
    </div>

    <!-- Communication Channels -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-12">
        <!-- WhatsApp -->
        <a href="https://wa.me/6282194132703" target="_blank" class="bg-white border border-[#dadada] p-6 rounded-[8px] shadow-sm hover:border-[#BBF7D0] hover:shadow-md transition-all group block no-underline outline-none focus-visible:ring-[3px] focus-visible:ring-[#EAB308]">
            <div class="flex items-center gap-4 mb-4">
                <div class="w-12 h-12 bg-green-50 text-green-600 border border-green-200 rounded-[8px] flex items-center justify-center shrink-0 group-hover:bg-green-100 transition-colors">
                    <iconify-icon icon="logos:whatsapp-icon" ></iconify-icon>
                </div>
                <div>
                    <h4 class="font-semibold text-[#222222] m-0">WhatsApp Cepat</h4>
                    <p class="font-serif text-sm text-[#666666] m-0">Chat pada jam layanan</p>
                </div>
            </div>
            <p class="text-lg font-mono font-bold text-[#168940] m-0 tracking-tight">0821 9413 2703</p>
        </a>

        <!-- Email -->
        <a href="mailto:perpustakaan@iainsorong.ac.id" class="bg-white border border-[#dadada] p-6 rounded-[8px] shadow-sm hover:border-[#BBF7D0] hover:shadow-md transition-all group block no-underline outline-none focus-visible:ring-[3px] focus-visible:ring-[#EAB308]">
            <div class="flex items-center gap-4 mb-4">
                <div class="w-12 h-12 bg-[#F8FAFC] text-blue-600 border border-[#dadada] rounded-[8px] flex items-center justify-center shrink-0 group-hover:border-blue-200 transition-colors">
                    <iconify-icon icon="flat-color-icons:letter" ></iconify-icon>
                </div>
                <div>
                    <h4 class="font-semibold text-[#222222] m-0">Email Resmi</h4>
                    <p class="font-serif text-sm text-[#666666] m-0">Untuk persuratan & institusi</p>
                </div>
            </div>
            <p class="text-lg font-bold text-blue-600 m-0 tracking-tight">perpustakaan@iainsorong.ac.id</p>
        </a>
    </div>

    <!-- Social Media -->
    <div class="bg-[#F8FAFC] border border-[#dadada] rounded-[8px] p-8 shadow-sm">
        <div class="text-center mb-8">
            <h3 class="text-2xl font-semibold text-[#222222] mb-2 m-0 tracking-tight">Ikuti Media Sosial Kami</h3>
            <p class="font-serif text-[#444444] text-sm m-0">Dapatkan info literasi terbaru, koleksi buku baru, dan jadwal bedah buku.</p>
        </div>

        <div class="flex flex-wrap justify-center gap-4">
            <a href="https://www.instagram.com/pustakaiainsorong/" target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 px-6 py-3 bg-white border border-[#dadada] rounded-[4px] hover:shadow-sm hover:-translate-y-0.5 hover:border-pink-300 transition-all text-[#222222] no-underline font-semibold text-sm outline-none focus-visible:ring-[3px] focus-visible:ring-[#EAB308]">
                <iconify-icon icon="skill-icons:instagram" ></iconify-icon>
                <span>@pustakaiainsorong</span>
            </a>
            
            <a href="https://www.facebook.com/perpustakaaniainsorong" target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 px-6 py-3 bg-white border border-[#dadada] rounded-[4px] hover:shadow-sm hover:-translate-y-0.5 hover:border-blue-300 transition-all text-[#222222] no-underline font-semibold text-sm outline-none focus-visible:ring-[3px] focus-visible:ring-[#EAB308]">
                <iconify-icon icon="logos:facebook" ></iconify-icon>
                <span>Perpustakaan IAIN Sorong</span>
            </a>
            
            <a href="https://www.youtube.com/@PustakaPertamaIAINSorong" target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 px-6 py-3 bg-white border border-[#dadada] rounded-[4px] hover:shadow-sm hover:-translate-y-0.5 hover:border-red-300 transition-all text-[#222222] no-underline font-semibold text-sm outline-none focus-visible:ring-[3px] focus-visible:ring-[#EAB308]">
                <iconify-icon icon="logos:youtube-icon" ></iconify-icon>
                <span>Pustaka IAIN Sorong</span>
            </a>
        </div>
    </div>

</LayoutSidebar>
