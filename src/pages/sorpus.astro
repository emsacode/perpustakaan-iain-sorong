---
import LayoutSidebar from '../layouts/LayoutSidebar.astro';

const sidebarMenu = {
    title: "Layanan & Koleksi",
    items: [{"label": "Sistem Otomasi (SORPUS)", "href": "/sorpus"}, {"label": "Keanggotaan Online", "href": "/k-online"}, {"label": "IAIN Sorong Press", "href": "/iainsorong-press"}]
};
---

<LayoutSidebar title="Sistem Otomasi (SORPUS)" sidebarMenu={sidebarMenu}>
    
    <!-- Hero Banner for External System (Clean Light Style) -->
    <div class="bg-white border border-[#dadada] rounded-[8px] overflow-hidden mb-12 shadow-sm relative group hover:border-[#BBF7D0] transition-all">
        <!-- Dashboard Mockup Decorative -->
        <div class="absolute right-0 bottom-0 w-[60%] h-[80%] translate-y-1/4 translate-x-1/4 opacity-30 z-0">
            <div class="w-full h-full bg-[#F8FAFC] rounded-tl-xl border-t border-l border-[#dadada] shadow-sm flex flex-col">
                <div class="h-4 bg-[#F0FDF4] border-b border-[#dadada] flex items-center gap-1 px-2">
                    <div class="w-2 h-2 rounded-full bg-[#dadada]"></div>
                    <div class="w-2 h-2 rounded-full bg-[#dadada]"></div>
                    <div class="w-2 h-2 rounded-full bg-[#dadada]"></div>
                </div>
                <div class="p-4 grid grid-cols-3 gap-2">
                    <div class="h-10 bg-white border border-[#dadada] rounded-[4px] col-span-1"></div>
                    <div class="h-10 bg-white border border-[#dadada] rounded-[4px] col-span-2"></div>
                    <div class="h-20 bg-white border border-[#dadada] rounded-[4px] col-span-3 mt-2"></div>
                </div>
            </div>
        </div>
        
        <div class="relative z-10 p-8 md:p-10 flex flex-col md:flex-row items-center gap-8">
            <div class="w-20 h-20 bg-[#F0FDF4] border border-[#dadada] rounded-[8px] flex items-center justify-center text-[#168940] shadow-sm shrink-0 group-hover:border-[#BBF7D0] transition-colors">
                <iconify-icon icon="flat-color-icons:server" ></iconify-icon>
            </div>
            <div class="text-center md:text-left flex-1">
                <div class="inline-flex items-center gap-2 mb-3">
                    <span class="px-3 py-1 bg-[#F8FAFC] border border-[#dadada] rounded-[4px] text-[#666666] text-[11px] font-semibold uppercase tracking-wider flex items-center gap-1">
                        <iconify-icon icon="flat-color-icons:database"></iconify-icon> OPAC SLiMS 9
                    </span>
                </div>
                <h2 class="text-2xl md:text-3xl font-semibold text-[#222222] mb-2 tracking-tight m-0">SORPUS</h2>
                <p class="font-serif text-[15px] text-[#444444] mb-6 m-0">Sorong Perpustakaan Otomasi Sistem</p>
                <a href="http://perpustakaan.iainsorong.ac.id" target="_blank" class="inline-flex items-center gap-2 bg-[#168940] hover:bg-[#0B4226] text-white font-semibold py-3 px-6 rounded-[4px] shadow-sm transition-colors focus:outline-none focus:ring-[3px] focus:ring-[#EAB308] text-sm no-underline">
                    Buka Portal SORPUS
                    <iconify-icon icon="flat-color-icons:up-right" ></iconify-icon>
                </a>
            </div>
        </div>
    </div>

    <!-- Info Content -->
    <div class="mb-10">
        <h3 class="text-2xl font-semibold text-[#222222] mb-4 m-0 tracking-tight">Mencari Buku Menjadi Lebih Mudah</h3>
        <p class="font-serif text-[15px] text-[#444444] leading-relaxed m-0">
            <strong>SORPUS</strong> adalah katalog publik dalam jaringan (OPAC) berbasis SLiMS 9 Bulian. Melalui SORPUS, Anda tidak perlu lagi mencari buku secara manual dari rak ke rak.
        </p>
    </div>

    <!-- Fitur Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div class="bg-white border border-[#dadada] p-6 rounded-[8px] shadow-sm hover:shadow-md hover:border-[#BBF7D0] transition-all flex items-start gap-4">
            <div class="w-12 h-12 bg-[#F0FDF4] border border-[#dadada] rounded-[8px] flex items-center justify-center shrink-0 text-[#168940]">
                <iconify-icon icon="flat-color-icons:search" ></iconify-icon>
            </div>
            <div>
                <h4 class="font-semibold text-[#222222] mb-1 m-0">Pencarian Cepat</h4>
                <p class="font-serif text-sm text-[#444444] m-0 leading-relaxed">Cari buku berdasarkan Judul, Pengarang, atau ISBN dalam hitungan detik.</p>
            </div>
        </div>
        
        <div class="bg-white border border-[#dadada] p-6 rounded-[8px] shadow-sm hover:shadow-md hover:border-[#BBF7D0] transition-all flex items-start gap-4">
            <div class="w-12 h-12 bg-[#F0FDF4] border border-[#dadada] rounded-[8px] flex items-center justify-center shrink-0 text-[#168940]">
                <iconify-icon icon="flat-color-icons:marker" ></iconify-icon>
            </div>
            <div>
                <h4 class="font-semibold text-[#222222] mb-1 m-0">Cek Ketersediaan</h4>
                <p class="font-serif text-sm text-[#444444] m-0 leading-relaxed">Ketahui secara real-time apakah buku sedang dipinjam atau tersedia di rak nomor berapa.</p>
            </div>
        </div>
        
        <div class="bg-white border border-[#dadada] p-6 rounded-[8px] shadow-sm hover:shadow-md hover:border-[#BBF7D0] transition-all flex items-start gap-4">
            <div class="w-12 h-12 bg-[#F0FDF4] border border-[#dadada] rounded-[8px] flex items-center justify-center shrink-0 text-[#168940]">
                <iconify-icon icon="flat-color-icons:bookmark" ></iconify-icon>
            </div>
            <div>
                <h4 class="font-semibold text-[#222222] mb-1 m-0">Riwayat Peminjaman</h4>
                <p class="font-serif text-sm text-[#444444] m-0 leading-relaxed">Login dengan nomor anggota untuk melihat buku apa saja yang sedang dan pernah Anda pinjam.</p>
            </div>
        </div>
        
        <div class="bg-white border border-[#dadada] p-6 rounded-[8px] shadow-sm hover:shadow-md hover:border-[#BBF7D0] transition-all flex items-start gap-4">
            <div class="w-12 h-12 bg-[#F0FDF4] border border-[#dadada] rounded-[8px] flex items-center justify-center shrink-0 text-[#168940]">
                <iconify-icon icon="flat-color-icons:clock" ></iconify-icon>
            </div>
            <div>
                <h4 class="font-semibold text-[#222222] mb-1 m-0">Perpanjangan Mandiri</h4>
                <p class="font-serif text-sm text-[#444444] m-0 leading-relaxed">Perpanjang masa pinjam buku Anda secara online tanpa perlu datang ke perpustakaan.</p>
            </div>
        </div>
    </div>

</LayoutSidebar>
