---
import LayoutSidebar from '../layouts/LayoutSidebar.astro';

const sidebarMenu = {
    title: "Fasilitas Ruangan",
    items: [{"label": "Lantai 1", "href": "/fasilitas/lantai-1"}, {"label": "Lantai Atas", "href": "/fasilitas/lantai-atas"}, {"label": "Reservasi Ruangan", "href": "/reservasi"}]
};
---

<LayoutSidebar title="Reservasi Ruangan" sidebarMenu={sidebarMenu}>
    
    <div class="mb-10 text-left">
        <h2 class="text-2xl font-semibold text-[#222222] mb-4 tracking-tight">Peminjaman Fasilitas</h2>
        <p class="font-serif text-[15px] text-[#444444] leading-relaxed">
            Gunakan formulir di bawah ini untuk mengajukan peminjaman Ruang Home Theater atau Area Diskusi Kelompok untuk keperluan akademik.
        </p>
    </div>

    <!-- Info Cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-8">
        <div class="bg-[#EFF6FF] border border-[#BFDBFE] rounded-[8px] p-5 flex gap-4 items-start shadow-sm hover:shadow-md hover:border-[#93C5FD] transition-all">
            <iconify-icon icon="flat-color-icons:info" class="shrink-0"></iconify-icon>
            <div>
                <h4 class="font-semibold text-blue-900 mb-1 m-0">Syarat Peminjaman</h4>
                <p class="font-serif text-[13px] text-blue-800/80 leading-relaxed m-0">Peminjaman diajukan maksimal H-2 sebelum acara. Prioritas diberikan untuk kegiatan perkuliahan, seminar proposal, atau bedah buku.</p>
            </div>
        </div>
        <div class="bg-[#FFFBEB] border border-[#FDE68A] rounded-[8px] p-5 flex gap-4 items-start shadow-sm hover:shadow-md hover:border-[#FCD34D] transition-all">
            <iconify-icon icon="flat-color-icons:warning-shield" class="shrink-0"></iconify-icon>
            <div>
                <h4 class="font-semibold text-amber-900 mb-1 m-0">Ketentuan Kapasitas</h4>
                <p class="font-serif text-[13px] text-amber-800/80 leading-relaxed m-0">Ruang Home Theater menampung maks 30 orang. Harap sesuaikan jumlah peserta agar tidak melebihi kapasitas ruangan.</p>
            </div>
        </div>
    </div>

    <!-- Form Container -->
    <div class="bg-white border border-[#dadada] rounded-[8px] p-6 md:p-8 shadow-sm mb-8">
        <form class="space-y-6" onsubmit="event.preventDefault(); alert('Permintaan reservasi telah dikirim. Menunggu konfirmasi admin.');">
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <!-- Nama Pemesan -->
                <div>
                    <label class="block text-sm font-semibold text-[#222222] mb-2">Nama Lengkap / Instansi <span class="text-red-500">*</span></label>
                    <input type="text" placeholder="Masukkan nama Anda" class="w-full bg-[#F8FAFC] border border-[#dadada] text-[#444444] font-serif rounded-[4px] px-4 py-3 focus:outline-none focus:ring-[3px] focus:ring-[#EAB308]/30 focus:border-[#168940] transition-colors" required>
                </div>

                <!-- Kontak -->
                <div>
                    <label class="block text-sm font-semibold text-[#222222] mb-2">Nomor WhatsApp <span class="text-red-500">*</span></label>
                    <input type="tel" placeholder="08xx xxxx xxxx" class="w-full bg-[#F8FAFC] border border-[#dadada] text-[#444444] font-serif rounded-[4px] px-4 py-3 focus:outline-none focus:ring-[3px] focus:ring-[#EAB308]/30 focus:border-[#168940] transition-colors" required>
                </div>
            </div>

            <!-- Pilihan Ruang -->
            <div class="pt-2">
                <label class="block text-sm font-semibold text-[#222222] mb-3">Ruangan yang Dipinjam <span class="text-red-500">*</span></label>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <label class="cursor-pointer relative">
                        <input type="radio" name="ruangan" class="peer sr-only" required>
                        <div class="p-5 rounded-[4px] border border-[#dadada] peer-checked:border-[#168940] peer-checked:bg-[#F0FDF4] hover:bg-[#F8FAFC] transition-all flex items-start gap-4">
                            <iconify-icon icon="flat-color-icons:video-projector" class="peer-checked:"></iconify-icon>
                            <div>
                                <h4 class="font-semibold text-[#222222] mb-1 m-0">Home Theater</h4>
                                <p class="font-serif text-[13px] text-[#666666] m-0">Lantai atas, fasilitas Proyektor, Sound System. Kapasitas 30 orang.</p>
                            </div>
                        </div>
                    </label>
                    
                    <label class="cursor-pointer relative">
                        <input type="radio" name="ruangan" class="peer sr-only">
                        <div class="p-5 rounded-[4px] border border-[#dadada] peer-checked:border-[#168940] peer-checked:bg-[#F0FDF4] hover:bg-[#F8FAFC] transition-all flex items-start gap-4">
                            <iconify-icon icon="flat-color-icons:collaboration" class="peer-checked:"></iconify-icon>
                            <div>
                                <h4 class="font-semibold text-[#222222] mb-1 m-0">Area Diskusi (Mesa Bundar)</h4>
                                <p class="font-serif text-[13px] text-[#666666] m-0">Lantai atas, area terbuka. Cocok untuk FGD skala kecil maks 15 orang.</p>
                            </div>
                        </div>
                    </label>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 pt-2">
                <!-- Tanggal -->
                <div>
                    <label class="block text-sm font-semibold text-[#222222] mb-2">Tanggal Penggunaan <span class="text-red-500">*</span></label>
                    <input type="date" class="w-full bg-[#F8FAFC] border border-[#dadada] text-[#444444] font-serif rounded-[4px] px-4 py-3 focus:outline-none focus:ring-[3px] focus:ring-[#EAB308]/30 focus:border-[#168940] transition-colors cursor-pointer" required>
                </div>

                <!-- Jam -->
                <div class="flex gap-4">
                    <div class="flex-1">
                        <label class="block text-sm font-semibold text-[#222222] mb-2">Jam Mulai</label>
                        <input type="time" class="w-full bg-[#F8FAFC] border border-[#dadada] text-[#444444] font-serif rounded-[4px] px-4 py-3 focus:outline-none focus:ring-[3px] focus:ring-[#EAB308]/30 focus:border-[#168940] transition-colors cursor-pointer" required>
                    </div>
                    <div class="flex-1">
                        <label class="block text-sm font-semibold text-[#222222] mb-2">Jam Selesai</label>
                        <input type="time" class="w-full bg-[#F8FAFC] border border-[#dadada] text-[#444444] font-serif rounded-[4px] px-4 py-3 focus:outline-none focus:ring-[3px] focus:ring-[#EAB308]/30 focus:border-[#168940] transition-colors cursor-pointer" required>
                    </div>
                </div>
            </div>

            <!-- Kegiatan -->
            <div class="pt-2">
                <label class="block text-sm font-semibold text-[#222222] mb-2">Nama / Deskripsi Kegiatan <span class="text-red-500">*</span></label>
                <textarea rows="3" placeholder="Contoh: Pemutaran film dokumenter sejarah islam kelas B..." class="w-full bg-[#F8FAFC] border border-[#dadada] text-[#444444] font-serif rounded-[4px] px-4 py-3 focus:outline-none focus:ring-[3px] focus:ring-[#EAB308]/30 focus:border-[#168940] transition-colors resize-none" required></textarea>
            </div>

            <!-- Submit -->
            <div class="pt-4 border-t border-[#dadada] flex justify-end">
                <button type="submit" class="w-full md:w-auto bg-[#168940] hover:bg-[#0B4226] text-white font-semibold py-3 px-8 rounded-[4px] transition-colors flex items-center justify-center gap-2 focus:outline-none focus:ring-[3px] focus:ring-[#EAB308]">
                    <iconify-icon icon="flat-color-icons:calendar" ></iconify-icon>
                    Ajukan Reservasi
                </button>
            </div>

        </form>
    </div>

</LayoutSidebar>
