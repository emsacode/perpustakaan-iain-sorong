---
import LayoutSidebar from '../layouts/LayoutSidebar.astro';

const sidebarMenu = {
    title: "Literasi & Publikasi",
    items: [
        {"label": "Kelas Literasi & HONAI", "href": "/literasi"}, 
        {"label": "Turnitin", "href": "/turnitin"}, 
        {"label": "Desiderata", "href": "/desiderata"}
    ]
};
---

<LayoutSidebar title="Layanan Turnitin" sidebarMenu={sidebarMenu}>
    
    <!-- Hero / Featured Banner -->
    <div class="bg-white border border-[#dadada] rounded-[8px] overflow-hidden mb-12 shadow-sm flex flex-col md:flex-row relative group hover:border-[#BBF7D0] transition-all">
        <!-- Decoration -->
        <div class="absolute right-0 top-0 w-32 h-32 bg-[#F0FDF4] rounded-bl-full opacity-50 z-0"></div>
        
        <!-- Thumbnail Cover -->
        <div class="w-full md:w-64 bg-[#F8FAFC] border-b md:border-b-0 md:border-r border-[#dadada] p-8 flex flex-col items-center justify-center shrink-0 relative z-10 group-hover:bg-[#F0FDF4] transition-colors">
            <div class="w-32 h-16 flex items-center justify-center mb-4 bg-white p-2 border border-[#dadada] rounded-[6px]">
                <img src="https://upload.wikimedia.org/wikipedia/commons/5/58/Turnitin_logo_%282021%29.svg" alt="Logo Turnitin" class="max-h-full max-w-full object-contain" />
            </div>
            <span class="text-xs font-bold text-[#168940] bg-[#F0FDF4] border border-[#168940]/20 px-2.5 py-1 rounded-full">Anti-Plagiarisme</span>
        </div>

        <!-- Meta text -->
        <div class="p-8 md:p-10 flex-1 relative z-10 font-sans">
            <div class="uppercase tracking-widest text-[10px] font-bold text-[#EAB308] mb-2">Layanan Publikasi & Tugas Akhir</div>
            <h2 class="text-2xl md:text-3xl font-semibold text-[#222222] mb-3 tracking-tight m-0">Pengecekan Plagiarisme Turnitin</h2>
            
            <p class="text-sm text-[#666666] leading-relaxed mb-6 font-serif">
                Perpustakaan IAIN Sorong memfasilitasi pengecekan orisinalitas naskah karya ilmiah (skripsi, tesis, disertasi, dan jurnal) bagi seluruh sivitas akademika menggunakan software Turnitin resmi.
            </p>
            
            <div class="flex items-center gap-4">
                <a href="https://wa.me/6282194132703" target="_blank" rel="noopener noreferrer" class="bg-[#168940] hover:bg-[#0B4226] text-white font-semibold py-3 px-6 rounded-[4px] shadow-sm transition-colors flex items-center gap-2 text-sm">
                    <iconify-icon icon="logos:whatsapp-icon" class="text-base"></iconify-icon>
                    Ajukan Cek Naskah
                </a>
            </div>
        </div>
    </div>

    <!-- Alert Box -->
    <div class="mb-12">
        <div class="font-serif text-[14px] text-[#2c5282] leading-relaxed border-l-4 border-blue-500 pl-5 bg-blue-50 p-5 rounded-r-[8px] flex gap-3 items-start">
            <iconify-icon icon="lucide:info" class="text-lg text-blue-600 shrink-0 mt-0.5"></iconify-icon>
            <div>
                <strong class="font-sans block mb-1">Ketentuan Ambang Batas (Treshold) Kelulusan Plagiarisme:</strong>
                Sesuai dengan regulasi akademik IAIN Sorong, batas maksimal persentase tingkat kemiripan (*similarity index*) untuk naskah tugas akhir mahasiswa adalah **20% - 25%** (kebijakan dapat bervariasi tergantung masing-masing fakultas/pascasarjana).
            </div>
        </div>
    </div>

    <!-- Alur Proses Turnitin -->
    <div class="bg-white border border-[#dadada] rounded-[8px] p-6 md:p-8 shadow-sm mb-12 font-sans">
        <h3 class="text-xl font-semibold text-[#222222] mb-6 tracking-tight border-b border-[#dadada] pb-4 m-0">Alur Pengajuan Cek Plagiarisme</h3>
        
        <div class="space-y-6 relative before:absolute before:left-[23px] before:top-2 before:bottom-2 before:w-[2px] before:bg-slate-100">
            
            <!-- Step 1 -->
            <div class="flex gap-4 items-start relative z-10">
                <div class="w-12 h-12 bg-[#F0FDF4] border border-[#dadada] rounded-full flex items-center justify-center shrink-0 text-[#168940] font-bold text-sm">
                    1
                </div>
                <div>
                    <h4 class="font-semibold text-slate-800 m-0 text-base">Persiapan Dokumen</h4>
                    <p class="text-sm text-slate-500 font-serif mt-1.5 leading-relaxed m-0">
                        Siapkan naskah Anda dalam format **PDF atau Word (.docx)**. Untuk proses pengecekan yang lebih cepat dan efisien, disarankan untuk memisahkan naskah dari bagian Cover, Kata Pengantar, Daftar Isi, dan Daftar Pustaka (cek hanya bagian Bab I s.d. Bab Kesimpulan).
                    </p>
                </div>
            </div>

            <!-- Step 2 -->
            <div class="flex gap-4 items-start relative z-10">
                <div class="w-12 h-12 bg-[#F0FDF4] border border-[#dadada] rounded-full flex items-center justify-center shrink-0 text-[#168940] font-bold text-sm">
                    2
                </div>
                <div>
                    <h4 class="font-semibold text-slate-800 m-0 text-base">Pengiriman File</h4>
                    <p class="text-sm text-slate-500 font-serif mt-1.5 leading-relaxed m-0">
                        Kirimkan berkas naskah Anda ke pustakawan melalui layanan **WhatsApp Ask A Librarian (0821-9413-2703)** atau via email resmi perpustakaan di **perpustakaan@iainsorong.ac.id** dengan menyertakan Nama Lengkap, NIM/NIP, Fakultas/Prodi, dan nomor WhatsApp aktif.
                    </p>
                </div>
            </div>

            <!-- Step 3 -->
            <div class="flex gap-4 items-start relative z-10">
                <div class="w-12 h-12 bg-[#F0FDF4] border border-[#dadada] rounded-full flex items-center justify-center shrink-0 text-[#168940] font-bold text-sm">
                    3
                </div>
                <div>
                    <h4 class="font-semibold text-slate-800 m-0 text-base">Proses Pengecekan oleh Pustakawan</h4>
                    <p class="text-sm text-slate-500 font-serif mt-1.5 leading-relaxed m-0">
                        Pustakawan akan memasukkan naskah Anda ke dalam repositori non-repository Turnitin (agar file naskah tidak tersimpan permanen di database pusat Turnitin dan tidak memicu plagiarisme internal saat dicek ulang di masa mendatang).
                    </p>
                </div>
            </div>

            <!-- Step 4 -->
            <div class="flex gap-4 items-start relative z-10">
                <div class="w-12 h-12 bg-[#F0FDF4] border border-[#dadada] rounded-full flex items-center justify-center shrink-0 text-[#168940] font-bold text-sm">
                    4
                </div>
                <div>
                    <h4 class="font-semibold text-slate-800 m-0 text-base">Penerimaan Hasil Laporan</h4>
                    <p class="text-sm text-slate-500 font-serif mt-1.5 leading-relaxed m-0">
                        Setelah proses pengecekan selesai (estimasi 15-30 menit tergantung antrean dan ukuran file), pustakawan akan mengirimkan berkas laporan orisinalitas dalam format PDF digital langsung ke WhatsApp atau email Anda.
                    </p>
                </div>
            </div>

        </div>
    </div>

    <!-- FAQ Turnitin -->
    <div class="bg-white border border-[#dadada] rounded-[8px] p-6 md:p-8 shadow-sm font-sans mb-12">
        <h3 class="text-xl font-semibold text-[#222222] mb-6 tracking-tight border-b border-[#dadada] pb-4 m-0">Pertanyaan Umum (FAQ) Layanan</h3>
        
        <div class="space-y-4 divide-y divide-gray-100">
            <!-- FAQ 1 -->
            <div class="pt-4 first:pt-0">
                <h4 class="font-semibold text-slate-800 text-[15px] m-0">Berapa biaya pengecekan Turnitin di Perpustakaan?</h4>
                <p class="text-sm text-slate-500 font-serif mt-2 leading-relaxed m-0">
                    Layanan pengecekan plagiarisme naskah Turnitin diberikan secara **gratis (tidak dipungut biaya)** untuk seluruh sivitas akademika IAIN Sorong yang memiliki keanggotaan perpustakaan aktif.
                </p>
            </div>
            
            <!-- FAQ 2 -->
            <div class="pt-4">
                <h4 class="font-semibold text-slate-800 text-[15px] m-0">Apakah naskah saya akan tersimpan permanen di server Turnitin?</h4>
                <p class="text-sm text-slate-500 font-serif mt-2 leading-relaxed m-0">
                    Tidak. Pustakawan memproses naskah menggunakan setelan **"No Repository"**. Naskah Anda tidak akan diindeks oleh Turnitin, sehingga Anda aman melakukan pengecekan berulang kali tanpa khawatir persentase similarity naik akibat naskah sendiri.
                </p>
            </div>

            <!-- FAQ 3 -->
            <div class="pt-4">
                <h4 class="font-semibold text-slate-800 text-[15px] m-0">Bagaimana jika naskah saya melebihi batas toleransi similarity?</h4>
                <p class="text-sm text-slate-500 font-serif mt-2 leading-relaxed m-0">
                    Laporan PDF yang kami kirimkan akan menyertakan highlight berwarna pada kalimat-kalimat yang dinilai mirip dengan sumber internet/jurnal lain. Anda disarankan melakukan parafrase (menulis ulang gagasan dengan kalimat Anda sendiri) pada bagian tersebut lalu mengajukan cek ulang kembali.
                </p>
            </div>
        </div>
    </div>

</LayoutSidebar>
