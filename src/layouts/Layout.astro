---
interface Props {
	title: string;
	description?: string;
}
import '../styles/global.css';
import ChatbotButton from '../components/ChatbotButton.astro';
import SearchModal from '../components/SearchModal.astro';
import FloatingWidget from '../components/FloatingWidget.astro';

const { title, description } = Astro.props;
const pageTitle = title ? `${title} | Perpustakaan IAIN Sorong` : 'Perpustakaan IAIN Sorong';
const pageDescription = description ?? 'Website resmi Perpustakaan IAIN Sorong untuk akses informasi layanan, koleksi, berita, statistik, dan sumber daya digital.';
---

<!doctype html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription}>
    <link rel="icon" type="image/png" href="/Logo/Logo_IAIN_Sorong.png" />
    <!-- Sienna Accessibility Widget -->
    <script is:inline src="https://cdn.jsdelivr.net/npm/sienna-accessibility/dist/sienna-accessibility.umd.js" defer></script>
    <script is:inline src="https://code.iconify.design/iconify-icon/1.0.7/iconify-icon.min.js"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="">
    <link href="https://fonts.googleapis.com/css2?family=Albert+Sans:wght@400;500;600;700&family=Plus+Jakarta+Sans:wght@500;600;700&display=swap" rel="stylesheet">
    
    <style is:global>
      body {
      font-family: 'Albert Sans', sans-serif;
      color: #0D1B12;
      background-color: #F7F7F2;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
      }
      .font-serif {
      font-family: 'Plus Jakarta Sans', sans-serif;
      }
      h1, h2, h3, h4, h5, h6 {
      font-family: 'Plus Jakarta Sans', sans-serif;
      }
      /* Custom scrollbar for a polished look */
      ::-webkit-scrollbar { width: 5px; height: 5px; }
      ::-webkit-scrollbar-track { background: #E8F5E9; }
      ::-webkit-scrollbar-thumb { background: #18BF5A; border-radius: 4px; }
      ::-webkit-scrollbar-thumb:hover { background: #118538; }
      /* Smooth scrolling */
      html { scroll-behavior: smooth; }

      /* Hide Default Sienna Widget Trigger */
      .asw-widget {
        display: none !important;
      }
    </style>
  </head>
  <body class="min-h-screen bg-surface text-dark font-sans antialiased">
    <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-[100] focus:rounded-full focus:bg-white focus:px-4 focus:py-2 focus:text-sm focus:font-semibold focus:text-[#168940] focus:shadow-lg">
      Lewati ke konten utama
    </a>

    <div class="relative isolate min-h-screen overflow-hidden">
      <div aria-hidden="true" class="pointer-events-none absolute inset-0 overflow-hidden">
        <div class="absolute -top-28 left-[-6rem] h-72 w-72 rounded-full bg-[#168940]/10 blur-3xl"></div>
        <div class="absolute right-[-5rem] top-24 h-80 w-80 rounded-full bg-[#BFA25A]/10 blur-3xl"></div>
        <div class="absolute bottom-0 left-1/2 h-56 w-[36rem] -translate-x-1/2 rounded-full bg-[#0D1B12]/5 blur-3xl"></div>
      </div>

      <div id="main-content" class="relative z-10">
        <slot />
      </div>
    </div>

    <ChatbotButton />
    <SearchModal />
    <FloatingWidget />
  </body>
</html>
