---
interface Props {
	title: string;
}
import '../styles/global.css';
import ChatbotButton from '../components/ChatbotButton.astro';
import SearchModal from '../components/SearchModal.astro';
import FloatingWidget from '../components/FloatingWidget.astro';

const { title } = Astro.props;
---

<!doctype html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Perpustakaan IAIN Sorong</title>
    <link rel="icon" type="image/png" href="/Logo/Logo_IAIN_Sorong.png" />
    <!-- Sienna Accessibility Widget -->
    <script is:inline src="https://cdn.jsdelivr.net/npm/sienna-accessibility/dist/sienna-accessibility.umd.js" defer></script>
    <script is:inline src="https://code.iconify.design/iconify-icon/1.0.7/iconify-icon.min.js"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="">
    <link href="https://fonts.googleapis.com/css2?family=Albert+Sans:wght@400;500;600;700&family=Plus+Jakarta+Sans:wght@500;600;700&display=swap" rel="stylesheet">
    
    <style is:global>
      body {
      font-family: 'Albert Sans', sans-serif;
      color: #0D1B12;
      background-color: #F7F7F2;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
      }
      .font-serif {
      font-family: 'Plus Jakarta Sans', sans-serif;
      }
      h1, h2, h3, h4, h5, h6 {
      font-family: 'Plus Jakarta Sans', sans-serif;
      }
      /* Custom scrollbar for a polished look */
      ::-webkit-scrollbar { width: 5px; height: 5px; }
      ::-webkit-scrollbar-track { background: #E8F5E9; }
      ::-webkit-scrollbar-thumb { background: #18BF5A; border-radius: 4px; }
      ::-webkit-scrollbar-thumb:hover { background: #118538; }
      /* Smooth scrolling */
      html { scroll-behavior: smooth; }

      /* Hide Default Sienna Widget Trigger */
      .asw-widget {
        display: none !important;
      }
    </style>
  </head>
  <body class="bg-surface text-dark font-sans antialiased">
    <slot />
    <ChatbotButton />
    <SearchModal />
    <FloatingWidget />
  </body>
</html>
