<script>
  function setupQACarousel() {
    const qaCarousel = document.getElementById('quick-access-carousel');
    const qaDot1 = document.getElementById('qa-dot-1');
    const qaDot2 = document.getElementById('qa-dot-2');
    
    if (qaCarousel && qaDot1 && qaDot2) {
      qaCarousel.addEventListener('scroll', () => {
        const scrollLeft = qaCarousel.scrollLeft;
        const width = qaCarousel.clientWidth;
        if (scrollLeft >= width / 2) {
          qaDot1.className = 'w-1.5 h-1.5 rounded-full bg-slate-300 transition-all duration-300';
          qaDot2.className = 'w-4 h-1.5 rounded-full bg-[#168940] transition-all duration-300';
        } else {
          qaDot2.className = 'w-1.5 h-1.5 rounded-full bg-slate-300 transition-all duration-300';
          qaDot1.className = 'w-4 h-1.5 rounded-full bg-[#168940] transition-all duration-300';
        }
      });
    }
  }

  // Setup on load
  setupQACarousel();
  // Setup on page navigation (Astro View Transitions support)
  document.addEventListener('astro:page-load', setupQACarousel);
</script>