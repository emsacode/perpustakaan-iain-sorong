---
---
<div id="announcement-popup-container" role="dialog" aria-modal="true" aria-labelledby="popup-title" class="fixed inset-0 z-[100] flex items-center justify-center p-4 bg-black/50 backdrop-blur-sm opacity-0 pointer-events-none transition-opacity duration-300">
  <div class="relative w-full max-w-lg bg-white rounded-2xl shadow-2xl border border-slate-200 overflow-hidden transform scale-95 transition-transform duration-300 flex flex-col max-h-[90vh]">
    
    <!-- Top Header Pattern -->
    <div class="relative bg-gradient-to-r from-[#062E19] to-[#168940] p-6 text-white shrink-0">
      <div class="absolute right-0 top-0 w-24 h-24 bg-white/5 rounded-bl-full pointer-events-none"></div>
      <button id="close-popup-header-btn" class="absolute top-4 right-4 text-white/80 hover:text-white bg-white/10 hover:bg-white/20 p-1.5 rounded-full transition-colors focus:outline-none" aria-label="Tutup Pop-up">
        <iconify-icon icon="lucide:x" class="text-lg block"></iconify-icon>
      </button>
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 bg-white/10 rounded-xl flex items-center justify-center text-accent">
          <iconify-icon icon="lucide:megaphone" class="text-2xl text-[#EAB308]"></iconify-icon>
        </div>
        <div>
          <h3 id="popup-title" class="text-lg font-bold tracking-tight m-0">Informasi & Layanan</h3>
          <p class="text-xs text-[#BBF7D0]/80 font-serif m-0 mt-0.5">Perpustakaan IAIN Sorong</p>
        </div>
      </div>
    </div>

    <!-- Navigation Tabs -->
    <div class="flex border-b border-slate-200 bg-slate-50 text-sm font-semibold text-[#444444] shrink-0">
      <button data-tab="penting" class="popup-tab-btn flex-1 py-3 px-2 text-center border-b-2 border-transparent transition-all hover:bg-slate-100/50 hover:text-[#168940] outline-none">
        Info Penting
      </button>
      <button data-tab="survei" class="popup-tab-btn flex-1 py-3 px-2 text-center border-b-2 border-transparent transition-all hover:bg-slate-100/50 hover:text-[#168940] outline-none">
        Survei IKM
      </button>
      <button data-tab="layanan" class="popup-tab-btn flex-1 py-3 px-2 text-center border-b-2 border-transparent transition-all hover:bg-slate-100/50 hover:text-[#168940] outline-none">
        Layanan
      </button>
    </div>

    <!-- Tab Contents (Scrollable if tall) -->
    <div class="p-6 overflow-y-auto flex-1 font-sans">
      
      <!-- Tab CONTENT 1: Info Penting -->
      <div id="popup-content-penting" class="popup-tab-content hidden space-y-4">
        <div class="bg-amber-50 border border-amber-200 rounded-lg p-3 text-amber-800 text-xs font-medium flex gap-2">
          <iconify-icon icon="lucide:calendar-clock" class="text-base shrink-0 mt-0.5"></iconify-icon>
          <span><strong>Informasi Libur:</strong> Perpustakaan akan menyesuaikan jadwal operasional pada Hari Libur Nasional dan Cuti Bersama.</span>
        </div>

        <div class="flex gap-3 items-start pt-2">
          <div class="w-8 h-8 rounded-lg bg-indigo-50 text-indigo-600 flex items-center justify-center shrink-0">
            <iconify-icon icon="lucide:party-popper" class="text-lg"></iconify-icon>
          </div>
          <div>
            <h4 class="font-bold text-slate-800 text-[14px] m-0">Event Bedah Buku & Literasi</h4>
            <p class="text-xs text-slate-500 font-serif mt-1.5 leading-relaxed m-0">
              Jangan lewatkan kegiatan bedah buku dan workshop literasi informasi yang rutin diadakan. Ikuti media sosial kami untuk update pendaftaran.
            </p>
            <a href="/berita" class="inline-flex items-center gap-1 text-[11px] font-bold text-[#168940] hover:text-[#0B4226] mt-2 group">
              Lihat Kabar Pustaka <iconify-icon icon="lucide:chevron-right" class="group-hover:translate-x-0.5 transition-transform"></iconify-icon>
            </a>
          </div>
        </div>
      </div>

      <!-- Tab CONTENT 3: Layanan -->
      <div id="popup-content-layanan" class="popup-tab-content hidden space-y-4">
        <div class="bg-blue-50 border border-blue-200 rounded-lg p-3 text-blue-800 text-xs font-medium flex gap-2">
          <iconify-icon icon="lucide:info" class="text-base shrink-0 mt-0.5"></iconify-icon>
          <span>Maksimal peminjaman buku cetak adalah <strong>3 eksemplar</strong> dengan batas waktu peminjaman selama <strong>7 hari kalender</strong>.</span>
        </div>

        <div class="flex gap-3.5 items-start pt-2">
          <div class="w-8 h-8 rounded-lg bg-red-50 text-red-600 flex items-center justify-center shrink-0">
            <iconify-icon icon="lucide:shield-check" class="text-lg"></iconify-icon>
          </div>
          <div>
            <h4 class="font-bold text-slate-800 text-[14px] m-0">Cek Plagiarisme Turnitin</h4>
            <p class="text-xs text-slate-500 font-serif mt-1.5 leading-relaxed m-0">
              Kini pengecekan orisinalitas naskah skripsi dengan software Turnitin resmi dapat diajukan secara gratis melalui Pustakawan.
            </p>
            <a href="/turnitin" class="inline-flex items-center gap-1 text-[11px] font-bold text-[#168940] hover:text-[#0B4226] mt-2 group">
              Panduan Turnitin <iconify-icon icon="lucide:chevron-right" class="group-hover:translate-x-0.5 transition-transform"></iconify-icon>
            </a>
          </div>
        </div>
        
        <div class="flex gap-3.5 items-start border-t border-slate-100 pt-4">
          <div class="w-8 h-8 rounded-lg bg-green-50 text-green-600 flex items-center justify-center shrink-0">
            <iconify-icon icon="lucide:file-check" class="text-lg"></iconify-icon>
          </div>
          <div>
            <h4 class="font-bold text-slate-800 text-[14px] m-0">Bebas Pustaka Wisuda</h4>
            <p class="text-xs text-slate-500 font-serif mt-1.5 leading-relaxed m-0">
              Bagi mahasiswa semester akhir yang akan Wisuda, pastikan Anda telah menyelesaikan administrasi pengembalian koleksi secara digital.
            </p>
            <a href="/bebas-pustaka" class="inline-flex items-center gap-1 text-[11px] font-bold text-[#168940] hover:text-[#0B4226] mt-2 group">
              Alur Pengajuan <iconify-icon icon="lucide:chevron-right" class="group-hover:translate-x-0.5 transition-transform"></iconify-icon>
            </a>
          </div>
        </div>
      </div>

      <!-- Tab CONTENT 3: Survei IKM -->
      <div id="popup-content-survei" class="popup-tab-content hidden flex flex-col items-center text-center py-4">
        <div class="w-16 h-16 bg-[#F0FDF4] rounded-full flex items-center justify-center text-[#168940] mb-4 border border-[#BBF7D0]">
          <iconify-icon icon="flat-color-icons:survey" class="text-4xl"></iconify-icon>
        </div>
        <h4 class="font-bold text-slate-800 text-[16px] mb-2 m-0">Bantu Kami Meningkatkan Kualitas Layanan</h4>
        <p class="text-xs text-slate-500 font-serif max-w-sm leading-relaxed mb-6 m-0">
          Umpan balik Anda sangat berarti. Pengisian Survei Indeks Kepuasan Masyarakat (IKM) hanya memakan waktu sekitar 3 menit dan membantu kami berbenah ke arah yang lebih baik.
        </p>
        <a href="/survei" class="w-full py-2.5 bg-[#168940] hover:bg-[#0B4226] text-white font-semibold rounded-md shadow-sm transition-colors text-xs inline-flex items-center justify-center gap-2">
          <iconify-icon icon="lucide:form-input" class="text-base"></iconify-icon>
          Isi Survei IKM Sekarang
        </a>
      </div>

    </div>

    <!-- Footer Controls -->
    <div class="px-6 py-4 bg-slate-50 border-t border-slate-200 flex items-center justify-between shrink-0 font-sans text-xs">
      <label class="flex items-center gap-2 text-slate-500 font-medium cursor-pointer">
        <input type="checkbox" id="dont-show-today-checkbox" class="w-3.5 h-3.5 text-[#168940] border-slate-300 rounded focus:ring-[#168940] cursor-pointer" />
        <span>Jangan tampilkan lagi hari ini</span>
      </label>
      <button id="close-popup-btn" class="bg-white hover:bg-slate-100 text-slate-700 font-semibold py-1.5 px-4 border border-slate-300 rounded-md transition-colors focus:outline-none">
        Tutup
      </button>
    </div>

  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const container = document.getElementById('announcement-popup-container');
    const modal = container?.firstElementChild;
    const closeHeaderBtn = document.getElementById('close-popup-header-btn');
    const closeFooterBtn = document.getElementById('close-popup-btn');
    const checkbox = document.getElementById('dont-show-today-checkbox') as HTMLInputElement | null;
    const tabs = document.querySelectorAll('.popup-tab-btn');
    const contents = document.querySelectorAll('.popup-tab-content');

    if (!container || !modal) return;

    // Helper: Tab switcher
    const switchTab = (tabName: string) => {
      tabs.forEach(tab => {
        const isCurrent = tab.getAttribute('data-tab') === tabName;
        if (isCurrent) {
          tab.classList.add('border-[#168940]', 'text-[#168940]', 'bg-white');
          tab.classList.remove('border-transparent', 'text-[#444444]');
        } else {
          tab.classList.remove('border-[#168940]', 'text-[#168940]', 'bg-white');
          tab.classList.add('border-transparent', 'text-[#444444]');
        }
      });

      contents.forEach(content => {
        if (content.id === `popup-content-${tabName}`) {
          content.classList.remove('hidden');
        } else {
          content.classList.add('hidden');
        }
      });
    };

    // Initialize tabs - show 'penting' by default
    switchTab('penting');

    // Add Tab click listeners
    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        const tabName = tab.getAttribute('data-tab');
        if (tabName) switchTab(tabName);
      });
    });

    // Close Modal Logic
    const closeModal = () => {
      // If checkbox is checked, set a timestamp in localStorage
      if (checkbox && checkbox.checked) {
        const midnight = new Date();
        midnight.setHours(23, 59, 59, 999);
        localStorage.setItem('announcement_popup_dismissed_until', midnight.getTime().toString());
      }
      
      // Animations out
      container.classList.remove('opacity-100', 'pointer-events-auto');
      container.classList.add('opacity-0', 'pointer-events-none');
      modal.classList.remove('scale-100');
      modal.classList.add('scale-95');
      
      // Completely hide after animation
      setTimeout(() => {
        container.style.display = 'none';
      }, 300);
    };

    // Close on buttons
    closeHeaderBtn?.addEventListener('click', closeModal);
    closeFooterBtn?.addEventListener('click', closeModal);

    // Close on background click
    container.addEventListener('click', (e) => {
      if (e.target === container) closeModal();
    });

    // Close on Escape key press
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !container.classList.contains('pointer-events-none')) {
        closeModal();
      }
    });

    // Check if dismissed previously
    const checkDismissed = () => {
      const dismissedUntil = localStorage.getItem('announcement_popup_dismissed_until');
      if (dismissedUntil) {
        const now = new Date().getTime();
        if (now < parseInt(dismissedUntil, 10)) {
          return true; // Still active
        } else {
          localStorage.removeItem('announcement_popup_dismissed_until'); // Expired
        }
      }
      return false;
    };

    // Show modal after 1.5 seconds if not dismissed
    if (!checkDismissed()) {
      setTimeout(() => {
        container.style.display = ''; // Reset display in case of view transitions
        container.classList.remove('opacity-0', 'pointer-events-none');
        container.classList.add('opacity-100', 'pointer-events-auto');
        modal.classList.remove('scale-95');
        modal.classList.add('scale-100');
      }, 1500);
    }
  });
</script>
