---
import catalogData from '../data/catalog.json';

// Helper to convert text to Title Case
function toTitleCase(str) {
  if (!str) return '';
  return str
    .toLowerCase()
    .split(' ')
    .map(word => word.charAt(0).toUpperCase() + word.slice(1))
    .join(' ');
}

// Filter Buku Cetak from SLiMS OPAC
const rawBooks = catalogData
  .filter(item => item.id.startsWith('opac-'))
  // Sort by biblio ID numeric value in descending order to get the latest
  .sort((a, b) => {
    const idA = parseInt(a.id.replace('opac-', ''), 10) || 0;
    const idB = parseInt(b.id.replace('opac-', ''), 10) || 0;
    return idB - idA;
  })
  .slice(0, 8);

// Fetch covers in parallel at build time
const books = await Promise.all(
  rawBooks.map(async (item) => {
    const biblioId = item.id.replace('opac-', '');
    let coverUrl = null;
    try {
      const url = `https://opac.iainsorong.ac.id/index.php?p=show_detail&id=${biblioId}`;
      const res = await fetch(url);
      if (res.ok) {
        const html = await res.text();
        // Extract cover filename
        const match = html.match(/createthumb\.php\?filename=images\/docs\/[^&"']+/);
        if (match) {
          coverUrl = `https://opac.iainsorong.ac.id/lib/minigalnano/${match[0]}&width=200`;
        }
      }
    } catch (e) {
      console.error(`Failed to fetch cover for ${item.id}:`, e);
    }

    return {
      id: item.id,
      title: toTitleCase(item.title),
      creator: toTitleCase(item.authors?.[0]?.name || 'Anonim'),
      publisher: toTitleCase(item.publisher || 'Tidak diketahui'),
      date: item.year || 'N/A',
      url: `/koleksi/katalog/${item.id}`,
      coverUrl
    };
  })
);

const errorMsg = books.length === 0 ? "Tidak ada koleksi terbaru yang tersedia." : null;
---

<section class="py-12 bg-[#F9FAFB] border-t border-[#dadada]">
  <div class="max-w-[1280px] mx-auto px-4 sm:px-6 lg:px-8">
    
    <div class="flex flex-col md:flex-row md:items-end justify-between mb-8 gap-4">
      <div>
        <h2 class="text-2xl md:text-3xl font-serif font-bold text-dark mb-2">Koleksi Terbaru</h2>
        <p class="text-sm font-sans text-[#718096]">Tambahan literatur mutakhir di Perpustakaan IAIN Sorong.</p>
      </div>
      
      <div class="flex items-center gap-4">
        <!-- Navigation Arrows (Desktop) -->
        <div class="hidden lg:flex items-center gap-2">
          <button onclick="document.getElementById('koleksi-carousel').scrollBy({left: -320, behavior: 'smooth'})" class="w-10 h-10 rounded-full border border-[#dadada] flex items-center justify-center text-dark hover:bg-primary hover:text-white hover:border-primary transition-all" aria-label="Geser Kiri">
            <iconify-icon icon="lucide:chevron-left"></iconify-icon>
          </button>
          <button onclick="document.getElementById('koleksi-carousel').scrollBy({left: 320, behavior: 'smooth'})" class="w-10 h-10 rounded-full border border-[#dadada] flex items-center justify-center text-dark hover:bg-primary hover:text-white hover:border-primary transition-all" aria-label="Geser Kanan">
            <iconify-icon icon="lucide:chevron-right"></iconify-icon>
          </button>
        </div>

        <a href="/koleksi/katalog" class="flex items-center gap-1 text-[13px] font-sans font-bold text-[#168940] hover:text-[#0B4226] transition-colors border border-[#168940] px-4 py-2 rounded-[6px] hover:bg-emerald-50 whitespace-nowrap">
          Semua Katalog <iconify-icon icon="lucide:arrow-right"></iconify-icon>
        </a>
      </div>
    </div>

    {errorMsg ? (
      <div class="bg-red-50 text-red-600 p-4 rounded-[8px] text-sm font-sans text-center border border-red-100">
        <iconify-icon icon="lucide:alert-circle" class="text-lg mb-1"></iconify-icon>
        <p>{errorMsg}</p>
      </div>
    ) : (
      <div id="koleksi-carousel" class="flex gap-4 overflow-x-auto snap-x snap-mandatory pb-6 px-1 [&::-webkit-scrollbar]:hidden [-ms-overflow-style:none] [scrollbar-width:none]">
        {books.map((book) => (
          <div class="w-[170px] md:w-[190px] shrink-0 snap-start bg-white rounded-[8px] border border-[#dadada] overflow-hidden hover:border-[#168940] hover:shadow-[0_4px_20px_rgba(17,133,59,0.08)] transition-all duration-300 group flex flex-col relative">
            
            {/* Book Cover Image or Fallback */}
            <div class="aspect-[3/4] relative overflow-hidden flex flex-col items-center justify-center text-center border-b-[3px] border-[#D69E2E] bg-[#0F291E] shrink-0">
              {book.coverUrl ? (
                <img src={book.coverUrl} alt={book.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
              ) : (
                <>
                  <div class="absolute inset-0 opacity-5 bg-[linear-gradient(45deg,transparent_25%,#ffffff_25%,#ffffff_50%,transparent_50%,transparent_75%,#ffffff_75%,#ffffff_100%)] bg-[length:10px_10px]"></div>
                  <iconify-icon icon="lucide:book-open" class="text-[#D69E2E] text-3xl mb-3 z-10"></iconify-icon>
                  <h3 class="text-white font-serif font-bold text-[11px] leading-snug line-clamp-4 z-10 px-2">{book.title}</h3>
                </>
              )}
            </div>

            {/* Book Details */}
            <div class="p-4 flex-1 flex flex-col font-sans">
              <div class="flex-1">
                <div class="text-[10px] font-semibold text-[#168940] mb-0.5 flex items-center gap-1 line-clamp-1">
                  <iconify-icon icon="lucide:pen-tool" class="text-[11px]"></iconify-icon> {book.creator}
                </div>
                <h3 class="text-slate-800 font-bold text-[12px] md:text-[13px] leading-snug mb-2 group-hover:text-[#168940] transition-colors line-clamp-2" title={book.title}>
                  <a href={book.url} class="before:absolute before:inset-0">
                    {book.title}
                  </a>
                </h3>
              </div>
              
              <div class="pt-2.5 mt-auto border-t border-gray-100 flex items-center justify-between text-[10px] md:text-[11px] text-[#718096]">
                <span class="flex items-center gap-1" title="Penerbit">
                  <iconify-icon icon="lucide:building"></iconify-icon> <span class="line-clamp-1 max-w-[90px]">{book.publisher}</span>
                </span>
                <span class="flex items-center gap-1 font-semibold text-slate-800 bg-[#F7F7F2] px-1.5 py-0.5 rounded-[3px]">
                  {book.date}
                </span>
              </div>
            </div>

          </div>
        ))}
      </div>
    )}

  </div>
</section>
