---
let sortedBerita = [];
try {
  const apiBase = import.meta.env.PUBLIC_API_URL || 'http://localhost:8000';
  const apiUrl = `${apiBase}/api/v1/berita`;
  const response = await fetch(apiUrl);
  if (response.ok) {
    const jsonResponse = await response.json();
    // Gunakan data dari struktur paginasi Laravel (.data)
    const allBerita = jsonResponse.data || [];
    sortedBerita = allBerita
      .sort((a: any, b: any) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
      .slice(0, 3);
  } else {
    console.error(`Failed to fetch articles: ${response.statusText}`);
  }
} catch (error) {
  console.error("Error fetching articles from API, using fallback empty array:", error);
}
---
<section id="berita" class="py-16 bg-white border-b border-[#dadada]">
  <div class="max-w-[1280px] mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col md:flex-row md:justify-between md:items-end mb-8 gap-4">
      <div>
        <h2 class="text-2xl lg:text-3xl tracking-tight font-semibold text-[#222222]">
          Berita Terbaru
        </h2>
        <p class="font-serif text-base text-[#666666] mt-2">
          Informasi terkini seputar kegiatan dan layanan Perpustakaan IAIN Sorong.
        </p>
      </div>
      <a href="/berita" class="hidden md:flex items-center gap-1 text-sm font-semibold text-[#168940] hover:text-[#0B4226] transition-colors focus-visible:ring-[3px] focus-visible:ring-[#EAB308] rounded-sm outline-none shrink-0">
        Lihat Semua Berita
        <iconify-icon icon="lucide:chevron-right" class="text-[#DD6B20]" width="1.2rem"></iconify-icon>
      </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {sortedBerita.map((item) => (
        <div class="bg-white border border-[#dadada] rounded-[8px] overflow-hidden group hover:border-[#BBF7D0] hover:shadow-md transition-all duration-200 flex flex-col">
          <div class="aspect-video bg-[#F0FDF4] relative overflow-hidden border-b border-[#dadada]">
            <a href={`/berita/${item.slug}`} class="block w-full h-full">
              <img src={item.data.image} alt={item.data.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy">
            </a>
          </div>
          <div class="p-5 flex flex-col flex-grow">
            <span class="text-[10px] font-bold text-[#168940] uppercase tracking-wider mb-2 block">
              {item.data.date}
            </span>
            <h4 class="text-base font-semibold text-[#222222] leading-snug line-clamp-2 mb-2 group-hover:text-[#168940] transition-colors">
              <a href={`/berita/${item.slug}`} class="hover:underline">
                {item.data.title}
              </a>
            </h4>
            <p class="text-sm text-[#444444] font-serif mb-4 line-clamp-3">
              {item.data.description}
            </p>
            <div class="mt-auto pt-4 border-t border-[#dadada]">
              <a href={`/berita/${item.slug}`} class="text-xs font-semibold text-[#168940] flex items-center gap-1 hover:text-[#0B4226] transition-colors w-max">
                Baca Selengkapnya
                <iconify-icon icon="lucide:chevron-right" class="text-[#3182CE]"></iconify-icon>
              </a>
            </div>
          </div>
        </div>
      ))}
    </div>

    <div class="mt-8 flex justify-center md:hidden">
      <a href="/berita" class="inline-flex items-center gap-2 text-sm font-semibold text-[#168940] border border-[#dadada] px-6 py-2.5 rounded-[4px] hover:border-[#EAB308] transition-colors focus-visible:ring-[3px] focus-visible:ring-[#EAB308] outline-none bg-white">
        Lihat Semua Berita
        <iconify-icon icon="lucide:chevron-right" class="text-[#D69E2E]"></iconify-icon>
      </a>
    </div>
  </div>
</section>