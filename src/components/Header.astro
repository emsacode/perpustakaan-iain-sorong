---
---
    <header class="sticky top-0 z-50 border-b border-slate-200/80 bg-white/85 backdrop-blur-xl">
      <div class="section-shell h-16 flex items-center justify-between">
        <a href="/" class="flex items-center gap-2 focus-visible:ring-[3px] focus-visible:ring-[#EAB308] rounded-[4px] outline-none">
          <img src="/Logo/Logo_IAIN_Sorong.png" alt="Logo IAIN Sorong" class="h-10 w-auto object-contain" />
          <span class="text-xl tracking-tight font-semibold text-[#0B4226] uppercase">
            Perpustakaan
            <span class="text-[#168940] font-medium">IAIN Sorong</span>
          </span>
        </a>

        <nav class="hidden md:flex items-center gap-6 h-full">
          <a href="/" class="h-full flex items-center text-sm font-semibold text-[#222222] hover:text-[#168940] transition-colors focus-visible:ring-[3px] focus-visible:ring-[#EAB308] outline-none">
            Beranda
          </a>

          <div class="group h-full flex items-center">
            <button class="h-full flex items-center gap-1 text-sm font-semibold text-[#222222] group-hover:text-[#168940] transition-colors focus-visible:ring-[3px] focus-visible:ring-[#EAB308] outline-none">
              Tentang Kami
              <iconify-icon icon="lucide:chevron-down" class="text-[#38A169]"></iconify-icon>
            </button>
            <div class="absolute left-0 top-full w-full bg-white border-b border-[#dadada] shadow-lg opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 ease-out z-50">
              <div class="max-w-[1280px] mx-auto px-4 sm:px-6 lg:px-8 py-10">
                <div class="grid grid-cols-12 gap-10">
                  <div class="col-span-3">
                    <h4 class="text-sm font-bold text-[#0B4226] uppercase tracking-wider mb-4">
                      Profil Singkat
                    </h4>
                    <ul class="space-y-3 font-serif">
                      <li>
                        <a href="/profil" class="text-sm text-[#444444] hover:text-[#168940]">
                          Profil Singkat
                        </a>
                      </li>
                      <li>
                        <a href="/visi-misi" class="text-sm text-[#444444] hover:text-[#168940]">
                          Visi &amp; Misi
                        </a>
                      </li>
                      <li>
                        <a href="/struktur" class="text-sm text-[#444444] hover:text-[#168940]">
                          Struktur Organisasi
                        </a>
                      </li>
                      <li>
                        <a href="/jam-layanan" class="text-sm text-[#444444] hover:text-[#168940]">
                          Jam Buka Layanan
                        </a>
                      </li>
                      <li>
                        <a href="/statistik" class="text-sm text-[#444444] hover:text-[#168940] font-semibold text-[#168940]">
                          Statistik Perpustakaan
                        </a>
                      </li>
                    </ul>
                  </div>
                  <div class="col-span-3">
                    <h4 class="text-sm font-bold text-[#0B4226] uppercase tracking-wider mb-4">
                      Layanan &amp; Aturan
                    </h4>
                    <ul class="space-y-3 font-serif">
                      <li>
                        <a href="/tata-tertib" class="text-sm text-[#444444] hover:text-[#168940]">
                          Tata Tertib Pemustaka
                        </a>
                      </li>
                      <li>
                        <a href="/panduan-ruangan" class="text-sm text-[#444444] hover:text-[#168940]">
                          Panduan Ruangan Gedung
                        </a>
                      </li>
                      <li>
                        <a href="/kontak" class="text-sm text-[#444444] hover:text-[#168940]">
                          Kontak &amp; Lokasi
                        </a>
                      </li>
                      <li>
                        <a href="/survei" class="text-sm text-[#444444] hover:text-[#168940]">
                          Survei Kepuasan (IKM)
                        </a>
                      </li>
                      <li>
                        <a href="/bebas-pustaka" class="text-sm text-[#444444] hover:text-[#168940]">
                          Bebas Pustaka
                        </a>
                      </li>
                      <li>
                        <a href="/faq" class="text-sm text-[#444444] hover:text-[#168940] font-semibold text-[#168940]">
                          FAQ &amp; Panduan
                        </a>
                      </li>
                    </ul>
                  </div>
                  <div class="col-span-6 border-l border-[#dadada] pl-8">
                    <div class="bg-[#F0FDF4] rounded-[8px] p-6 h-full flex flex-col justify-center relative overflow-hidden group/card border border-[#dadada]">
                      <img src="https://images.unsplash.com/photo-1541339907198-e08756dedf3f?q=80&amp;w=800&amp;auto=format&amp;fit=crop" class="absolute inset-0 w-full h-full object-cover opacity-20 group-hover/card:scale-105 transition-transform duration-500" alt="Gedung Baru">
                      <div class="relative z-10">
                        <h4 class="text-lg font-semibold text-[#0B4226] mb-2 tracking-tight">
                          Gedung Baru Perpustakaan
                        </h4>
                        <p class="text-sm text-[#444444] font-serif mb-4 leading-relaxed">
                          Jelajahi fasilitas modern dan nyaman di gedung
                          perpustakaan IAIN Sorong yang baru.
                        </p>
                        <a href="/galeri" class="inline-flex items-center gap-2 text-sm font-semibold text-[#168940] hover:text-[#0B4226]">
                          Lihat Galeri
                          <iconify-icon icon="lucide:chevron-right" class="text-[#D69E2E]"></iconify-icon>
                        </a>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <div class="group h-full flex items-center">
            <button class="h-full flex items-center gap-1 text-sm font-semibold text-[#222222] group-hover:text-[#168940] transition-colors focus-visible:ring-[3px] focus-visible:ring-[#EAB308] outline-none">
              Layanan Digital
              <iconify-icon icon="lucide:chevron-down" class="text-[#E53E3E]"></iconify-icon>
            </button>
            <div class="absolute left-0 top-full w-full bg-white border-b border-[#dadada] shadow-lg opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 ease-out z-50">
              <div class="max-w-[1280px] mx-auto px-4 sm:px-6 lg:px-8 py-10">
                <div class="grid grid-cols-12 gap-10">
                  <div class="col-span-3">
                    <h4 class="text-sm font-bold text-[#0B4226] uppercase tracking-wider mb-4">
                      Akses Koleksi
                    </h4>
                    <ul class="space-y-3 font-serif">
                      <li>
                        <a href="/koleksi/katalog" class="text-sm text-[#444444] hover:text-[#168940] font-semibold text-[#168940]">
                          Katalog Terpadu (Internal)
                        </a>
                      </li>
                      <li>
                        <a href="/koleksi/scopus" class="text-sm text-[#444444] hover:text-[#168940]">
                          Rujukan Jurnal Scopus (Internasional)
                        </a>
                      </li>
                      <li>
                        <a href="/koleksi/sinta" class="text-sm text-[#444444] hover:text-[#168940]">
                          Rujukan Jurnal Sinta (Nasional)
                        </a>
                      </li>
                      <li>
                        <a href="/koleksi/e-resources" class="text-sm text-[#444444] hover:text-[#168940]">
                          Database &amp; E-Resource
                        </a>
                      </li>
                    </ul>
                  </div>
                  <div class="col-span-3">
                    <h4 class="text-sm font-bold text-[#0B4226] uppercase tracking-wider mb-4">
                      Koleksi Internal
                    </h4>
                    <ul class="space-y-3 font-serif">
                      <li>
                        <a href="https://web-sorongpustaka.moco.co.id/book/0e0acb94-4855-498e-a8d3-6f753829ec77/f2b0efdb-7c91-4db1-99db-e0022869667d" target="_blank" rel="noopener noreferrer" class="text-sm text-[#444444] hover:text-[#168940]">
                          SORPUS (Sorong Pustaka)
                        </a>
                      </li>
                      <li>
                        <a href="http://opac.iainsorong.ac.id" target="_blank" rel="noopener noreferrer" class="text-sm text-[#444444] hover:text-[#168940]">
                          OPAC Katalog
                        </a>
                      </li>
                      <li>
                        <a href="/peminjaman" class="text-sm text-[#444444] hover:text-[#168940]">
                          Alur Peminjaman
                        </a>
                      </li>
                      <li>
                        <a href="https://opac.iainsorong.ac.id/index.php?p=member" target="_blank" rel="noopener noreferrer" class="text-sm text-[#444444] hover:text-[#168940]">
                          K-Online (Keanggotaan)
                        </a>
                      </li>
                      <li>
                        <a href="https://e-jurnal.iainsorong.ac.id/" target="_blank" rel="noopener noreferrer" class="text-sm text-[#444444] hover:text-[#168940]">
                          Rumah Jurnal
                        </a>
                      </li>
                      <li>
                        <a href="https://repositori.iainsorong.ac.id/" target="_blank" rel="noopener noreferrer" class="text-sm text-[#444444] hover:text-[#168940]">
                          Repository Ilmiah
                        </a>
                      </li>
                      <li>
                        <a href="/iainsorong-press" class="text-sm text-[#444444] hover:text-[#168940]">
                          IAINSORONG Press
                        </a>
                      </li>
                    </ul>
                  </div>
                  <div class="col-span-6 border-l border-[#dadada] pl-8">
                    <div class="bg-[#0B4226] rounded-[8px] p-6 h-full flex items-center gap-6 relative overflow-hidden text-white border border-[#168940]">
                      <div class="flex-1 relative z-10">
                        <h4 class="text-lg font-semibold mb-2 tracking-tight">
                          Unduh Aplikasi SORPUS
                        </h4>
                        <p class="text-sm text-[#BBF7D0] font-serif mb-5 leading-relaxed">
                          Akses layanan perpustakaan digital lebih mudah
                          langsung dari perangkat genggam Anda.
                        </p>
                        <div class="flex gap-3">
                          <a href="https://play.google.com/store/apps/details?id=mam.reader.sorongpustaka&hl=id" target="_blank" rel="noopener noreferrer" class="px-4 py-2 bg-white text-[#0B4226] text-xs font-semibold rounded-[4px] flex items-center gap-2 hover:bg-[#F0FDF4] transition-colors">
                            <iconify-icon icon="logos:google-play-icon" width="1.2rem"></iconify-icon>
                            Play Store
                          </a>
                        </div>
                      </div>
                      <iconify-icon icon="lucide:smartphone" class="text-[#38A169] /10 absolute -right-2 -bottom-2 transform -rotate-12"></iconify-icon>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <div class="group h-full flex items-center">
            <button class="h-full flex items-center gap-1 text-sm font-semibold text-[#222222] group-hover:text-[#168940] transition-colors focus-visible:ring-[3px] focus-visible:ring-[#EAB308] outline-none">
              Fasilitas
              <iconify-icon icon="lucide:chevron-down" class="text-[#D69E2E]"></iconify-icon>
            </button>
            <div class="absolute left-0 top-full w-full bg-white border-b border-[#dadada] shadow-lg opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 ease-out z-50">
              <div class="max-w-[1280px] mx-auto px-4 sm:px-6 lg:px-8 py-10">
                <div class="grid grid-cols-12 gap-10">
                  <div class="col-span-3">
                    <h4 class="text-sm font-bold text-[#0B4226] uppercase tracking-wider mb-4">
                      Lantai 1
                    </h4>
                    <ul class="space-y-3 font-serif">
                      <li>
                        <a href="/fasilitas/lantai-1" class="text-sm text-[#444444] hover:text-[#168940]">
                          Ruang Loker &amp; Laktasi
                        </a>
                      </li>
                      <li>
                        <a href="/fasilitas/lantai-1" class="text-sm text-[#444444] hover:text-[#168940]">
                          Pojok Baca &amp; Musala
                        </a>
                      </li>
                      <li>
                        <a href="/fasilitas/lantai-1" class="text-sm text-[#444444] hover:text-[#168940]">
                          Ruang Multimedia
                        </a>
                      </li>
                    </ul>
                  </div>
                  <div class="col-span-3">
                    <h4 class="text-sm font-bold text-[#0B4226] uppercase tracking-wider mb-4">
                      Lantai Atas
                    </h4>
                    <ul class="space-y-3 font-serif">
                      <li>
                        <a href="/fasilitas/lantai-atas" class="text-sm text-[#444444] hover:text-[#168940]">
                          Ruang Home Theater
                        </a>
                      </li>
                      <li>
                        <a href="/fasilitas/lantai-atas" class="text-sm text-[#444444] hover:text-[#168940]">
                          Ruang Referensi &amp; Kitab
                        </a>
                      </li>
                      <li>
                        <a href="/fasilitas/lantai-atas" class="text-sm text-[#444444] hover:text-[#168940]">
                          Rooftop &amp; Cafeteria
                        </a>
                      </li>
                    </ul>
                  </div>
                  <div class="col-span-6 border-l border-[#dadada] pl-8">
                    <div class="bg-gradient-to-br from-[#168940] to-[#0B4226] rounded-[8px] p-6 h-full flex flex-col justify-center text-white relative overflow-hidden">
                      <div class="relative z-10">
                        <div class="w-10 h-10 rounded-[4px] bg-white/10 flex items-center justify-center mb-4 backdrop-blur-sm">
                          <iconify-icon icon="lucide:calendar" class="text-[#E53E3E]" ></iconify-icon>
                        </div>
                        <h4 class="text-lg font-semibold mb-2 tracking-tight">
                          Reservasi Ruangan Online
                        </h4>
                        <p class="text-sm text-[#BBF7D0] font-serif mb-5 leading-relaxed">
                          Pesan Ruang Multimedia, Ruang Rapat, atau Home Theater
                          untuk kegiatan akademik Anda dengan mudah.
                        </p>
                        <a href="/reservasi" class="inline-flex items-center gap-2 text-sm font-semibold bg-white text-[#0B4226] px-5 py-2.5 rounded-[4px] hover:bg-[#F0FDF4] transition-colors shadow-sm">
                          Form Reservasi
                          <iconify-icon icon="lucide:chevron-right" class="text-[#805AD5]"></iconify-icon>
                        </a>
                      </div>
                      <iconify-icon icon="lucide:building-2" class="text-[#3182CE] /5 absolute -right-4 -bottom-4"></iconify-icon>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>



          <div class="group h-full flex items-center">
            <button class="h-full flex items-center gap-1 text-sm font-semibold text-[#222222] group-hover:text-[#168940] transition-colors focus-visible:ring-[3px] focus-visible:ring-[#EAB308] outline-none">
              Literasi &amp; Publikasi
              <iconify-icon icon="lucide:chevron-down" class="text-[#805AD5]"></iconify-icon>
            </button>
            <div class="absolute left-0 top-full w-full bg-white border-b border-[#dadada] shadow-lg opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 ease-out z-50">
              <div class="max-w-[1280px] mx-auto px-4 sm:px-6 lg:px-8 py-10">
                <div class="grid grid-cols-12 gap-10">
                  <div class="col-span-3">
                    <h4 class="text-sm font-bold text-[#0B4226] uppercase tracking-wider mb-4">
                      Literasi Akademik
                    </h4>
                    <ul class="space-y-3 font-serif">
                      <li>
                        <a href="/literasi" class="text-sm text-[#444444] hover:text-[#168940]">
                          Kelas Literasi Maba
                        </a>
                      </li>
                      <li>
                        <a href="/literasi" class="text-sm text-[#444444] hover:text-[#168940]">
                          HONAI Mahasiswa
                        </a>
                      </li>
                      <li>
                        <a href="/literasi" class="text-sm text-[#444444] hover:text-[#168940]">
                          HONAI Dosen
                        </a>
                      </li>
                    </ul>
                  </div>
                  <div class="col-span-3">
                    <h4 class="text-sm font-bold text-[#0B4226] uppercase tracking-wider mb-4">
                      Pengembangan
                    </h4>
                    <ul class="space-y-3 font-serif">
                      <li>
                        <a href="/literasi" class="text-sm text-[#444444] hover:text-[#168940]">
                          Kelas Terbuka (KALISTA)
                        </a>
                      </li>
                      <li>
                        <a href="/turnitin" class="text-sm text-[#444444] hover:text-[#168940]">
                          Layanan Turnitin
                        </a>
                      </li>
                      <li>
                        <a href="/desiderata" class="text-sm text-[#444444] hover:text-[#168940]">
                          Usulan Buku (Desiderata)
                        </a>
                      </li>
                    </ul>
                  </div>
                  <div class="col-span-6 border-l border-[#dadada] pl-8">
                    <div class="bg-white border border-[#dadada] rounded-[8px] p-6 h-full flex flex-col justify-center group/card hover:border-[#BBF7D0] transition-colors relative overflow-hidden shadow-sm">
                      <div class="absolute right-0 top-0 w-32 h-32 bg-[#F0FDF4] rounded-bl-full -z-10 group-hover/card:scale-110 transition-transform duration-500"></div>
                      <span class="text-[10px] font-bold text-[#168940] uppercase tracking-wider mb-2 block">
                        Layanan Akademik
                      </span>
                      <h4 class="text-lg font-semibold text-[#222222] mb-2 tracking-tight group-hover/card:text-[#168940] transition-colors">
                        Pengecekan Plagiarisme Turnitin
                      </h4>
                      <p class="text-sm text-[#444444] font-serif mb-5 leading-relaxed">
                        Cek orisinalitas naskah karya ilmiah, skripsi, dan artikel jurnal Anda dengan Turnitin resmi perpustakaan.
                      </p>
                      <a href="/turnitin" class="inline-flex items-center gap-2 text-sm font-semibold text-[#168940] hover:text-[#0B4226]">
                        <iconify-icon icon="lucide:shield-check" class="text-[#168940]" ></iconify-icon>
                        Pelajari Selengkapnya
                      </a>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Menu: Berita & Kegiatan -->
          <div class="group h-full flex items-center">
            <a href="/berita" class="h-full flex items-center gap-1 text-sm font-semibold text-[#222222] group-hover:text-[#168940] transition-colors focus-visible:ring-[3px] focus-visible:ring-[#EAB308] outline-none">
              Berita
            </a>
          </div>

          <!-- Menu: PPID -->
          <div class="group h-full flex items-center">
            <a href="/ppid" class="h-full flex items-center gap-1 text-sm font-semibold text-[#222222] group-hover:text-[#168940] transition-colors focus-visible:ring-[3px] focus-visible:ring-[#EAB308] outline-none">
              PPID
            </a>
          </div>
        </nav>

        <div class="flex items-center gap-3">
          <!-- Custom Modern Language Switcher -->
          <div class="relative group hidden md:block">
            <button class="flex items-center justify-center w-9 h-9 rounded-full bg-slate-50 border border-slate-200 text-slate-600 hover:bg-[#F0FDF4] hover:border-[#168940] hover:text-[#168940] transition-all duration-300 focus-visible:ring-[3px] focus-visible:ring-[#EAB308] outline-none" aria-label="Pilih Bahasa">
              <iconify-icon icon="lucide:globe" class="text-[#D69E2E]" width="1.2rem"></iconify-icon>
            </button>
            
            <div class="absolute right-0 top-full mt-2 w-36 bg-white border border-slate-100 rounded-xl shadow-[0_10px_40px_-10px_rgba(0,0,0,0.1)] opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 ease-out z-50 transform origin-top-right scale-95 group-hover:scale-100 overflow-hidden">
              <div class="p-1">
                <button onclick="changeGTranslate('id')" class="w-full flex items-center gap-2 px-3 py-2.5 text-sm font-medium text-slate-700 hover:bg-[#F0FDF4] hover:text-[#168940] rounded-lg transition-colors">
                  <span class="w-5 h-5 rounded-full bg-slate-100 flex items-center justify-center text-[10px]">ID</span>
                  Indonesia
                </button>
                <button onclick="changeGTranslate('en')" class="w-full flex items-center gap-2 px-3 py-2.5 text-sm font-medium text-slate-700 hover:bg-[#F0FDF4] hover:text-[#168940] rounded-lg transition-colors">
                  <span class="w-5 h-5 rounded-full bg-slate-100 flex items-center justify-center text-[10px]">EN</span>
                  English
                </button>
                <button onclick="changeGTranslate('ar')" class="w-full flex items-center gap-2 px-3 py-2.5 text-sm font-medium text-slate-700 hover:bg-[#F0FDF4] hover:text-[#168940] rounded-lg transition-colors">
                  <span class="w-5 h-5 rounded-full bg-slate-100 flex items-center justify-center text-[10px]">AR</span>
                  العربية
                </button>
              </div>
            </div>
          </div>
          
          <!-- Hidden Native Google Translate Element -->
          <div id="google_translate_element" class="hidden"></div>
          
          <!-- Modern Expandable Search Trigger -->
          <div class="hidden lg:flex items-center">
            <button id="open-search-modal-btn" class="flex items-center justify-center w-9 h-9 rounded-full bg-slate-50 border border-slate-200 text-slate-600 hover:bg-[#F0FDF4] hover:border-[#168940] hover:text-[#168940] transition-all duration-300 focus-visible:ring-[3px] focus-visible:ring-[#EAB308] outline-none" aria-label="Buka Pencarian (Ctrl+K)">
              <iconify-icon icon="lucide:search" class="text-[#319795]" width="1.2rem"></iconify-icon>
            </button>
          </div>

          <button id="mobile-menu-btn" class="md:hidden flex items-center justify-center text-[#0B4226] p-1.5 ml-1 hover:bg-slate-100 rounded-[4px] transition-colors focus:outline-none focus-visible:ring-[3px] focus-visible:ring-[#EAB308]" aria-label="Toggle Menu">
            <iconify-icon icon="flat-color-icons:menu" width="1.75rem"></iconify-icon>
          </button>
        </div>
      </div>
      <div id="mobile-menu" class="hidden md:hidden bg-white/95 border-t border-slate-200 absolute w-full left-0 top-full shadow-xl z-50 max-h-[85vh] overflow-y-auto">
        <nav class="flex flex-col px-4 py-4 space-y-1">
          <a href="/" class="block px-3 py-2.5 text-base font-semibold text-[#222222] hover:text-[#168940] hover:bg-slate-50 rounded-md">
            Beranda
          </a>
          <div class="border-t border-slate-100 my-2"></div>
          <button class="w-full flex justify-between items-center px-3 py-2.5 text-sm font-bold text-[#0B4226] uppercase focus:outline-none" onclick="this.nextElementSibling.classList.toggle('hidden'); this.querySelector('iconify-icon').classList.toggle('rotate-180');">
            Tentang Kami
            <iconify-icon icon="lucide:chevron-down" class="text-[#319795] transition-transform duration-200"></iconify-icon>
          </button>
          <div class="hidden pl-4 pb-2 space-y-1">
            <a href="/profil" class="block px-3 py-2 text-sm text-[#444444] hover:text-[#168940] hover:bg-slate-50 rounded-md">
              Profil Singkat
            </a>
            <a href="/visi-misi" class="block px-3 py-2 text-sm text-[#444444] hover:text-[#168940] hover:bg-slate-50 rounded-md">
              Visi &amp; Misi
            </a>
            <a href="/struktur" class="block px-3 py-2 text-sm text-[#444444] hover:text-[#168940] hover:bg-slate-50 rounded-md">
