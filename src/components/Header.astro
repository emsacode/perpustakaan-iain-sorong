<script>
  // Mobile Menu Toggle Logic
  function setupMobileMenu() {
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    
    if (btn && menu) {
      // Remove old listeners to prevent duplicates
      const newBtn = btn.cloneNode(true);
      if (btn.parentNode) {
        btn.parentNode.replaceChild(newBtn, btn);
      }
      
      newBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        menu.classList.toggle('hidden');
      });
    }
  }

  // Setup on initial load
  setupMobileMenu();

  // Setup on ViewTransitions navigation
  document.addEventListener('astro:page-load', setupMobileMenu);
</script>

<script type="text/javascript">
function googleTranslateElementInit() {
  new google.translate.TranslateElement({
    pageLanguage: 'id', 
    includedLanguages: 'id,en,ar',
    autoDisplay: false
  }, 'google_translate_element');
}

function changeGTranslate(langCode) {
  // Fungsi pembantu untuk menghapus cookie dengan nama tertentu di berbagai domain & sub-domain
  const eraseCookie = (name) => {
    const hostname = window.location.hostname;
    const domains = [
      '', // default path tanpa domain eksplisit
      hostname,
      '.' + hostname
    ];
    // Masukkan root domain jika sub-domain digunakan (misal: .halsen.id dari perpustakaan.halsen.id)
    const hostParts = hostname.split('.');
    if (hostParts.length >= 2) {
      const rootDomain = hostParts.slice(-2).join('.');
      domains.push(rootDomain);
      domains.push('.' + rootDomain);
    }
    
    domains.forEach(domain => {
      let cookieBase = name + '=; expires=Thu, 01 Jan 1970 00:00:00 UTC; path=/';
      document.cookie = cookieBase; // Tanpa domain
      if (domain) {
        document.cookie = cookieBase + '; domain=' + domain;
      }
    });
  };

  // 1. Bersihkan semua cookie googtrans yang ada untuk menghindari bentrokan
  eraseCookie('googtrans');

  // 2. Jika berganti ke selain bahasa default (id), buat cookie baru
  if (langCode !== 'id') {
    const cookieValue = '/id/' + langCode;
    // Setel untuk hostname saat ini
    document.cookie = 'googtrans=' + cookieValue + '; path=/';
    
    // Setel untuk root domain (misal: .halsen.id)
    const hostname = window.location.hostname;
    const hostParts = hostname.split('.');
    if (hostParts.length >= 2) {
      const rootDomain = '.' + hostParts.slice(-2).join('.');
      document.cookie = 'googtrans=' + cookieValue + '; path=/; domain=' + rootDomain;
    }
  }
  
  // 3. Muat ulang halaman untuk menerapkan perubahan bahasa secara bersih
  window.location.reload();
}
</script>
