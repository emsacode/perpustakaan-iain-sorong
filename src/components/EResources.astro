---

<section class="py-12 bg-white border-b border-[#dadada]">
  <div class="max-w-[1280px] mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 items-start">
      
      <!-- LEFT COLUMN: Pengumuman -->
      <div class="lg:col-span-3">
        <!-- Title -->
        <h2 class="flex items-center gap-2 text-xl font-serif font-bold text-dark border-b-[2px] border-primary pb-3 mb-2">
          <iconify-icon icon="lucide:newspaper" class="text-primary text-2xl"></iconify-icon>
          Pengumuman
        </h2>

        <!-- News List (Dynamic) -->
        <div class="flex flex-col">
          {newsData.map(news => (
            <div class="py-4 border-b border-gray-100 font-sans">
              <a href={news.link} target="_blank" rel="noopener noreferrer" class="text-[13px] font-bold text-dark hover:text-primary transition-colors leading-snug line-clamp-3">
                {news.title}
              </a>
              <div class="flex items-center gap-3 mt-2 text-[11px] text-[#718096] font-medium">
                <span class="flex items-center gap-1"><iconify-icon icon="lucide:calendar"></iconify-icon> {news.date}</span>
                <span class="flex items-center gap-1"><iconify-icon icon="lucide:eye"></iconify-icon> {news.views} kali</span>
              </div>
            </div>
          ))}
        </div>

        <a href="#berita" class="flex items-center justify-between border border-[#dadada] rounded-[6px] py-2.5 px-4 mt-4 text-[13px] font-sans font-bold text-dark hover:border-primary hover:text-primary transition-colors group">
          More News
          <iconify-icon icon="lucide:arrow-right" class="text-gray-400 group-hover:text-primary transition-colors"></iconify-icon>
        </a>
      </div>

      <!-- RIGHT COLUMN: Library E-Resources -->
      <div class="lg:col-span-9">
        
        <!-- Header -->
        <div class="flex flex-col md:flex-row md:items-end justify-between border-b-[2px] border-primary pb-3 mb-6 gap-4">
          <h2 class="flex items-center gap-2 text-xl md:text-2xl font-serif font-bold text-dark leading-none">
            <iconify-icon icon="lucide:globe" class="text-primary text-2xl"></iconify-icon>
            Library E-Resources & Networks
          </h2>
          <div class="flex flex-wrap items-center gap-2 font-sans">
            <a href="/panduan-eresources" class="flex items-center gap-1.5 border border-primary text-primary hover:bg-secondary-bg px-3 py-1.5 rounded-[4px] text-[11px] font-bold transition-colors">
              <iconify-icon icon="lucide:file-text"></iconify-icon> E-Resources Subject Guide
            </a>
          </div>
        </div>

                <!-- E-Resources: Mobile Marquee -->
        <div class="md:hidden relative flex overflow-x-hidden bg-slate-50 border border-slate-100 rounded-xl py-4 group">
          <div class="absolute inset-y-0 left-0 w-8 bg-gradient-to-r from-slate-50 to-transparent z-10 pointer-events-none"></div>
          <div class="absolute inset-y-0 right-0 w-8 bg-gradient-to-l from-slate-50 to-transparent z-10 pointer-events-none"></div>
          
          <div class="animate-marquee flex whitespace-nowrap items-center gap-3 group-hover:[animation-play-state:paused]">
            {Array(2).fill(null).map(() => (
              <div class="grid grid-rows-2 grid-flow-col gap-3 px-1.5">
                {internationalResources.map(res => (
                  <a href={res.url} target="_blank" rel="noopener noreferrer" class="h-12 w-28 shrink-0 border border-gray-200 rounded-[6px] flex items-center justify-center hover:border-[#0284C7] transition-all bg-white p-2" title={res.name}>
                    <img src={res.logo} alt={res.name} class="max-h-full max-w-full object-contain" loading="lazy" />
                  </a>
                ))}
              </div>
            ))}
          </div>
        </div>

        <!-- E-Resources: Desktop Grid -->
        <div class="hidden md:flex flex-wrap items-center justify-center gap-4 bg-slate-50 border border-slate-100 rounded-xl py-6 px-6">
          {internationalResources.map(res => (
            <a href={res.url} target="_blank" rel="noopener noreferrer" class="h-14 w-32 border border-gray-200 rounded-[6px] flex items-center justify-center hover:border-[#0284C7] transition-all bg-white p-2" title={res.name}>
              <img src={res.logo} alt={res.name} class="max-h-full max-w-full object-contain" loading="lazy" />
            </a>
          ))}
        </div>

        <!-- Networks / Integrations: Mobile Marquee -->
        <div class="md:hidden relative flex overflow-x-hidden mt-6 group">
          <div class="absolute inset-y-0 left-0 w-8 bg-gradient-to-r from-white to-transparent z-10 pointer-events-none"></div>
          <div class="absolute inset-y-0 right-0 w-8 bg-gradient-to-l from-white to-transparent z-10 pointer-events-none"></div>
          
          <div class="animate-marquee flex whitespace-nowrap items-center gap-4 group-hover:[animation-play-state:paused]">
            {Array(2).fill(null).map(() => (
              <div class="flex items-center gap-4 px-2">
                {localResources.map(res => (
                  res.type === "icon" ? (
                    <a href={res.url} target="_blank" rel="noopener noreferrer" class="h-16 w-48 border border-gray-200 rounded-[6px] flex items-center justify-center gap-2 hover:border-[#0284C7] hover:shadow-sm transition-all bg-white p-2" title={res.name}>
                      <iconify-icon icon={res.icon} class="text-2xl text-[#0284C7]"></iconify-icon>
                      <span class="font-sans font-bold text-[12px] text-center text-[#0284C7] leading-tight" set:html={res.htmlName}></span>
                    </a>
                  ) : (
                    <a href={res.url} target="_blank" rel="noopener noreferrer" class="h-16 w-48 border border-gray-200 rounded-[6px] flex items-center justify-center hover:border-[#0284C7] hover:shadow-sm transition-all bg-white p-2" title={res.name}>
                      <img src={res.logo} alt={res.name} class="max-h-full max-w-full object-contain" loading="lazy" />
                    </a>
                  )
                ))}
              </div>
            ))}
          </div>
        </div>

        <!-- Networks / Integrations: Desktop Grid -->
        <div class="hidden md:grid mt-10 grid-cols-5 gap-4">
          {localResources.map(res => (
            res.type === "icon" ? (
              <a href={res.url} target="_blank" rel="noopener noreferrer" class="h-16 border border-gray-200 rounded-[6px] flex items-center justify-center gap-2 hover:border-[#0284C7] hover:shadow-sm transition-all bg-white group overflow-hidden p-2" title={res.name}>
                <iconify-icon icon={res.icon} class="text-2xl text-[#0284C7] group-hover:scale-110 transition-transform"></iconify-icon>
                <span class="font-sans font-bold text-[13px] text-center text-[#0284C7] leading-tight" set:html={res.htmlName}></span>
              </a>
            ) : (
              <a href={res.url} target="_blank" rel="noopener noreferrer" class="h-16 border border-gray-200 rounded-[6px] flex items-center justify-center hover:border-[#0284C7] hover:shadow-sm transition-all bg-white group overflow-hidden p-2" title={res.name}>
                <img src={res.logo} alt={res.name} class="max-h-full max-w-full object-contain group-hover:scale-105 transition-transform" loading="lazy" />
              </a>
            )
          ))}
        </div>



      </div>

    </div>
  </div>
</section>

<style>
  @keyframes marquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
  .animate-marquee {
    animation: marquee 35s linear infinite;
    width: max-content;
  }
</style>
