<script>
  function setupERCarousel() {
    const erCarousel = document.getElementById('er-resources-carousel');
    const dots = [
      document.getElementById('er-dot-1'),
      document.getElementById('er-dot-2'),
      document.getElementById('er-dot-3'),
      document.getElementById('er-dot-4'),
      document.getElementById('er-dot-5')
    ];
    
    if (erCarousel && dots.every(d => d)) {
      erCarousel.addEventListener('scroll', () => {
        const scrollLeft = erCarousel.scrollLeft;
        const width = erCarousel.clientWidth;
        const activeIndex = Math.round(scrollLeft / width);
        
        dots.forEach((dot, idx) => {
          if (idx === activeIndex) {
            dot.className = 'w-4 h-1.5 rounded-full bg-[#168940] transition-all duration-300';
          } else {
            dot.className = 'w-1.5 h-1.5 rounded-full bg-slate-300 transition-all duration-300';
          }
        });
      });
    }
  }

  // Setup on load
  setupERCarousel();
  document.addEventListener('astro:page-load', setupERCarousel);
</script>
