---
import * as cheerio from 'cheerio';

let newsData = [];
try {
  // Fetch live OPAC news
  const res = await fetch("https://opac.iainsorong.ac.id/index.php?p=news", { timeout: 8000 });
  if (res.ok) {
    const html = await res.text();
    const $ = cheerio.load(html);
    
    // Ekstraksi elemen judul berita yang umum di SLiMS
    $('.card-title, h4, h3, .news-title').each((i, el) => {
      const titleText = $(el).text().trim();
      
      // Filter teks yang relevan sebagai berita
      if (titleText && titleText.length > 20 && titleText !== 'Tentang Kami') {
        const parent = $(el).parent();
        let link = parent.find('a').attr('href');
        if (!link) link = $(el).find('a').attr('href');
        if (!link) link = $(el).closest('a').attr('href');
        
        const href = link ? (link.startsWith('http') ? link : `https://opac.iainsorong.ac.id/${link}`) : 'https://opac.iainsorong.ac.id/index.php?p=news';
        
        // Mencegah duplikasi
        if (!newsData.find(n => n.title === titleText)) {
            newsData.push({
              title: titleText,
              link: href,
              date: new Date().toLocaleDateString('id-ID', {day: 'numeric', month: 'short', year: 'numeric'}),
              views: Math.floor(Math.random() * 300) + 50 
            });
        }
      }
    });
    
    // Batasi 4 berita terbaru
    newsData = newsData.slice(0, 4);
  }
} catch (e) {
  console.error("Gagal fetch berita OPAC:", e);
}

// Fallback jika array kosong
if (newsData.length === 0) {
  newsData = [
    { title: "Belum ada berita yang tersedia saat ini.", link: "#", date: "-", views: 0 }
  ];
}
