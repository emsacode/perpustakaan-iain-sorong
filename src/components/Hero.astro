---
---
<!-- Hero Section -->
    <section class="relative bg-[#0B4226] overflow-hidden">
      <!-- Abstract Academic Background Image (Slideshow) -->
      <div class="absolute inset-0 z-0 opacity-50" id="hero-slideshow">
        <img src="/images/slide/slide1.jpg" alt="Slide 1" class="absolute inset-0 w-full h-full object-cover transition-opacity duration-[1500ms] opacity-100 slide-img">
        <img src="/images/slide/slide2.jpg" alt="Slide 2" class="absolute inset-0 w-full h-full object-cover transition-opacity duration-[1500ms] opacity-0 slide-img">
        <img src="/images/slide/slide3.jpg" alt="Slide 3" class="absolute inset-0 w-full h-full object-cover transition-opacity duration-[1500ms] opacity-0 slide-img">
      </div>
      <script>
        document.addEventListener('DOMContentLoaded', () => {
          const slides = document.querySelectorAll('.slide-img');
          let current = 0;
          if(slides.length > 0) {
            setInterval(() => {
              slides[current].classList.replace('opacity-100', 'opacity-0');
              current = (current + 1) % slides.length;
              slides[current].classList.replace('opacity-0', 'opacity-100');
            }, 5000); // Change image every 5 seconds
          }
        });
      </script>
      <div class="absolute inset-0 z-10 bg-gradient-to-t from-[#0B4226]/90 via-[#0B4226]/60 to-transparent"></div>

      <div class="max-w-[1280px] mx-auto px-4 sm:px-6 lg:px-8 py-20 lg:py-28 relative z-20 flex flex-col items-center text-center">
        <span class="text-xs font-semibold tracking-widest text-[#BBF7D0] uppercase mb-4 block">
          Center of Excellence for Information Resources
        </span>
        <h1 class="text-2xl sm:text-3xl md:text-4xl lg:text-5xl tracking-tight font-semibold text-white max-w-4xl leading-tight mb-6">
          Panduan &amp; Informasi Layanan
          <br>
          Perpustakaan IAIN Sorong
        </h1>
        <p class="font-serif text-lg text-[#F0FDF4] max-w-2xl mx-auto mb-10 leading-relaxed opacity-90">
          "Membaca adalah jendela dunia, perpustakaan adalah kuncinya."
          Mendukung Tridharma Perguruan Tinggi berbasis local wisdom dan
          moderasi beragama di tanah Papua.
        </p>

        <!-- Search Component -->
        <div class="w-full max-w-4xl mx-auto flex flex-col gap-2 sm:gap-4 bg-white p-2 sm:p-4 rounded-[1rem] sm:rounded-[2rem] shadow-2xl">
          <div class="flex flex-nowrap sm:flex-wrap overflow-x-auto items-center gap-1.5 sm:gap-2 px-1 sm:px-2 pt-1 pb-2 sm:pb-3 [&::-webkit-scrollbar]:hidden [-ms-overflow-style:none] [scrollbar-width:none]" id="search-tabs-container">
            <button type="button" data-type="opac" data-placeholder="Cari judul buku, pengarang, penerbit, atau kata kunci (SLiMS OPAC)..." class="search-tab shrink-0 px-3 sm:px-5 py-1.5 sm:py-2.5 text-xs sm:text-sm font-normal rounded-full transition-all duration-300 bg-[#168940] text-white shadow-md flex items-center gap-2">
              <iconify-icon icon="lucide:book-open" class="text-[#38A169]" width="1rem"></iconify-icon>
              Katalog Buku (OPAC)
            </button>
            <button type="button" data-type="archive" data-placeholder="Cari skripsi, tesis, disertasi, atau tugas akhir mahasiswa..." class="search-tab shrink-0 px-3 sm:px-5 py-1.5 sm:py-2.5 text-xs sm:text-sm font-normal rounded-full transition-all duration-300 bg-slate-100 text-slate-600 hover:bg-slate-200 flex items-center gap-2">
              <iconify-icon icon="lucide:archive" class="text-[#E53E3E]" width="1rem"></iconify-icon>
              Repository Ilmiah
            </button>
            <button type="button" data-type="journal" data-placeholder="Cari artikel ilmiah, publikasi dosen, atau e-journal..." class="search-tab shrink-0 px-3 sm:px-5 py-1.5 sm:py-2.5 text-xs sm:text-sm font-normal rounded-full transition-all duration-300 bg-slate-100 text-slate-600 hover:bg-slate-200 flex items-center gap-2">
              <iconify-icon icon="lucide:file-text" class="text-[#3182CE]" width="1rem"></iconify-icon>
              Rumah Jurnal (OJS)
            </button>
            <button type="button" data-type="scholar" data-placeholder="Cari artikel ilmiah, penulis, atau publikasi di Google Scholar..." class="search-tab shrink-0 px-3 sm:px-5 py-1.5 sm:py-2.5 text-xs sm:text-sm font-normal rounded-full transition-all duration-300 bg-slate-100 text-slate-600 hover:bg-slate-200 flex items-center gap-2">
              <iconify-icon icon="lucide:graduation-cap" class="text-[#D69E2E]" width="1rem"></iconify-icon>
              Google Scholar
            </button>
          </div>

          <div class="bg-slate-50 border-2 border-slate-100 rounded-xl sm:rounded-2xl p-1.5 flex focus-within:border-[#168940]/30 focus-within:ring-4 focus-within:ring-[#168940]/10 focus-within:bg-white transition-all duration-300">
            <div class="pl-3 sm:pl-4 flex items-center text-slate-400">
              <iconify-icon icon="lucide:search" class="text-[#DD6B20]" width="1.25rem"></iconify-icon>
            </div>
            <input id="main-search-input" type="text" placeholder="Cari judul buku, pengarang, penerbit, atau kata kunci (SLiMS OPAC)..." class="w-full pl-3 pr-4 py-2.5 sm:py-3 text-[15px] text-slate-800 bg-transparent border-none outline-none font-sans placeholder:text-slate-400">
            <button type="button" id="execute-search-btn" class="bg-[#168940] text-white px-5 sm:px-8 py-2.5 rounded-lg sm:rounded-xl text-sm font-normal hover:bg-[#0B4226] transition-all duration-300 whitespace-nowrap flex items-center gap-2 shadow-sm">
              Cari
              <span class="hidden sm:inline">Koleksi</span>
              <iconify-icon icon="lucide:chevron-right" class="text-[#805AD5] hidden sm:inline-block" width="1rem"></iconify-icon>
            </button>
          </div>

          <script>
            let currentSearchType = 'opac'; // default state
            const input = document.getElementById('main-search-input');
            const searchBtn = document.getElementById('execute-search-btn');
            const tabs = document.querySelectorAll('.search-tab');

            if (input && searchBtn && tabs.length) {
              tabs.forEach(tab => {
                tab.addEventListener('click', (e) => {
                  const target = e.currentTarget;
                  const type = target.getAttribute('data-type') || 'opac';
                  const placeholder = target.getAttribute('data-placeholder') || '';

                  // Update input state
                  input.placeholder = placeholder;
                  input.focus();
                  currentSearchType = type;

                  // Update tabs styling
                  tabs.forEach(t => {
                    t.classList.remove('bg-[#168940]', 'text-white', 'shadow-md');
                    t.classList.add('bg-slate-100', 'text-slate-600', 'hover:bg-slate-200');
                  });

                  target.classList.remove('bg-slate-100', 'text-slate-600', 'hover:bg-slate-200');
                  target.classList.add('bg-[#168940]', 'text-white', 'shadow-md');
                });
              });

              function executeSearch() {
                const query = input.value.trim();
                if (!query) return;

                if (currentSearchType === 'opac') {
                  window.location.href = `/koleksi/katalog?q=${encodeURIComponent(query)}`;
                  return;
                }

                let url = '';
                switch (currentSearchType) {
                  case 'archive':
                    // Mengarah ke EPrints Repository
                    url = `https://repositori.iainsorong.ac.id/cgi/search/archive/simple?q=${encodeURIComponent(query)}`;
                    break;
                  case 'journal':
                    // Mengarah ke Rumah Jurnal OJS
                    url = `https://e-jurnal.iainsorong.ac.id/index.php/index/search/search?query=${encodeURIComponent(query)}`;
                    break;
                  case 'scholar':
                    // Mengarah ke Google Scholar
                    url = `https://scholar.google.com/scholar?q=${encodeURIComponent(query)}`;
                    break;
                }
                
                window.open(url, '_blank');
              }

              searchBtn.addEventListener('click', executeSearch);

              input.addEventListener('keypress', (e) => {
                if (e.key === 'Enter') {
                  executeSearch();
                }
              });
            }
          </script>
        </div>
      </div>
    </section>