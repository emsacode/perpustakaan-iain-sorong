  <script is:inline>
    async function fetchVisitorStats() {
      try {
        const statsResponse = await fetch('/api/live-analytics.json');
        
        if (!statsResponse.ok) {
          throw new Error(`Local API failed with status ${statsResponse.status}`);
        }
        
        const statsData = await statsResponse.json();
        const data = statsData.data;
        
        if (data) {
          const format = (num) => typeof num === 'number' ? num.toLocaleString('id-ID') : num;
          
          const elTahunIni = document.getElementById('ga-tahun-ini');
          if (elTahunIni && data.tahun_ini !== undefined) elTahunIni.innerText = format(data.tahun_ini);
          
          const elBulanIni = document.getElementById('ga-bulan-ini');
          if (elBulanIni && data.bulan_ini !== undefined) elBulanIni.innerText = format(data.bulan_ini);
          
          const elHariIni = document.getElementById('ga-hari-ini');
          if (elHariIni && data.hari_ini !== undefined) elHariIni.innerText = format(data.hari_ini);
          
          const elOnline = document.getElementById('ga-online');
          if (elOnline && data.online !== undefined) {
            elOnline.innerHTML = `
              <span class="relative flex h-2 w-2">
                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
                <span class="relative inline-flex rounded-full h-2 w-2 bg-green-500"></span>
              </span>
              ${format(data.online)}
            `;
          }
        }
      } catch (error) {
        console.error("Gagal memuat statistik GA4:", error);
      }
    }
    
    // Panggilan pertama saat dimuat
    fetchVisitorStats();
    // Sinkronisasi otomatis tiap 2 menit
    setInterval(fetchVisitorStats, 120000);
  </script>
</footer>

<script>
function getWITDateTime() {
  const formatter = new Intl.DateTimeFormat('id-ID', {
    timeZone: 'Asia/Jayapura',
    hour: 'numeric',
    minute: 'numeric',
    weekday: 'long',
    hour12: false
  });
  const parts = formatter.formatToParts(new Date());
  const dayName = parts.find(p => p.type === 'weekday').value;
  const hourVal = parseInt(parts.find(p => p.type === 'hour').value, 10);
  const minuteVal = parseInt(parts.find(p => p.type === 'minute').value, 10);
  
  const daysMap = { 'Minggu': 0, 'Senin': 1, 'Selasa': 2, 'Rabu': 3, 'Kamis': 4, 'Jumat': 5, 'Sabtu': 6 };
  const day = daysMap[dayName] !== undefined ? daysMap[dayName] : 0;
  
  return {
    day,
    dayName,
    hours: hourVal,
    minutes: minuteVal,
    time: hourVal + minuteVal / 60
  };
}

function updateFooterStatusHospitality() {
  const wit = getWITDateTime();
  const day = wit.day;
  const time = wit.time;
  const hours = wit.hours;
  const minutes = wit.minutes;
  
  const dot = document.getElementById('footer-op-dot');
  const text = document.getElementById('footer-op-text');
  
  if (!dot || !text) return;
  
  let isOpen = false;
  if (day >= 1 && day <= 5) {
    if (time >= 8 && time < 15.5) isOpen = true;
  }
  
  if (isOpen) {
    dot.className = "shrink-0 w-2 h-2 rounded-full bg-[#168940] shadow-[0_0_0_3px_rgba(22,137,64,0.2)] animate-pulse";
    text.textContent = "Buka Sekarang";
    text.className = "text-[#168940]";
  } else {
    dot.className = "shrink-0 w-2 h-2 rounded-full bg-red-500 shadow-[0_0_0_3px_rgba(239,68,68,0.2)]";
    text.textContent = "Sedang Tutup";
    text.className = "text-red-400";
  }
  
  // Update Live Clock
  const clockEl = document.getElementById('footer-op-clock');
  const dayEl = document.getElementById('footer-op-day');
  if (clockEl && dayEl) {
    clockEl.textContent = `${String(hours).padStart(2, '0')}:${String(minutes).padStart(2, '0')}`;
    dayEl.textContent = `${wit.dayName}, WIT`;
  }
  
  // Highlight active pill
  for (let i = 0; i <= 6; i++) {
    const el = document.getElementById('f-day-' + i);
    if (!el) continue;
    
    if (i === day) {
      el.classList.remove('bg-white/5', 'text-[#BBF7D0]/70', 'text-[#BBF7D0]/30');
      el.classList.add('bg-[#168940]', 'text-white', 'shadow-sm', 'scale-[1.03]', 'z-10');
    } else {
      el.classList.remove('bg-[#168940]', 'text-white', 'shadow-sm', 'scale-[1.03]', 'z-10');
      if (i === 0 || i === 6) {
        el.classList.add('text-[#BBF7D0]/30');
      } else {
        el.classList.add('bg-white/5', 'text-[#BBF7D0]/70');
      }
    }
  }
}

setInterval(updateFooterStatusHospitality, 1000);
setTimeout(updateFooterStatusHospitality, 100);
document.addEventListener('astro:page-load', updateFooterStatusHospitality);
</script>
